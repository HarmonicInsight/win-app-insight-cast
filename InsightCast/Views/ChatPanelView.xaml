<UserControl x:Class="InsightCast.Views.ChatPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:InsightCast.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <Border Background="{DynamicResource BgPrimary}"
            BorderBrush="{DynamicResource BorderDefault}"
            BorderThickness="1,0,0,0"
            TextBlock.FontFamily="{DynamicResource AppFontFamily}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>              <!-- 0: Header -->
                <RowDefinition Height="Auto"/>              <!-- 1: API Key Panel -->
                <RowDefinition Height="2*" MinHeight="30"/> <!-- 2: Prompts area -->
                <RowDefinition Height="Auto"/>              <!-- 3: Splitter -->
                <RowDefinition Height="3*" MinHeight="30"/> <!-- 4: Execution area -->
            </Grid.RowDefinitions>

            <!-- ═══ Row 0: Header ═══ -->
            <Border Grid.Row="0" Style="{StaticResource PanelHeaderStyle}">
                <DockPanel>
                    <!-- Left: Title + Help -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource Chat.Title}"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="{DynamicResource BrandPrimary}"
                                   VerticalAlignment="Center"/>
                        <Button Style="{StaticResource SmallButton}"
                                Click="HelpButton_Click"
                                ToolTip="{DynamicResource PromptLib.Help.Tooltip}"
                                Padding="3,1" Margin="6,0,0,0" FontSize="10" MinWidth="0" MinHeight="0">
                            <TextBlock Text="&#xE897;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                        </Button>
                    </StackPanel>

                    <!-- Right: Prompt Editor + PopOut + Settings -->
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Style="{StaticResource SmallButton}"
                                Command="{Binding OpenPromptEditorCommand}"
                                ToolTip="{DynamicResource Ai.PromptEditor}"
                                Content="{DynamicResource Ai.PromptEditor}"
                                FontSize="11" Padding="8,3" Margin="0,0,4,0"/>
                        <Button Style="{StaticResource SmallButton}"
                                Click="PopOutButton_Click"
                                ToolTip="{DynamicResource Ai.Popout}"
                                FontSize="12" Padding="4,2" Margin="0,0,2,0">
                            <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        </Button>
                        <Button Style="{StaticResource SmallButton}"
                                Command="{Binding ToggleApiKeyPanelCommand}"
                                ToolTip="{DynamicResource Ai.ApiKeySettings}"
                                FontSize="14" Padding="4,2">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ═══ Row 1: API Key Panel (collapsible) ═══ -->
            <Border Grid.Row="1"
                    Background="{DynamicResource BgSecondary}"
                    BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,0,0,1"
                    Padding="8,6"
                    Visibility="{Binding IsApiKeyPanelOpen, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <!-- Claude API Key -->
                    <TextBlock Text="{DynamicResource Ai.EnterApiKey}"
                               FontSize="10"
                               Foreground="{DynamicResource TextSecondary}"
                               Visibility="{Binding IsApiKeySet, Converter={StaticResource InverseBoolToVis}}"
                               Margin="0,0,0,4"/>
                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Content="{DynamicResource Ai.SetBtn}"
                                Style="{StaticResource PrimaryButton}"
                                Padding="10,4" Margin="4,0,0,0" FontSize="10"
                                Command="{Binding SetApiKeyCommand}"/>
                        <PasswordBox x:Name="ApiKeyBox" FontSize="10" Padding="6,4"
                                     PasswordChanged="ApiKeyBox_PasswordChanged"/>
                    </DockPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                Visibility="{Binding IsApiKeySet, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="✓ " FontSize="9" Foreground="{DynamicResource Success}"/>
                        <TextBlock Text="{DynamicResource Chat.ApiKeyStatus}" FontSize="9"
                                   Foreground="{DynamicResource TextTertiary}"/>
                    </StackPanel>

                    <!-- OpenAI API Key -->
                    <Border BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,1,0,0"
                            Margin="0,8,0,0" Padding="0,8,0,0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Ai.OpenAIApiKey}"
                                       FontSize="10" Foreground="{DynamicResource TextSecondary}"
                                       Margin="0,0,0,4"/>
                            <DockPanel>
                                <Button DockPanel.Dock="Right"
                                        Content="{DynamicResource Ai.SetOpenAIBtn}"
                                        Style="{StaticResource PrimaryButton}"
                                        Padding="10,4" Margin="4,0,0,0" FontSize="10"
                                        Command="{Binding SetOpenAIApiKeyCommand}"/>
                                <PasswordBox x:Name="OpenAIApiKeyBox" FontSize="10" Padding="6,4"
                                             PasswordChanged="OpenAIApiKeyBox_PasswordChanged"/>
                            </DockPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                        Visibility="{Binding IsOpenAIApiKeySet, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="✓ " FontSize="9" Foreground="{DynamicResource Success}"/>
                                <TextBlock Text="{DynamicResource Ai.OpenAIApiKeyStatus}" FontSize="9"
                                           Foreground="{DynamicResource TextTertiary}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

            <!-- ═══ Row 2: My Prompts + Preset Prompts ═══ -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8,6">

                    <!-- Mode Toggle (Text / Image filter) -->
                    <DockPanel Margin="0,0,0,6">
                        <!-- Active model (right) -->
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding ActiveModelDisplay}"
                                   FontSize="9" Foreground="{DynamicResource TextTertiary}"
                                   VerticalAlignment="Center"/>

                        <!-- Text / Image toggle (left) -->
                        <Border Background="{DynamicResource BgSecondary}" CornerRadius="8"
                                BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1"
                                Padding="2" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <Button Padding="6,3" FontSize="10" Margin="0,0,2,0"
                                        Click="TextModeButton_Click" Cursor="Hand">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsImageMode}" Value="False">
                                                    <Setter Property="Background" Value="{StaticResource BgPrimary}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8BD;" FontFamily="Segoe MDL2 Assets" FontSize="10" Margin="0,0,4,0"/>
                                        <TextBlock Text="{DynamicResource Ai.TextMode}" FontSize="10"/>
                                    </StackPanel>
                                </Button>
                                <Button Padding="6,3" FontSize="10"
                                        Click="ImageModeButton_Click" Cursor="Hand">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsImageMode}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource BgPrimary}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xEB9F;" FontFamily="Segoe MDL2 Assets" FontSize="10" Margin="0,0,4,0"/>
                                        <TextBlock Text="{DynamicResource Ai.ImageMode}" FontSize="10"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </DockPanel>

                    <!-- Usage Stats (inline) -->
                    <WrapPanel Margin="0,0,0,6">
                        <TextBlock FontSize="9" Foreground="{DynamicResource TextTertiary}" Margin="0,0,12,0">
                            <Run Text="{DynamicResource Chat.UsageCalls}"/>
                            <Run Text="{Binding ApiCalls, Mode=OneWay}" FontWeight="SemiBold"/>
                        </TextBlock>
                        <TextBlock FontSize="9" Foreground="{DynamicResource TextTertiary}" Margin="0,0,12,0">
                            <Run Text="{DynamicResource Chat.UsageTokens}"/>
                            <Run Text="{Binding InputTokens, Mode=OneWay}" FontWeight="SemiBold"/>
                            <Run Text="/"/>
                            <Run Text="{Binding OutputTokens, Mode=OneWay}" FontWeight="SemiBold"/>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource Chat.UsageCost}" FontSize="9"
                                       Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding CostDisplay, Mode=OneWay}" FontSize="9" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </WrapPanel>

                    <!-- My Prompts Toggle -->
                    <ToggleButton IsChecked="{Binding IsUserPromptsVisible}"
                                  Style="{StaticResource PanelToggleButtonStyle}"
                                  HorizontalAlignment="Left"
                                  Padding="4,2" Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource Ai.MyPrompts}"
                                       FontSize="10.5" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="&#x25BC;" FontSize="8" Margin="4,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>

                    <!-- My Prompts List -->
                    <StackPanel Visibility="{Binding IsUserPromptsVisible, Converter={StaticResource BoolToVis}}">
                        <!-- Empty state -->
                        <TextBlock Text="{DynamicResource Ai.MyPromptsEmpty}"
                                   FontSize="10" Foreground="{DynamicResource TextTertiary}"
                                   FontStyle="Italic" Margin="0,2,0,4">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasUserPrompts}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- User prompt groups -->
                        <ItemsControl ItemsSource="{Binding UserPromptGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,4">
                                        <TextBlock Text="{Binding CategoryName}"
                                                   FontSize="9.5" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   Margin="0,2,0,2"/>
                                        <ItemsControl ItemsSource="{Binding Prompts}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Style="{StaticResource PresetChipStyle}"
                                                            ToolTip="{Binding Tooltip}"
                                                            Command="{Binding DataContext.LoadUserPromptToEditorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Margin="0,0,4,4">
                                                        <Button.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="{DynamicResource PromptLib.Menu.Edit}"
                                                                          Click="UserPromptEdit_Click"
                                                                          Padding="8,4"/>
                                                                <MenuItem Header="{DynamicResource PromptLib.Menu.Duplicate}"
                                                                          Click="UserPromptDuplicate_Click"
                                                                          Padding="8,4"/>
                                                                <Separator/>
                                                                <MenuItem Header="{DynamicResource PromptLib.Menu.Delete}"
                                                                          Click="UserPromptDelete_Click"
                                                                          Padding="8,4"/>
                                                            </ContextMenu>
                                                        </Button.ContextMenu>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Icon}" Margin="0,0,4,0"/>
                                                            <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding ModelDisplay}" FontSize="8"
                                                                       Foreground="{DynamicResource TextTertiary}"
                                                                       Margin="4,0,0,0" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Preset Prompts Toggle (inline) -->
                    <ToggleButton IsChecked="{Binding IsPresetPromptsVisible}"
                                  Style="{StaticResource PanelToggleButtonStyle}"
                                  HorizontalAlignment="Left"
                                  Padding="4,2" Margin="0,4,0,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource Ai.PresetPrompts}"
                                       FontSize="10.5" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="&#x25BC;" FontSize="8" Margin="4,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>

                    <!-- Preset Prompts List (inline, filtered by mode) -->
                    <StackPanel Visibility="{Binding IsPresetPromptsVisible, Converter={StaticResource BoolToVis}}">
                        <ItemsControl ItemsSource="{Binding PresetPromptGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,4">
                                        <TextBlock Text="{Binding CategoryName}"
                                                   FontSize="9" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   Margin="0,2,0,2"/>
                                        <ItemsControl ItemsSource="{Binding Prompts}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Style="{StaticResource PresetChipStyle}"
                                                            ToolTip="{Binding Tooltip}"
                                                            Command="{Binding DataContext.LoadPresetToEditorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Margin="0,0,4,4">
                                                        <Button.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="{DynamicResource PromptLib.DuplicatePreset}"
                                                                          Click="PresetDuplicate_Click"
                                                                          Padding="8,4"/>
                                                            </ContextMenu>
                                                        </Button.ContextMenu>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Icon}" Margin="0,0,4,0"/>
                                                            <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding ModelDisplay}" FontSize="8"
                                                                       Foreground="{DynamicResource TextTertiary}"
                                                                       Margin="4,0,0,0" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Inline Edit Panel -->
                    <Border Background="{DynamicResource BgSecondary}"
                            BorderBrush="{DynamicResource BrandPrimary}"
                            BorderThickness="1" CornerRadius="4"
                            Margin="0,6,0,0" Padding="10,8"
                            Visibility="{Binding IsEditingPrompt, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource PromptLib.Edit.Title}"
                                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <DockPanel Margin="0,0,0,4">
                                <TextBox DockPanel.Dock="Left"
                                         Text="{Binding EditIcon, UpdateSourceTrigger=PropertyChanged}"
                                         Width="36" FontSize="12" Padding="4,3" Margin="0,0,6,0"
                                         MaxLength="4" TextAlignment="Center"
                                         ToolTip="{DynamicResource PromptLib.Edit.Icon.Placeholder}"/>
                                <TextBox Text="{Binding EditLabel, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="10" Padding="6,3"
                                         ToolTip="{DynamicResource PromptLib.Save.Label.Placeholder}"/>
                            </DockPanel>
                            <TextBox Text="{Binding EditCategory, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="10" Padding="6,3" Margin="0,0,0,4"
                                     ToolTip="{DynamicResource PromptLib.Save.Category.Placeholder}"/>
                            <TextBox Text="{Binding EditPrompt, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="10" Padding="6,3" Margin="0,0,0,6"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     MinLines="3" MaxLines="8"
                                     VerticalScrollBarVisibility="Auto"
                                     ToolTip="{DynamicResource PromptLib.Edit.Prompt.Placeholder}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="{DynamicResource PromptLib.Edit.Cancel}"
                                        Style="{StaticResource SmallButton}"
                                        FontSize="10" Padding="10,4" Margin="0,0,6,0"
                                        Command="{Binding CancelEditCommand}"/>
                                <Button Content="{DynamicResource PromptLib.Edit.Confirm}"
                                        Style="{StaticResource PrimaryButton}"
                                        FontSize="10" Padding="10,4"
                                        Command="{Binding ConfirmEditCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Save Prompt Panel -->
                    <Border Background="{DynamicResource BgSecondary}"
                            BorderBrush="{DynamicResource BrandPrimary}"
                            BorderThickness="1" CornerRadius="4"
                            Margin="0,6,0,0" Padding="10,8"
                            Visibility="{Binding IsSavePromptPanelOpen, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource PromptLib.Save.Title}"
                                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding SavePromptText}" FontSize="9"
                                       Foreground="{DynamicResource TextTertiary}"
                                       TextTrimming="CharacterEllipsis" MaxHeight="32"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="{DynamicResource PromptLib.Save.Label}" FontSize="9"
                                       Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding SavePromptLabel, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="10" Padding="6,3" Margin="0,0,0,4"
                                     ToolTip="{DynamicResource PromptLib.Save.Label.Placeholder}"/>
                            <TextBlock Text="{DynamicResource PromptLib.Save.Category}" FontSize="9"
                                       Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding SavePromptCategory, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="10" Padding="6,3" Margin="0,0,0,4"
                                     ToolTip="{DynamicResource PromptLib.Save.Category.Placeholder}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="{DynamicResource PromptLib.Save.Cancel}"
                                        Style="{StaticResource SmallButton}"
                                        FontSize="10" Padding="10,4" Margin="0,0,6,0"
                                        Command="{Binding CancelSavePromptCommand}"/>
                                <Button Content="{DynamicResource PromptLib.Save.Confirm}"
                                        Style="{StaticResource PrimaryButton}"
                                        FontSize="10" Padding="10,4"
                                        Command="{Binding ConfirmSavePromptCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ═══ Row 3: GridSplitter ═══ -->
            <GridSplitter Grid.Row="3"
                          Height="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Background="{DynamicResource BorderDefault}"
                          Cursor="SizeNS"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- ═══ Row 4: Execution Area (includes processing indicator) ═══ -->
            <DockPanel Grid.Row="4" Margin="0">

                <!-- Top: Processing Indicator -->
                <Border DockPanel.Dock="Top"
                        Padding="8,4"
                        Background="{DynamicResource BgSecondary}"
                        Visibility="{Binding IsAiProcessing, Converter={StaticResource BoolToVis}}">
                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Content="{DynamicResource Chat.Cancel}"
                                Style="{StaticResource SmallButton}"
                                FontSize="9" Padding="8,3"
                                Command="{Binding CancelCommand}"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding AiProcessingModelName}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrandPrimary}"
                                       Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding AiProcessingText}"
                                       FontSize="10" Foreground="{DynamicResource TextSecondary}"
                                       FontStyle="Italic" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Bottom: Save + Execute Buttons -->
                <DockPanel DockPanel.Dock="Bottom" Margin="8,6,8,6">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="{DynamicResource Ai.Execute}"
                                Style="{StaticResource PrimaryButton}"
                                Padding="12,6" FontSize="11" FontWeight="SemiBold"
                                Command="{Binding ExecutePromptCommand}"
                                IsEnabled="{Binding IsAiProcessing, Converter={StaticResource InverseBool}}"
                                AutomationProperties.Name="Execute prompt"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource SmallButton}"
                                Command="{Binding SaveAsUserPromptCommand}"
                                ToolTip="{DynamicResource Ai.SaveAsPrompt}"
                                FontSize="14" Padding="4,2" Margin="0,0,2,0"
                                IsEnabled="{Binding IsAiProcessing, Converter={StaticResource InverseBool}}">
                            <TextBlock Text="&#x1F4BE;" FontSize="14"/>
                        </Button>
                    </StackPanel>
                </DockPanel>

                <!-- Bottom: Result Display -->
                <Border DockPanel.Dock="Bottom"
                        Background="{DynamicResource BgSecondary}"
                        CornerRadius="4" Padding="8,6" Margin="8,6,8,0"
                        Visibility="{Binding IsLastAiResultVisible, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Ai.Result}"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrandPrimary}"
                                   Margin="0,0,0,4"/>
                        <TextBox Text="{Binding LastAiResult, Mode=OneWay}"
                                 TextWrapping="Wrap" FontSize="11"
                                 Background="Transparent" BorderThickness="0"
                                 IsReadOnly="True"
                                 MaxHeight="300"
                                 VerticalScrollBarVisibility="Auto"
                                 Cursor="Arrow">
                            <TextBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{DynamicResource Ai.CopyMenu}"
                                              Command="ApplicationCommands.Copy"/>
                                </ContextMenu>
                            </TextBox.ContextMenu>
                        </TextBox>

                        <!-- Thumbnail Preview -->
                        <Border Margin="0,8,0,0" CornerRadius="4"
                                Background="{DynamicResource BgPrimary}"
                                Padding="8"
                                Visibility="{Binding HasGeneratedThumbnail, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <Image x:Name="ThumbnailPreview"
                                       MaxHeight="300"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <Button Content="{DynamicResource Ai.SaveThumbnail}"
                                        Style="{StaticResource SmallButton}"
                                        HorizontalAlignment="Right"
                                        FontSize="10" Padding="10,4" Margin="0,6,0,0"
                                        Command="{Binding SaveThumbnailCommand}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Fill: Prompt Input (expands to fill remaining space) -->
                <TextBox Text="{Binding AiInput, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         MinHeight="60" Margin="8,6,8,0"
                         VerticalScrollBarVisibility="Auto"
                         FontSize="11" Padding="8,6"
                         KeyDown="InputBox_KeyDown"
                         AutomationProperties.Name="AI prompt input"/>
            </DockPanel>
        </Grid>
    </Border>
</UserControl>
