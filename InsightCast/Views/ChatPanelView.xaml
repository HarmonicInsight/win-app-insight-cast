<UserControl x:Class="InsightCast.Views.ChatPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:InsightCast.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <Border Background="{DynamicResource BgPrimary}"
            BorderBrush="{DynamicResource BorderDefault}"
            BorderThickness="1,0,0,0"
            TextBlock.FontFamily="{DynamicResource AppFontFamily}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>              <!-- 0: Header -->
                <RowDefinition Height="*" MinHeight="0"/>   <!-- 1: Preset Prompts (variable) -->
                <RowDefinition Height="Auto"/>              <!-- 2: GridSplitter -->
                <RowDefinition Height="2*"/>                <!-- 3: Chat Area -->
                <RowDefinition Height="Auto"/>              <!-- 4: Input Area -->
            </Grid.RowDefinitions>

            <!-- ═══ Row 0: Header ═══ -->
            <Border Grid.Row="0" Style="{StaticResource PanelHeaderStyle}">
                <StackPanel>
                    <!-- Row 1: Title + icon buttons -->
                    <DockPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding PanelTitle}"
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="{DynamicResource BrandPrimary}"
                                       VerticalAlignment="Center"/>
                            <Button Style="{StaticResource SmallButton}"
                                    Click="HelpButton_Click"
                                    ToolTip="{DynamicResource PromptLib.Help.Tooltip}"
                                    Padding="3,1" Margin="6,0,0,0" FontSize="10" MinWidth="0" MinHeight="0">
                                <TextBlock Text="&#xE897;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                            </Button>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <Button Style="{StaticResource SmallButton}"
                                    Click="PopOutButton_Click"
                                    ToolTip="{DynamicResource Ai.Popout}"
                                    FontSize="12" Padding="4,2" Margin="0,0,2,0">
                                <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                            </Button>
                            <Button Style="{StaticResource SmallButton}"
                                    Command="{Binding OpenAiSettingsCommand}"
                                    ToolTip="{DynamicResource Ai.AiSettings}"
                                    FontSize="14" Padding="4,2" Margin="0,0,2,0">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                            </Button>
                            <Button Style="{StaticResource SmallButton}"
                                    Click="CloseButton_Click"
                                    ToolTip="{DynamicResource Common.Close}"
                                    FontSize="14" Padding="4,2">
                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                            </Button>
                        </StackPanel>
                    </DockPanel>
                    <!-- Row 2: Preset toggle + Prompt Editor button -->
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <ToggleButton IsChecked="{Binding IsPresetPromptsVisible}"
                                      ToolTip="{DynamicResource Chat.Presets}"
                                      Padding="8,3" MinWidth="0" MinHeight="0"
                                      Background="Transparent" BorderThickness="1"
                                      BorderBrush="{DynamicResource BorderDefault}"
                                      Cursor="Hand" Margin="0,0,4,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8EC;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0"/>
                                <TextBlock Text="{DynamicResource Chat.Presets}" FontSize="10"/>
                            </StackPanel>
                        </ToggleButton>
                        <Button Style="{StaticResource SmallButton}"
                                Command="{Binding OpenPromptEditorCommand}"
                                ToolTip="{DynamicResource Ai.PromptEditor}"
                                HorizontalAlignment="Left"
                                Padding="8,3">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0"/>
                                <TextBlock Text="{DynamicResource Ai.PromptEditor}" FontSize="10"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ═══ Row 1: Preset Prompts (collapsible) ═══ -->
            <Border Grid.Row="1"
                    BorderBrush="{DynamicResource BorderDefault}"
                    BorderThickness="0,0,0,1"
                    Visibility="{Binding IsPresetPromptsVisible, Converter={StaticResource BoolToVis}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="4,2">
                    <ItemsControl ItemsSource="{Binding PresetPromptGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,2">
                                    <TextBlock Text="{Binding CategoryName}"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextTertiary}"
                                               Margin="8,4,0,2"
                                               FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>
                                    <ItemsControl ItemsSource="{Binding Prompts}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource BgSecondary}"
                                                        BorderBrush="{DynamicResource BorderDefault}"
                                                        BorderThickness="1" CornerRadius="10"
                                                        Padding="7,3" Margin="0,0,3,3" Cursor="Hand"
                                                        MouseLeftButtonDown="PresetChip_Click"
                                                        ToolTip="{Binding Tooltip}">
                                                    <Border.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="{DynamicResource PromptLib.Duplicate}"
                                                                      Click="PresetDuplicate_Click"/>
                                                        </ContextMenu>
                                                    </Border.ContextMenu>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Icon}" FontSize="10" Margin="0,0,3,0"/>
                                                        <TextBlock Text="{Binding Label}" FontSize="10"
                                                                   Foreground="{DynamicResource TextPrimary}"
                                                                   FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- ═══ Row 2: GridSplitter ═══ -->
            <GridSplitter Grid.Row="2" Height="6"
                          HorizontalAlignment="Stretch" VerticalAlignment="Center"
                          Background="Transparent" Cursor="SizeNS"
                          Visibility="{Binding IsPresetPromptsVisible, Converter={StaticResource BoolToVis}}"/>

            <!-- ═══ Row 3: Chat Area ═══ -->
            <Grid Grid.Row="3">
                <!-- Chat messages -->
                <ScrollViewer x:Name="ChatScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="8,4">
                    <ItemsControl ItemsSource="{Binding ChatMessages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="4,3" Padding="10,7" MaxWidth="380"
                                        CornerRadius="12">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#F5F5F5"/>
                                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Role}" Value="User">
                                                    <Setter Property="Background" Value="#E3F2FD"/>
                                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                                    <Setter Property="CornerRadius" Value="12,12,0,12"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Role}" Value="Assistant">
                                                    <Setter Property="Background" Value="#F3E5F5"/>
                                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                                    <Setter Property="CornerRadius" Value="12,12,12,0"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Role}" Value="System">
                                                    <Setter Property="Background" Value="#FFF3E0"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="CornerRadius" Value="8"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBox Text="{Binding Content, Mode=OneWay}"
                                             TextWrapping="Wrap" FontSize="12.5"
                                             FontFamily="Yu Gothic UI, Meiryo, Segoe UI"
                                             Foreground="{DynamicResource TextPrimary}"
                                             Background="Transparent" BorderThickness="0"
                                             IsReadOnly="True" Cursor="Arrow"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Thumbnail Preview overlay (bottom-right) -->
                <Border Margin="8" Padding="8" CornerRadius="8"
                        Background="{DynamicResource BgPrimary}"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Visibility="{Binding HasGeneratedThumbnail, Converter={StaticResource BoolToVis}}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" Opacity="0.15" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <Image x:Name="ThumbnailPreview"
                               MaxHeight="200" MaxWidth="250"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <Button Content="{DynamicResource Ai.SaveThumbnail}"
                                Style="{StaticResource SmallButton}"
                                HorizontalAlignment="Right"
                                FontSize="9" Padding="8,3" Margin="0,4,0,0"
                                Command="{Binding SaveThumbnailCommand}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══ Row 4: Input Area ═══ -->
            <Border Grid.Row="4"
                    BorderBrush="{DynamicResource BorderDefault}"
                    BorderThickness="0,1,0,0"
                    Padding="8,6">
                <StackPanel>
                    <!-- Processing indicator -->
                    <DockPanel Margin="0,0,0,4"
                               Visibility="{Binding IsAiProcessing, Converter={StaticResource BoolToVis}}">
                        <Button DockPanel.Dock="Right"
                                Content="{DynamicResource Chat.Cancel}"
                                Style="{StaticResource SmallButton}"
                                FontSize="9" Padding="8,3"
                                Command="{Binding CancelCommand}"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="●" FontSize="8"
                                       Foreground="{DynamicResource BrandPrimary}"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding AiProcessingModelName}"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrandPrimary}"
                                       Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding AiProcessingText}"
                                       FontSize="10" Foreground="{DynamicResource TextSecondary}"
                                       FontStyle="Italic" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- Input + Send -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding AiInput, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 MinHeight="90" MaxHeight="200"
                                 VerticalScrollBarVisibility="Auto"
                                 FontSize="12" Padding="8,6"
                                 KeyDown="InputBox_KeyDown"
                                 AutomationProperties.Name="AI prompt input"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="4,0,0,0">
                            <Button Style="{StaticResource PrimaryButton}"
                                    Padding="8,6" MinWidth="36"
                                    Command="{Binding ExecutePromptCommand}"
                                    IsEnabled="{Binding IsAiProcessing, Converter={StaticResource InverseBool}}"
                                    ToolTip="{DynamicResource Chat.Execute.Tooltip}">
                                <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                            </Button>
                            <Button Command="{Binding ClearChatCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" Padding="4,2" Margin="0,2,0,0"
                                    ToolTip="{DynamicResource Chat.Clear}">
                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
