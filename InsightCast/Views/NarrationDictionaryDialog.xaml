<Window x:Class="InsightCast.Views.NarrationDictionaryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="読み上げ辞書"
        Width="650" Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource BgBase}">

    <Window.Resources>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Description -->
        <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,10"
                   Foreground="{DynamicResource TextSecondary}" FontSize="11.5">
            字幕はそのまま、ナレーション読み上げ時のみ変換されます。変換元を入力して追加してください。エクスポート／プレビュー時に自動適用されます。
        </TextBlock>

        <!-- Add new entry -->
        <Border Grid.Row="1" Background="{DynamicResource BgCard}"
                BorderBrush="{DynamicResource BorderLight}" BorderThickness="1"
                CornerRadius="5" Padding="10,8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- Labels -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="変換元" FontSize="10.5"
                           Foreground="{DynamicResource TextTertiary}" Margin="2,0,0,3"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="変換先（読み）" FontSize="10.5"
                           Foreground="{DynamicResource TextTertiary}" Margin="2,0,0,3"/>
                <!-- Inputs -->
                <TextBox x:Name="NewFromTextBox" Grid.Row="1" Grid.Column="0"
                         VerticalContentAlignment="Center" Height="32" FontSize="12"
                         Padding="6,4"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="→" HorizontalAlignment="Center"
                           VerticalAlignment="Center" Foreground="{DynamicResource TextTertiary}" FontSize="13"/>
                <TextBox x:Name="NewToTextBox" Grid.Row="1" Grid.Column="2"
                         VerticalContentAlignment="Center" Height="32" FontSize="12"
                         Padding="6,4"/>
                <Button x:Name="AddButton" Grid.Row="1" Grid.Column="3" Content="追加"
                        Style="{StaticResource DialogButton}" Margin="8,0,0,0"
                        Click="AddButton_Click"/>
            </Grid>
        </Border>

        <!-- Entries list -->
        <Border Grid.Row="2" Background="{DynamicResource BgCard}"
                BorderBrush="{DynamicResource BorderLight}" BorderThickness="1"
                CornerRadius="5" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Column headers -->
                <Border Grid.Row="0" BorderBrush="{DynamicResource BorderLight}" BorderThickness="0,0,0,1"
                        Padding="8,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="26"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="56"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="1" Text="変換元" FontSize="10.5" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextTertiary}"/>
                        <TextBlock Grid.Column="3" Text="変換先" FontSize="10.5" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextTertiary}"/>
                        <TextBlock Grid.Column="4" Text="種別" FontSize="10.5" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextTertiary}" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <ListView x:Name="EntriesListView" Grid.Row="1"
                          BorderThickness="0" Background="Transparent"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,1,8,1" Height="24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="26"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="44"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsEnabled}"
                                          VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding From}"
                                           VerticalAlignment="Center" FontSize="11.5"
                                           Foreground="{DynamicResource TextPrimary}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="2" Text="→" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextTertiary}" FontSize="11"/>
                                <TextBlock Grid.Column="3" Text="{Binding To}"
                                           VerticalAlignment="Center" FontSize="11.5"
                                           Foreground="{DynamicResource AccentGold}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="4" Text="{Binding TypeLabel}"
                                           VerticalAlignment="Center" FontSize="10"
                                           Foreground="{DynamicResource TextTertiary}"
                                           HorizontalAlignment="Center"/>
                                <Button Grid.Column="5" Content="✕" FontSize="10"
                                        Visibility="{Binding DeleteVisible}"
                                        Click="DeleteButton_Click"
                                        Tag="{Binding}"
                                        Padding="4,1" Height="20" MinWidth="0"
                                        VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- Entry count -->
        <TextBlock x:Name="EntryCountLabel" Grid.Row="3" Margin="0,5,0,6"
                   FontSize="10.5" Foreground="{DynamicResource TextTertiary}"/>

        <!-- OK / Cancel Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="プリセット復元" Style="{StaticResource DialogButton}"
                    Click="ResetPresetsButton_Click"/>
            <Button Content="保存" Style="{StaticResource DialogButton}"
                    IsDefault="True" Click="SaveButton_Click"/>
            <Button Content="キャンセル" Style="{StaticResource DialogButton}"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
