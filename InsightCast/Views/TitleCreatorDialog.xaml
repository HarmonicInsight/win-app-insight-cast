<Window x:Class="InsightCast.Views.TitleCreatorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Planning.ThumbnailGenerator}"
        Width="480" Height="820"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgPrimary}">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BgCard}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefault}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Padding" Value="12,4"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
        <StackPanel>
            <!-- Pattern Selection -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Thumbnail.Pattern}" Style="{StaticResource SectionHeader}"/>
                    <ComboBox Height="40" FontSize="13"
                              ItemsSource="{Binding ThumbnailPatterns}"
                              SelectedIndex="{Binding SelectedThumbnailPatternIndex}"
                              ToolTip="{DynamicResource Thumbnail.Pattern.Tooltip}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <Border Width="24" Height="24" CornerRadius="4" Margin="0,0,10,0"
                                            Background="{Binding ColorBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                               FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Style Presets -->
                    <TextBlock Text="{DynamicResource Thumbnail.StylePreset}" Margin="0,10,0,6"
                               FontSize="12" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <ItemsControl ItemsSource="{Binding StylePresets}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="2" Padding="8,6" Cursor="Hand"
                                        Command="{Binding DataContext.ApplyStylePresetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding Style}"
                                        ToolTip="{Binding Description}">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="14" Height="14" CornerRadius="2" Margin="0,0,6,0"
                                                Background="{Binding ColorBrush}"/>
                                        <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Text Input Section -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <!-- Main Text -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="メイン" FontSize="11" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Height="36" FontSize="13" FontWeight="Bold" Padding="6,4"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding ThumbnailMainText, UpdateSourceTrigger=PropertyChanged}"/>
                        <ComboBox Grid.Column="2" Height="36" Margin="4,0,0,0" FontSize="10"
                                  ItemsSource="{Binding AvailableFonts}"
                                  SelectedIndex="{Binding SelectedMainFontIndex}"
                                  ToolTip="{DynamicResource Thumbnail.Font.Tooltip}"/>
                        <ComboBox Grid.Column="3" Height="36" Margin="4,0,0,0" FontSize="10"
                                  ItemsSource="{Binding FontSizeOptions}"
                                  SelectedIndex="{Binding MainFontSizeIndex}"
                                  ToolTip="{DynamicResource Thumbnail.FontSize.Tooltip}"/>
                        <ToggleButton x:Name="MainColorToggle" Grid.Column="4" Width="36" Height="36" Margin="4,0,0,0"
                                      BorderThickness="1" BorderBrush="#666" Padding="0"
                                      ToolTip="{DynamicResource Thumbnail.Color.Tooltip}">
                            <Border Width="24" Height="24" CornerRadius="2"
                                    Background="{Binding SelectedMainColorBrush}"/>
                        </ToggleButton>
                        <Popup IsOpen="{Binding IsChecked, ElementName=MainColorToggle}" StaysOpen="False"
                               PlacementTarget="{Binding ElementName=MainColorToggle}" Placement="Bottom">
                            <Border Background="{DynamicResource BgCard}" BorderBrush="#555" BorderThickness="1"
                                    CornerRadius="4" Padding="4">
                                <ItemsControl ItemsSource="{Binding ColorPalette}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><UniformGrid Columns="10"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="20" Height="20" Margin="1" CornerRadius="2" Cursor="Hand"
                                                    Background="{Binding Brush}" BorderThickness="1" BorderBrush="#444"
                                                    MouseLeftButtonDown="MainColorPalette_Click" Tag="{Binding Index}"
                                                    ToolTip="{Binding Name}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </Popup>
                    </Grid>

                    <!-- Sub Text -->
                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="サブ1" FontSize="11" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Height="36" FontSize="13" Padding="6,4"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding ThumbnailSubText, UpdateSourceTrigger=PropertyChanged}"/>
                        <ComboBox Grid.Column="2" Height="36" Margin="4,0,0,0" FontSize="10"
                                  ItemsSource="{Binding AvailableFonts}"
                                  SelectedIndex="{Binding SelectedSubFontIndex}"
                                  ToolTip="{DynamicResource Thumbnail.Font.Tooltip}"/>
                        <ComboBox Grid.Column="3" Height="36" Margin="4,0,0,0" FontSize="10"
                                  ItemsSource="{Binding FontSizeOptions}"
                                  SelectedIndex="{Binding SubFontSizeIndex}"
                                  ToolTip="{DynamicResource Thumbnail.FontSize.Tooltip}"/>
                        <ToggleButton x:Name="SubColorToggle" Grid.Column="4" Width="36" Height="36" Margin="4,0,0,0"
                                      BorderThickness="1" BorderBrush="#666" Padding="0"
                                      ToolTip="{DynamicResource Thumbnail.Color.Tooltip}">
                            <Border Width="24" Height="24" CornerRadius="2"
                                    Background="{Binding SelectedSubColorBrush}"/>
                        </ToggleButton>
                        <Popup IsOpen="{Binding IsChecked, ElementName=SubColorToggle}" StaysOpen="False"
                               PlacementTarget="{Binding ElementName=SubColorToggle}" Placement="Bottom">
                            <Border Background="{DynamicResource BgCard}" BorderBrush="#555" BorderThickness="1"
                                    CornerRadius="4" Padding="4">
                                <ItemsControl ItemsSource="{Binding ColorPalette}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><UniformGrid Columns="10"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="20" Height="20" Margin="1" CornerRadius="2" Cursor="Hand"
                                                    Background="{Binding Brush}" BorderThickness="1" BorderBrush="#444"
                                                    MouseLeftButtonDown="SubColorPalette_Click" Tag="{Binding Index}"
                                                    ToolTip="{Binding Name}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </Popup>
                    </Grid>

                    <!-- SubSub Text -->
                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="サブ2" FontSize="11" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Height="36" FontSize="13" Padding="6,4"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding ThumbnailSubSubText, UpdateSourceTrigger=PropertyChanged}"/>
                        <ComboBox Grid.Column="2" Height="36" Margin="4,0,0,0" FontSize="10"
                                  ItemsSource="{Binding AvailableFonts}"
                                  SelectedIndex="{Binding SelectedSubSubFontIndex}"
                                  ToolTip="{DynamicResource Thumbnail.Font.Tooltip}"/>
                        <ComboBox Grid.Column="3" Height="36" Margin="4,0,0,0" FontSize="10"
                                  ItemsSource="{Binding FontSizeOptions}"
                                  SelectedIndex="{Binding SubSubFontSizeIndex}"
                                  ToolTip="{DynamicResource Thumbnail.FontSize.Tooltip}"/>
                        <ToggleButton x:Name="SubSubColorToggle" Grid.Column="4" Width="36" Height="36" Margin="4,0,0,0"
                                      BorderThickness="1" BorderBrush="#666" Padding="0"
                                      ToolTip="{DynamicResource Thumbnail.Color.Tooltip}">
                            <Border Width="24" Height="24" CornerRadius="2"
                                    Background="{Binding SelectedSubSubColorBrush}"/>
                        </ToggleButton>
                        <Popup IsOpen="{Binding IsChecked, ElementName=SubSubColorToggle}" StaysOpen="False"
                               PlacementTarget="{Binding ElementName=SubSubColorToggle}" Placement="Bottom">
                            <Border Background="{DynamicResource BgCard}" BorderBrush="#555" BorderThickness="1"
                                    CornerRadius="4" Padding="4">
                                <ItemsControl ItemsSource="{Binding ColorPalette}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><UniformGrid Columns="10"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="20" Height="20" Margin="1" CornerRadius="2" Cursor="Hand"
                                                    Background="{Binding Brush}" BorderThickness="1" BorderBrush="#444"
                                                    MouseLeftButtonDown="SubSubColorPalette_Click" Tag="{Binding Index}"
                                                    ToolTip="{Binding Name}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </Popup>
                    </Grid>

                    <!-- Character Count -->
                    <TextBlock Text="{Binding ThumbnailCharCountText}" Margin="0,4,0,0"
                               FontSize="10" Foreground="{Binding ThumbnailCharCountColor}"
                               HorizontalAlignment="Right"/>
                </StackPanel>
            </Border>

            <!-- Background Settings -->
            <Border Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{DynamicResource Thumbnail.Background}" FontSize="11"
                               Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding ThumbnailBgFileName}"
                               VerticalAlignment="Center" FontSize="10"
                               Foreground="{DynamicResource TextSecondary}"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="{DynamicResource Common.Browse.Short}" Padding="6,2" FontSize="10"
                                Command="{Binding SelectThumbnailBgCommand}"
                                ToolTip="{DynamicResource Thumbnail.BgBrowse.Tooltip}"/>
                        <Button Content="×" Padding="4,2" Margin="2,0,0,0" FontSize="10"
                                Command="{Binding ClearThumbnailBgCommand}"
                                ToolTip="{DynamicResource Thumbnail.BgClear.Tooltip}"/>
                    </StackPanel>
                    <Button x:Name="AiImageBtn" Grid.Column="4" Content="AI" Padding="8,2" Margin="4,0,0,0"
                            FontSize="10" FontWeight="Bold"
                            ToolTip="AI で背景画像を生成"
                            Click="AiImageBtn_Click"/>
                    <ToggleButton x:Name="BgColorToggle" Grid.Column="3" Width="32" Height="32" Margin="8,0,0,0"
                                  BorderThickness="1" BorderBrush="#666" Padding="0"
                                  ToolTip="{DynamicResource Thumbnail.BgColor.Tooltip}">
                        <Border Width="24" Height="24" CornerRadius="2"
                                Background="{Binding SelectedBgColorBrush}"/>
                    </ToggleButton>
                    <Popup IsOpen="{Binding IsChecked, ElementName=BgColorToggle}" StaysOpen="False"
                           PlacementTarget="{Binding ElementName=BgColorToggle}" Placement="Bottom">
                        <Border Background="{DynamicResource BgCard}" BorderBrush="#555" BorderThickness="1"
                                CornerRadius="4" Padding="4">
                            <ItemsControl ItemsSource="{Binding ColorPalette}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><UniformGrid Columns="10"/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="20" Height="20" Margin="1" CornerRadius="2" Cursor="Hand"
                                                Background="{Binding Brush}" BorderThickness="1" BorderBrush="#444"
                                                MouseLeftButtonDown="BgColorPalette_Click" Tag="{Binding Index}"
                                                ToolTip="{Binding Name}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Popup>
                </Grid>
            </Border>

            <!-- AI Image Generation -->
            <Border x:Name="AiImagePanel" Style="{StaticResource CardBorder}" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="AI 画像生成" Style="{StaticResource SectionHeader}"/>
                    <TextBox x:Name="AiPromptBox" Height="60" AcceptsReturn="True" TextWrapping="Wrap"
                             FontSize="12" Padding="6,4" Margin="0,0,0,6"
                             VerticalScrollBarVisibility="Auto"
                             Text="ビジネスプレゼンテーション用の背景画像、プロフェッショナルな雰囲気"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="AiModelCombo" Height="32" FontSize="11" Margin="0,0,4,0"/>
                        <ComboBox x:Name="AiSizeCombo" Grid.Column="1" Height="32" FontSize="11" Width="110" Margin="0,0,4,0">
                            <ComboBoxItem Content="1280x720 (16:9)" Tag="1280x720" IsSelected="True"/>
                            <ComboBoxItem Content="1024x1024 (1:1)" Tag="1024x1024"/>
                            <ComboBoxItem Content="1792x1024 (Wide)" Tag="1792x1024"/>
                        </ComboBox>
                        <Button x:Name="AiGenerateBtn" Grid.Column="2" Content="生成" Padding="12,4"
                                Height="32" FontWeight="Bold" Click="AiGenerate_Click"/>
                    </Grid>
                    <TextBlock x:Name="AiStatusText" Text="" FontSize="10" Margin="0,4,0,0"
                               Foreground="{DynamicResource TextSecondary}"/>
                </StackPanel>
            </Border>

            <!-- Generate Buttons -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="{DynamicResource Thumbnail.Generate}"
                                Style="{StaticResource ActionButton}"
                                Height="40" FontSize="14" FontWeight="Bold"
                                HorizontalAlignment="Stretch"
                                Command="{Binding GenerateThumbnailCommand}"/>
                        <Button Grid.Column="1" Content="{DynamicResource Thumbnail.Clear}" Padding="12,4" Margin="8,0,0,0"
                                Height="40" Foreground="OrangeRed"
                                Command="{Binding ClearThumbnailCommand}"
                                ToolTip="{DynamicResource Thumbnail.Clear.All.Tooltip}"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Center">
                        <Button Content="シーンに追加" Padding="12,4"
                                Click="AddToScene_Click"
                                ToolTip="生成した画像を現在のシーンに追加"/>
                        <Button Content="{DynamicResource Thumbnail.SaveAs}" Padding="12,4" Margin="8,0,0,0"
                                Command="{Binding SaveThumbnailCommand}"
                                ToolTip="{DynamicResource Thumbnail.SaveAs.Tooltip}"/>
                        <Button Content="{DynamicResource Thumbnail.OpenFolder}" Padding="12,4" Margin="8,0,0,0"
                                Command="{Binding OpenThumbnailFolderCommand}"
                                ToolTip="{DynamicResource Thumbnail.OpenFolder.Tooltip}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Preview -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Planning.Preview}"
                               Style="{StaticResource SectionHeader}"/>
                    <Border Background="{DynamicResource BgSecondary}"
                            CornerRadius="4" MinHeight="140">
                        <Image x:Name="ThumbnailPreview" Source="{Binding ThumbnailPreviewImage}"
                               Stretch="Uniform" MaxHeight="220"/>
                    </Border>
                    <TextBlock Text="1280 x 720 px (YouTube推奨サイズ)" Margin="0,4,0,0"
                               FontSize="10" Foreground="{DynamicResource TextTertiary}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Close Button -->
            <Button Content="{DynamicResource Common.Close}" HorizontalAlignment="Right"
                    Padding="16,8" Margin="0,8,0,0" Click="Close_Click"/>
        </StackPanel>
    </ScrollViewer>
</Window>
