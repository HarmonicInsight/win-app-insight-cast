<Window x:Class="InsightCast.Views.AIProjectGenerateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource AIGenerate.Title}"
        Width="500" Height="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="100"/>
        </Style>
        <Style x:Key="SectionBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BgCard}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefault}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="Padding" Value="16,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Topic Input -->
        <Border Grid.Row="0" Style="{StaticResource SectionBorder}">
            <StackPanel>
                <TextBlock Text="{DynamicResource AIGenerate.Topic}" Style="{StaticResource SectionHeader}"/>
                <TextBox x:Name="TopicTextBox" Height="60" AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"/>
                <TextBlock Text="{DynamicResource AIGenerate.Topic.Hint}"
                           Foreground="{DynamicResource TextTertiary}" FontSize="11" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Settings -->
        <Border Grid.Row="1" Style="{StaticResource SectionBorder}">
            <StackPanel>
                <TextBlock Text="{DynamicResource AIGenerate.Settings}" Style="{StaticResource SectionHeader}"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource AIGenerate.Style}" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="StyleCombo" Grid.Column="1" Height="28">
                        <ComboBoxItem Content="{DynamicResource AIGenerate.Style.Educational}" Tag="educational" IsSelected="True"/>
                        <ComboBoxItem Content="{DynamicResource AIGenerate.Style.Conversational}" Tag="conversational"/>
                        <ComboBoxItem Content="{DynamicResource AIGenerate.Style.Formal}" Tag="formal"/>
                        <ComboBoxItem Content="{DynamicResource AIGenerate.Style.Energetic}" Tag="energetic"/>
                        <ComboBoxItem Content="{DynamicResource AIGenerate.Style.Calm}" Tag="calm"/>
                    </ComboBox>
                </Grid>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource AIGenerate.SceneCount}" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="SceneCountCombo" Grid.Column="1" Width="80" Height="28">
                        <ComboBoxItem Content="3"/>
                        <ComboBoxItem Content="5" IsSelected="True"/>
                        <ComboBoxItem Content="7"/>
                        <ComboBoxItem Content="10"/>
                    </ComboBox>
                </Grid>

                <CheckBox x:Name="GenerateImagesCheckBox" Content="{DynamicResource AIGenerate.GenerateImages}"
                          IsChecked="True" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Progress -->
        <Border Grid.Row="2" Style="{StaticResource SectionBorder}" x:Name="ProgressPanel" Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="ProgressLabel" Text="{DynamicResource AIGenerate.Progress.Preparing}"
                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,8"/>
                <ProgressBar x:Name="ProgressBar" Height="20" Minimum="0" Maximum="100" IsIndeterminate="True"/>
            </StackPanel>
        </Border>

        <!-- Error Message -->
        <Border Grid.Row="3" x:Name="ErrorPanel" Visibility="Collapsed"
                Background="#20FF0000" BorderBrush="#FF6666" BorderThickness="1"
                CornerRadius="4" Padding="8" Margin="0,0,0,12">
            <TextBlock x:Name="ErrorLabel" Foreground="#FF6666" TextWrapping="Wrap"/>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="GenerateButton" Content="{DynamicResource AIGenerate.Generate}"
                    Style="{StaticResource DialogButton}" Click="GenerateButton_Click"/>
            <Button x:Name="CancelButton" Content="{DynamicResource Common.Cancel}"
                    Style="{StaticResource DialogButton}" IsCancel="True" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
