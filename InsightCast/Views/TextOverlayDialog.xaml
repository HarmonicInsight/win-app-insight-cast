<Window x:Class="InsightCast.Views.TextOverlayDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:InsightCast.Views"
        Title="{DynamicResource Overlay.Dialog.Title}"
        Width="560" Height="700"
        MinWidth="500" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <local:NullToCollapsedConverter x:Key="NullToCollapsedConverter"/>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Preview -->
            <RowDefinition Height="*" MinHeight="80"/>   <!-- Overlay list (grows) -->
            <RowDefinition Height="Auto"/>   <!-- Editor -->
            <RowDefinition Height="Auto"/>   <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- ═══ Preview (miniature scene) ═══ -->
        <Border Grid.Row="0" Height="160" CornerRadius="6" Margin="0,0,0,8" ClipToBounds="True">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF1A1A2E" Offset="0"/>
                    <GradientStop Color="#FF16213E" Offset="0.5"/>
                    <GradientStop Color="#FF0F3460" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Image x:Name="PreviewImage" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <Canvas x:Name="PreviewCanvas"/>
            </Grid>
        </Border>

        <!-- ═══ Overlay list + Toolbar ═══ -->
        <Border Grid.Row="1" Margin="0,0,0,6" CornerRadius="6"
                BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1"
                Background="{DynamicResource BgCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <Border Grid.Row="0" Padding="6,5"
                        BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,0,0,1"
                        Background="{DynamicResource BgSecondary}" CornerRadius="6,6,0,0">
                    <DockPanel>
                        <!-- Right: move + delete -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Width="28" Height="28" FontSize="10" Padding="0"
                                    Click="MoveUp_Click" ToolTip="{DynamicResource Overlay.MoveUp.Tooltip}"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand">
                                <TextBlock Text="&#xE74A;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="{DynamicResource TextSecondary}"/>
                            </Button>
                            <Button Width="28" Height="28" FontSize="10" Padding="0"
                                    Click="MoveDown_Click" ToolTip="{DynamicResource Overlay.MoveDown.Tooltip}"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand">
                                <TextBlock Text="&#xE74B;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="{DynamicResource TextSecondary}"/>
                            </Button>
                            <Border Width="1" Height="18" Background="{DynamicResource BorderDefault}" Margin="4,0"/>
                            <Button Width="28" Height="28" Padding="0"
                                    Click="RemoveOverlay_Click" ToolTip="{DynamicResource Overlay.Remove.Tooltip}"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand">
                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="#CC4444"/>
                            </Button>
                        </StackPanel>

                        <!-- Left: add action -->
                        <StackPanel Orientation="Horizontal">
                            <Button Height="28" Padding="10,0"
                                    Click="AddOverlay_Click" ToolTip="{DynamicResource Overlay.Add.Tooltip}"
                                    Cursor="Hand" FontSize="11">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" CornerRadius="4" Padding="{TemplateBinding Padding}"
                                                Background="#B8942F">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#D4AA3C"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                               Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="{DynamicResource Overlay.Add.Label}" FontSize="11"
                                               Foreground="White" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Overlay list -->
                <ListBox Grid.Row="1" x:Name="OverlayList" MinHeight="52"
                         SelectionChanged="OverlayList_SelectionChanged"
                         HorizontalContentAlignment="Stretch"
                         Background="Transparent" BorderThickness="0" Padding="4,2">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2,1">
                                <Border Width="8" Height="16" CornerRadius="2" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <Border.Background>
                                        <SolidColorBrush Color="{Binding ColorValue}"/>
                                    </Border.Background>
                                </Border>
                                <TextBlock Text="{Binding Label}" FontSize="11.5" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextPrimary}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- ═══ Editor ═══ -->
        <Border Grid.Row="2" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1"
                CornerRadius="6" Padding="12,10" Background="{DynamicResource BgCard}"
                Visibility="{Binding ElementName=OverlayList, Path=SelectedItem, Converter={StaticResource NullToCollapsedConverter}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <!-- ① テキスト入力 -->
                    <TextBlock Text="{DynamicResource Overlay.Text}" FontSize="11" Margin="0,0,0,3"
                               Foreground="{DynamicResource TextSecondary}"/>
                    <TextBox x:Name="OverlayTextBox" Padding="6" MinHeight="36" MaxHeight="80"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             VerticalContentAlignment="Top" FontSize="13"
                             TextChanged="OverlayText_Changed"/>

                    <!-- ② 配置 -->
                    <TextBlock Text="{DynamicResource Overlay.Position}" FontSize="11" Margin="0,10,0,4"
                               Foreground="{DynamicResource TextSecondary}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ミニ画面風 3x3 配置グリッド -->
                        <Border Grid.Column="0" Background="#1a1a2e" CornerRadius="6"
                                Width="128" Height="72" ClipToBounds="True">
                            <UniformGrid Rows="3" Columns="3" x:Name="PositionGrid"/>
                        </Border>

                        <!-- X/Y スライダー -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="38"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource Overlay.XPosition}" FontSize="11"
                                           Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center"/>
                                <Slider x:Name="XSlider" Grid.Column="1" Minimum="0" Maximum="100"
                                        VerticalAlignment="Center" ValueChanged="XSlider_Changed"/>
                                <TextBlock x:Name="XLabel" Grid.Column="2" FontSize="11" TextAlignment="Right"
                                           Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="38"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource Overlay.YPosition}" FontSize="11"
                                           Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center"/>
                                <Slider x:Name="YSlider" Grid.Column="1" Minimum="0" Maximum="100"
                                        VerticalAlignment="Center" ValueChanged="YSlider_Changed"/>
                                <TextBlock x:Name="YLabel" Grid.Column="2" FontSize="11" TextAlignment="Right"
                                           Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <!-- ③ 外観 -->
                    <TextBlock Text="{DynamicResource Overlay.Appearance}" FontSize="11" Margin="0,10,0,6"
                               Foreground="{DynamicResource TextSecondary}"/>

                    <!-- フォント選択 + 太字 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="FontFamilyCombo" Height="28" FontSize="11"
                                  SelectionChanged="FontFamily_Changed"
                                  ToolTip="{DynamicResource Overlay.Font.Tooltip}"/>
                        <ToggleButton x:Name="BoldToggle" Grid.Column="1" Width="32" Height="28"
                                      Margin="6,0,0,0" FontWeight="Bold" FontSize="13"
                                      Content="B" Click="Bold_Click"
                                      ToolTip="{DynamicResource Overlay.Bold.Tooltip}">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderDefault}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="Bd" CornerRadius="4"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#B8942F"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#B8942F"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>
                    </Grid>

                    <!-- サイズプリセット + スライダー -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                            <Button Content="S" Width="28" Height="26" FontSize="11" Padding="0" Margin="0,0,3,0"
                                    Click="SizePreset_Click" Tag="28" ToolTip="28pt"/>
                            <Button Content="M" Width="28" Height="26" FontSize="11" Padding="0" Margin="0,0,3,0"
                                    Click="SizePreset_Click" Tag="48" ToolTip="48pt"/>
                            <Button Content="L" Width="28" Height="26" FontSize="11" Padding="0" Margin="0,0,3,0"
                                    Click="SizePreset_Click" Tag="72" ToolTip="72pt"/>
                            <Button Content="XL" Width="32" Height="26" FontSize="11" Padding="0"
                                    Click="SizePreset_Click" Tag="96" ToolTip="96pt"/>
                        </StackPanel>
                        <Slider x:Name="FontSizeSlider" Grid.Column="1" Minimum="16" Maximum="120"
                                TickFrequency="4" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" ValueChanged="FontSize_Changed"/>
                        <TextBlock x:Name="FontSizeLabel" Grid.Column="2" FontSize="11" Width="38" TextAlignment="Right"
                                   Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </Grid>

                    <!-- 色 + 揃え -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel x:Name="ColorSwatchPanel" Orientation="Horizontal" VerticalAlignment="Center"/>

                        <ComboBox x:Name="AlignmentCombo" Grid.Column="1" Width="70" FontSize="11" Height="26" Margin="8,0,0,0"
                                  SelectionChanged="Alignment_Changed"/>
                    </Grid>

                    <!-- 縁取り + 透明度 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource Overlay.Stroke}" FontSize="10"
                                   Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Slider x:Name="StrokeSlider" Grid.Column="1" Minimum="0" Maximum="8"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" ValueChanged="Stroke_Changed"/>
                        <TextBlock x:Name="StrokeLabel" Grid.Column="2" FontSize="10" Width="20" TextAlignment="Right"
                                   Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center" Margin="4,0,0,0"/>

                        <TextBlock Grid.Column="4" Text="{DynamicResource Overlay.Opacity}" FontSize="10"
                                   Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Slider x:Name="OpacitySlider" Grid.Column="5" Minimum="0" Maximum="100"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" ValueChanged="Opacity_Changed"/>
                        <TextBlock x:Name="OpacityLabel" Grid.Column="6" FontSize="10" Width="30" Margin="4,0,0,0"
                                   Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ═══ OK / Cancel ═══ -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="{DynamicResource Common.OK}" MinWidth="90" Height="32" Padding="16,4"
                    IsDefault="True" Click="OkButton_Click"/>
            <Button Content="{DynamicResource Common.Cancel}" MinWidth="90" Height="32" Padding="16,4"
                    Margin="8,0,0,0" IsCancel="True" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>

</Window>
