<UserControl x:Class="InsightCast.Views.PlanningTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:InsightCast.Converters"
             xmlns:local="clr-namespace:InsightCast.Views">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>

        <!-- Compact icon button -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#10000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Gold primary button -->
        <Style x:Key="GoldBtn" TargetType="Button">
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="5" Padding="{TemplateBinding Padding}"
                                Background="#B8942F">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D4AA3C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#C8C0B0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Outlined button -->
        <Style x:Key="OutlineBtn" TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="4" Padding="{TemplateBinding Padding}"
                                Background="Transparent"
                                BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentGold}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" MinWidth="180"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ Left: Material Library (narrow) ═══ -->
        <local:WorkingFolderPanel Grid.Column="0" x:Name="WorkingFolderPanelControl"/>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="Transparent"/>

        <!-- ═══ Right: AI Production ═══ -->
        <Grid Grid.Column="2" Margin="4,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Setup bar -->
                <RowDefinition Height="Auto"/>  <!-- Chapter preview (collapsed) -->
                <RowDefinition Height="*"/>     <!-- Scene list (main content) -->
                <RowDefinition Height="Auto"/>  <!-- Footer tools -->
            </Grid.RowDefinitions>

            <!-- ── Setup Bar (compact, one line) ── -->
            <Border Grid.Row="0" CornerRadius="6" Padding="10,8"
                    Background="{DynamicResource BgCard}"
                    BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1"
                    Margin="0,0,0,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Chapter count -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="{DynamicResource AiChapter.ChapterCount}" FontSize="11"
                                   Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox x:Name="ChapterCountCombo" Height="26" Width="60" FontSize="11" SelectedIndex="2">
                            <ComboBoxItem Content="3"/>
                            <ComboBoxItem Content="5"/>
                            <ComboBoxItem Content="7"/>
                            <ComboBoxItem Content="10"/>
                            <ComboBoxItem Content="15"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Instructions (compact inline) -->
                    <TextBox Grid.Column="2" x:Name="InstructionsBox" FontSize="11" Padding="6,4"
                             VerticalAlignment="Center" Margin="0,0,10,0" Height="26"
                             VerticalContentAlignment="Center">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush Stretch="None" AlignmentX="Left" AlignmentY="Center">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="{DynamicResource AiFlow.Step1.Hint}"
                                                                   FontSize="11" Foreground="#AAA" Margin="6,0,0,0"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- Material count -->
                    <TextBlock Grid.Column="3" x:Name="MaterialStatusText" FontSize="10"
                               Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center"
                               Margin="0,0,10,0"/>

                    <!-- Generate button -->
                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                        <ProgressBar x:Name="ChapterProgressBar" Width="60" Height="3"
                                     IsIndeterminate="True" Visibility="Collapsed" Margin="0,0,8,0"
                                     VerticalAlignment="Center"/>
                        <Button x:Name="GenerateChaptersButton" Style="{StaticResource GoldBtn}"
                                Content="{DynamicResource AiFlow.GenerateBtn}"
                                Click="GenerateChapters_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Chapter Preview (shown after generation, before apply) ── -->
            <Border Grid.Row="1" x:Name="ChapterPreviewCard" Visibility="Collapsed"
                    CornerRadius="6" Padding="10,8"
                    Background="{DynamicResource BgCard}"
                    BorderBrush="{DynamicResource AccentGold}" BorderThickness="1"
                    Margin="0,0,0,6" MaxHeight="300">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Preview header -->
                    <DockPanel Grid.Row="0" Margin="0,0,0,6">
                        <TextBlock x:Name="VideoTitleText" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock x:Name="ChapterStatusText" FontSize="10"
                                       Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <Button Content="{DynamicResource AiFlow.ExpandScenes}" Style="{StaticResource GoldBtn}"
                                    Padding="12,5" FontSize="11"
                                    Click="ExpandToScenes_Click"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- Chapter list (scrollable, compact) -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="ChapterPreviewPanel"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ── Scene List (MAIN CONTENT - fills remaining space) ── -->
            <Border Grid.Row="2" x:Name="SceneListCard" Visibility="Collapsed"
                    CornerRadius="6"
                    Background="{DynamicResource BgCard}"
                    BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Scene list header -->
                    <Border Grid.Row="0" Padding="10,6"
                            BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <TextBlock Text="{DynamicResource AiFlow.Scenes}" FontWeight="SemiBold" FontSize="12"
                                       Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="SceneCountText" FontSize="10"
                                       Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>
                            <Button DockPanel.Dock="Right" HorizontalAlignment="Right"
                                    Content="{DynamicResource Planning.ClearAll}" Style="{StaticResource IconBtn}"
                                    Foreground="OrangeRed" FontSize="10"
                                    Command="{Binding ClearAllScenesCommand}"/>
                        </DockPanel>
                    </Border>

                    <!-- Scene items (scrollable) -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0">
                        <ItemsControl x:Name="SceneListControl" ItemsSource="{Binding PlanningScenes}"
                                      Margin="6,4,6,6">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,6" Padding="10,8" CornerRadius="6"
                                            BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1"
                                            Background="{DynamicResource BgCard}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Number -->
                                            <TextBlock Text="{Binding Index}" FontWeight="Bold" FontSize="13"
                                                       Foreground="{DynamicResource AccentGold}"
                                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>

                                            <!-- Left: Narration section -->
                                            <DockPanel Grid.Column="1" Margin="4,0,6,0">
                                                <!-- Title (editable) -->
                                                <TextBox DockPanel.Dock="Top"
                                                         Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                                         FontWeight="SemiBold" FontSize="11.5"
                                                         BorderThickness="0" Background="Transparent"
                                                         Foreground="{DynamicResource TextPrimary}"
                                                         Margin="0,0,0,4"/>
                                                <!-- Label -->
                                                <TextBlock DockPanel.Dock="Top" FontSize="10"
                                                           Foreground="{DynamicResource TextTertiary}" Margin="2,0,0,3"
                                                           Text="{DynamicResource AiFlow.NarrationLabel}"/>
                                                <!-- Narration textarea -->
                                                <Border CornerRadius="4" BorderBrush="{DynamicResource BorderLight}"
                                                        BorderThickness="1" Background="{DynamicResource BgInput}">
                                                    <TextBox Text="{Binding Script, UpdateSourceTrigger=PropertyChanged}"
                                                             MinHeight="60" MaxHeight="140" AcceptsReturn="True"
                                                             TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                                             FontSize="11" Padding="6,4"
                                                             BorderThickness="0" Background="Transparent"
                                                             Foreground="{DynamicResource TextPrimary}"
                                                             VerticalContentAlignment="Top"/>
                                                </Border>
                                            </DockPanel>

                                            <!-- Right: Image prompt section -->
                                            <DockPanel Grid.Column="2" Margin="6,0,0,0">
                                                <!-- Header with copy button -->
                                                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,3">
                                                    <TextBlock FontSize="10"
                                                               Foreground="{DynamicResource TextTertiary}" Margin="2,0,0,0"
                                                               VerticalAlignment="Center"
                                                               Text="{DynamicResource AiFlow.ImagePrompt}"/>
                                                    <Button DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                            Click="CopyPrompt_Click"
                                                            Tag="{Binding ImagePrompt}" Style="{StaticResource IconBtn}"
                                                            ToolTip="{DynamicResource AiFlow.CopyPrompt}"
                                                            Padding="4,2">
                                                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                                   Foreground="{DynamicResource AccentGold}"/>
                                                    </Button>
                                                </DockPanel>
                                                <!-- Spacer for title alignment -->
                                                <Border DockPanel.Dock="Top" Height="22"/>
                                                <!-- Image prompt textarea -->
                                                <Border CornerRadius="4" BorderThickness="1">
                                                    <Border.BorderBrush>
                                                        <SolidColorBrush Color="#B8942F" Opacity="0.3"/>
                                                    </Border.BorderBrush>
                                                    <Border.Background>
                                                        <SolidColorBrush Color="#B8942F" Opacity="0.04"/>
                                                    </Border.Background>
                                                    <TextBox Text="{Binding ImagePrompt, UpdateSourceTrigger=PropertyChanged}"
                                                             MinHeight="60" MaxHeight="140" AcceptsReturn="True"
                                                             TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                                             FontSize="11" Padding="6,4"
                                                             BorderThickness="0" Background="Transparent"
                                                             Foreground="{DynamicResource TextPrimary}"
                                                             VerticalContentAlignment="Top"/>
                                                </Border>
                                            </DockPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Empty state (shown when no scenes) -->
            <Border Grid.Row="2" x:Name="EmptyState" CornerRadius="6" Padding="24"
                    Background="{DynamicResource BgCard}"
                    BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border Width="48" Height="48" CornerRadius="24" HorizontalAlignment="Center"
                            Margin="0,0,0,12">
                        <Border.Background>
                            <SolidColorBrush Color="#B8942F" Opacity="0.1"/>
                        </Border.Background>
                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{DynamicResource AccentGold}"/>
                    </Border>
                    <TextBlock Text="{DynamicResource AiFlow.EmptyTitle}" FontSize="14" FontWeight="SemiBold"
                               TextAlignment="Center" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                    <TextBlock Text="{DynamicResource AiFlow.EmptyDesc}" FontSize="11"
                               TextAlignment="Center" Foreground="{DynamicResource TextTertiary}"
                               TextWrapping="Wrap" MaxWidth="320"/>
                </StackPanel>
            </Border>

            <!-- ── Footer Tools ── -->
            <Border Grid.Row="3" Padding="8,6,8,4" Margin="0,6,0,0"
                    CornerRadius="6"
                    Background="{DynamicResource BgCard}"
                    BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1">
                <DockPanel>
                    <TextBlock x:Name="ImageGenStatusText" FontSize="10"
                               Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- PPTX Export from scenes -->
                        <Button Style="{StaticResource GoldBtn}" Click="ExportPptx_Click"
                                Padding="12,5" Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{DynamicResource AiFlow.ExportPptx}" FontSize="11"
                                           Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <!-- JSON Export -->
                        <Button Style="{StaticResource OutlineBtn}" Click="ExportJson_Click"
                                ToolTip="{DynamicResource AiFlow.JsonExport.Tooltip}" Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xEDE1;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="{DynamicResource AccentGold}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{DynamicResource AiFlow.JsonExport}" FontSize="11"
                                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <!-- JSON Import -->
                        <Button Style="{StaticResource OutlineBtn}" Click="ImportJson_Click"
                                ToolTip="{DynamicResource AiFlow.JsonImport.Tooltip}" Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="{DynamicResource AccentGold}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{DynamicResource AiFlow.JsonImport}" FontSize="11"
                                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <!-- AI Image Generation -->
                        <Button Style="{StaticResource OutlineBtn}" Click="AiGenerateImages_Click"
                                ToolTip="{DynamicResource AiGenerate.ImagesButton.Tooltip}" Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE91B;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="{DynamicResource AccentGold}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{DynamicResource AiFlow.Tool.AiImage}" FontSize="11"
                                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <!-- Thumbnail Creator -->
                        <Button Style="{StaticResource OutlineBtn}" Click="OpenThumbnailCreator_Click"
                                ToolTip="{DynamicResource AiWorkspace.ThumbnailButton.Tooltip}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8B9;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="{DynamicResource AccentGold}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{DynamicResource AiFlow.Tool.Thumbnail}" FontSize="11"
                                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
