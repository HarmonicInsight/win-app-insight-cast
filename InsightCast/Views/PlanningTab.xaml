<UserControl x:Class="InsightCast.Views.PlanningTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:InsightCast.Converters"
             xmlns:local="clr-namespace:InsightCast.Views"
             xmlns:ref="clr-namespace:InsightCommon.UI.Reference;assembly=InsightCommon">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: Step bar -->
            <RowDefinition Height="*"/>     <!-- 1: Content -->
            <RowDefinition Height="Auto"/>  <!-- 2: Action buttons -->
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <!-- Col 0: ① INPUT — 参考資料 -->
            <ColumnDefinition x:Name="RefCol" Width="200" MinWidth="140" MaxWidth="320"/>
            <ColumnDefinition x:Name="RefSplitterCol" Width="Auto"/>
            <!-- Col 2: プロンプト一覧 -->
            <ColumnDefinition Width="180" MinWidth="140" MaxWidth="300"/>
            <ColumnDefinition Width="Auto"/>
            <!-- Col 4: プロンプト内容 -->
            <ColumnDefinition Width="260" MinWidth="180" MaxWidth="450"/>
            <ColumnDefinition Width="Auto"/>
            <!-- Col 6: ③ OUTPUT — 成果物 -->
            <ColumnDefinition x:Name="OutputCol" Width="*" MinWidth="160"/>
            <ColumnDefinition Width="Auto"/>
            <!-- Col 8: ④ AI Chat -->
            <ColumnDefinition x:Name="ChatCol" Width="300" MinWidth="220" MaxWidth="500"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ Row 0: ステップバー ═══ -->

        <!-- ① 入力 (Col 0) — Light Gold -->
        <Border x:Name="StepInputBar" Grid.Row="0" Grid.Column="0"
                Background="#C9A84C" Padding="8,4"
                BorderBrush="#B8942F" BorderThickness="0,0,0,1">
            <TextBlock FontSize="10" FontWeight="Bold" Foreground="White"
                       FontFamily="Yu Gothic UI, Meiryo, Segoe UI">
                <Run Text="{DynamicResource PE.InputHeader}"/>
            </TextBlock>
        </Border>

        <!-- ② 処理 (Col 2 + 3 + 4) — Primary Gold -->
        <Border Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="3"
                Background="#B8942F" Padding="8,4"
                BorderBrush="#A68329" BorderThickness="0,0,0,1">
            <TextBlock FontSize="10" FontWeight="Bold" Foreground="White"
                       FontFamily="Yu Gothic UI, Meiryo, Segoe UI">
                <Run Text="{DynamicResource PE.ProcessHeader}"/>
            </TextBlock>
        </Border>

        <!-- ③ 成果物 (Col 6) — Deep Gold -->
        <Border Grid.Row="0" Grid.Column="6"
                Background="#9A7B25" Padding="8,4"
                BorderBrush="#7D6420" BorderThickness="0,0,0,1">
            <TextBlock FontSize="10" FontWeight="Bold" Foreground="White"
                       FontFamily="Yu Gothic UI, Meiryo, Segoe UI">
                <Run Text="{DynamicResource PE.OutputHeader}"/>
            </TextBlock>
        </Border>

        <!-- ④ AI コンシェルジュ (Col 8) — Warm accent -->
        <Border Grid.Row="0" Grid.Column="8"
                Background="#7C6A3A" Padding="8,4"
                BorderBrush="#5C4E2B" BorderThickness="0,0,0,1">
            <TextBlock FontSize="10" FontWeight="Bold" Foreground="White"
                       FontFamily="Yu Gothic UI, Meiryo, Segoe UI">
                <Run Text="{DynamicResource PE.ChatHeader}"/>
            </TextBlock>
        </Border>

        <!-- ═══ Row 1: コンテンツ ═══ -->

        <!-- Col 0: INPUT — 参考資料 -->
        <Border x:Name="RefBorder" Grid.Row="1" Grid.RowSpan="2" Grid.Column="0"
                BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,0,1,0">
            <ref:ReferencePanelView x:Name="ReferencePanelControl"/>
        </Border>

        <GridSplitter x:Name="RefSplitter" Grid.Row="0" Grid.RowSpan="3" Grid.Column="1"
                      Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      Background="Transparent" Cursor="SizeWE" ResizeBehavior="PreviousAndNext"/>

        <!-- Col 2: プロンプト一覧 -->
        <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="2"
                BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Padding="8,5"
                        BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,0,0,1">
                    <Border.Background>
                        <SolidColorBrush Color="#B8942F" Opacity="0.08"/>
                    </Border.Background>
                    <DockPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                       Foreground="{DynamicResource AccentGold}"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="{DynamicResource PE.PromptList}" FontWeight="SemiBold" FontSize="12"
                                       Foreground="{DynamicResource AccentGold}"
                                       FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="AddGroupButton"
                                    Click="AddGroup_Click" Padding="3,1" MinWidth="0" MinHeight="0"
                                    Cursor="Hand"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource AccentGold}"
                                    ToolTip="{DynamicResource PE.AddGroup}">
                                <TextBlock Text="&#xE8F4;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                            </Button>
                            <Button x:Name="AddButton"
                                    Click="Add_Click"
                                    Padding="3,1" MinWidth="0" MinHeight="0"
                                    Cursor="Hand"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource AccentGold}"
                                    ToolTip="{DynamicResource PE.Add}">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                            </Button>
                            <Button x:Name="DeleteButton"
                                    Click="Delete_Click" Padding="3,1" MinWidth="0" MinHeight="0"
                                    Cursor="Hand"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="OrangeRed"
                                    ToolTip="{DynamicResource PE.Delete}"
                                    IsEnabled="False">
                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Tree -->
                <TreeView Grid.Row="1" x:Name="PromptTree" BorderThickness="0"
                          SelectedItemChanged="PromptTree_SelectedItemChanged"
                          Background="Transparent"
                          FontFamily="Yu Gothic UI, Meiryo, Segoe UI">
                    <TreeView.Resources>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="Padding" Value="2,1"/>
                            <Setter Property="FontSize" Value="11"/>
                        </Style>
                    </TreeView.Resources>
                </TreeView>
            </Grid>
        </Border>

        <!-- Splitter -->
        <GridSplitter Grid.Row="0" Grid.RowSpan="3" Grid.Column="3"
                      Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      Background="Transparent" Cursor="SizeWE" ResizeBehavior="PreviousAndNext"/>

        <!-- Col 4: プロンプト内容 -->
        <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="4"
                BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,0,1,0">
            <Grid x:Name="EditorPanel" IsEnabled="False" Margin="6,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- 0: Name + Model -->
                    <RowDefinition Height="*"/>     <!-- 1: Prompt box -->
                    <RowDefinition Height="Auto"/>  <!-- 2: Buttons -->
                </Grid.RowDefinitions>

                <!-- Name + Model (compact: Doc Factory style) -->
                <Grid Grid.Row="0" Margin="0,0,0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="NameBox" FontSize="11" Padding="4,2"
                             Foreground="{DynamicResource TextPrimary}"
                             BorderBrush="{DynamicResource BorderDefault}"
                             FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>
                    <ComboBox Grid.Column="2" x:Name="ModelCombo"
                              FontSize="11" Padding="3,1" MinWidth="90"
                              Foreground="{DynamicResource TextPrimary}"
                              BorderBrush="{DynamicResource BorderDefault}"
                              FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>
                </Grid>

                <!-- Hidden: Category (kept for code-behind compatibility) -->
                <ComboBox x:Name="CategoryCombo" IsEditable="True" Visibility="Collapsed"/>

                <!-- Prompt Text -->
                <TextBox Grid.Row="1" x:Name="PromptBox" FontSize="11" Padding="4,3"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Foreground="{DynamicResource TextPrimary}"
                         BorderBrush="{DynamicResource BorderDefault}"
                         FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>

                <!-- Buttons (Doc Factory style: compact colored, right-aligned) -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,3,0,0">
                    <Button x:Name="CustomizeButton"
                            Content="{DynamicResource PE.Customize}"
                            Click="Customize_Click" Padding="6,2" Margin="0,0,3,0" Cursor="Hand"
                            Background="#C9A84C" Foreground="White"
                            BorderThickness="0" FontSize="10" FontWeight="SemiBold"
                            IsEnabled="False"
                            ToolTip="{DynamicResource PE.CustomizeTooltip}"
                            FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>
                    <Button x:Name="SaveButton"
                            Content="{DynamicResource PE.Save}"
                            Click="Save_Click" Padding="6,2" Margin="0,0,3,0" Cursor="Hand"
                            Background="#B8942F" Foreground="White"
                            BorderThickness="0" FontSize="10" FontWeight="SemiBold"
                            FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>
                    <Button x:Name="ConfirmToChatButton"
                            Content="{DynamicResource PE.ConfirmToChat}"
                            Click="ConfirmToChat_Click" Padding="6,2" Cursor="Hand"
                            Background="#9A7B25" Foreground="White"
                            BorderThickness="0" FontSize="10" FontWeight="SemiBold"
                            IsEnabled="False"
                            ToolTip="{DynamicResource PE.ConfirmToChatTooltip}"
                            FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Splitter -->
        <GridSplitter Grid.Row="0" Grid.RowSpan="3" Grid.Column="5"
                      Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      Background="Transparent" Cursor="SizeWE" ResizeBehavior="PreviousAndNext"/>

        <!-- Col 6: OUTPUT — 成果物パネル -->
        <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="6"
                BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Header -->
                    <RowDefinition Height="Auto"/>  <!-- Filter -->
                    <RowDefinition Height="*"/>     <!-- List -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Padding="8,5"
                        BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,0,0,1">
                    <Border.Background>
                        <SolidColorBrush Color="#B8942F" Opacity="0.08"/>
                    </Border.Background>
                    <DockPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                       Foreground="{DynamicResource AccentGold}"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock x:Name="ArtifactHeaderText"
                                       Text="{DynamicResource PE.ArtifactTitle}" FontWeight="SemiBold" FontSize="12"
                                       Foreground="{DynamicResource AccentGold}"
                                       FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>
                            <TextBlock x:Name="ArtifactCountBadge" Text="" FontSize="10"
                                       Foreground="{DynamicResource TextSecondary}"
                                       VerticalAlignment="Center" Margin="6,0,0,0"
                                       FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="OpenArtifactFolderButton"
                                    Click="OpenArtifactFolder_Click" Padding="3,1" MinWidth="0" MinHeight="0"
                                    Cursor="Hand"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource AccentGold}"
                                    ToolTip="{DynamicResource PE.OpenFolder}">
                                <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Filter -->
                <Border Grid.Row="1" Padding="4,3"
                        BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,0,0,1">
                    <DockPanel>
                        <ComboBox x:Name="ArtifactFilterCombo" DockPanel.Dock="Left"
                                  FontSize="11" Padding="3,1" MinWidth="70"
                                  SelectionChanged="ArtifactFilter_Changed"
                                  Foreground="{DynamicResource TextPrimary}"
                                  BorderBrush="{DynamicResource BorderDefault}"
                                  FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>
                        <TextBox x:Name="ArtifactSearchBox" Margin="4,0,0,0"
                                 FontSize="11" Padding="3,1"
                                 TextChanged="ArtifactSearch_Changed"
                                 Foreground="{DynamicResource TextPrimary}"
                                 BorderBrush="{DynamicResource BorderDefault}"
                                 FontFamily="Yu Gothic UI, Meiryo, Segoe UI"/>
                    </DockPanel>
                </Border>

                <!-- Output content area -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled" Padding="4">
                    <StackPanel x:Name="OutputPanel">
                        <!-- Empty state -->
                        <TextBlock x:Name="OutputEmptyText"
                                   Text="{DynamicResource PE.OutputEmpty}"
                                   FontSize="11" Foreground="{DynamicResource TextSecondary}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontFamily="Yu Gothic UI, Meiryo, Segoe UI"
                                   TextWrapping="Wrap" Margin="20"/>
                        <!-- Output items will be added dynamically -->
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Splitter -->
        <GridSplitter Grid.Row="0" Grid.RowSpan="3" Grid.Column="7"
                      Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      Background="Transparent" Cursor="SizeWE" ResizeBehavior="PreviousAndNext"/>

        <!-- Col 8: ④ AI Chat — コンシェルジュ -->
        <local:ChatPanelView x:Name="PlanningChatPanel" Grid.Row="1" Grid.RowSpan="2" Grid.Column="8"/>
    </Grid>
</UserControl>
