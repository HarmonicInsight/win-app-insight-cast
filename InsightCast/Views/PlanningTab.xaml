<UserControl x:Class="InsightCast.Views.PlanningTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:InsightCast.Converters"
             xmlns:local="clr-namespace:InsightCast.Views"
             xmlns:ref="clr-namespace:InsightCommon.UI.Reference;assembly=InsightCommon">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>      <!-- 0: Main 4-panel area -->
            <RowDefinition Height="Auto"/>   <!-- 1: Action buttons bar -->
        </Grid.RowDefinitions>

        <!-- ═══ Row 0: 4-Panel Layout ═══ -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="RefCol" Width="200" MinWidth="120" MaxWidth="320"/>
                <ColumnDefinition x:Name="RefSplitterCol" Width="Auto"/>
                <ColumnDefinition Width="200" MinWidth="120" MaxWidth="320"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition x:Name="OutputCol" Width="280" MinWidth="180" MaxWidth="500"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition x:Name="ChatCol" Width="300" MinWidth="220" MaxWidth="500"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ Col 0: ① Input — 参考資料 ═══ -->
            <Border x:Name="RefBorder" Grid.Column="0"
                    BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- Section Header -->
                    <Border Grid.Row="0" Padding="8,4"
                            BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,0,0,1">
                        <Border.Background>
                            <SolidColorBrush Color="#4CAF50" Opacity="0.08"/>
                        </Border.Background>
                        <TextBlock Text="{DynamicResource PE.InputHeader}" FontWeight="SemiBold" FontSize="11"
                                   Foreground="#4CAF50"/>
                    </Border>
                    <ref:ReferencePanelView Grid.Row="1" x:Name="ReferencePanelControl"/>
                </Grid>
            </Border>

            <!-- Splitter -->
            <GridSplitter x:Name="RefSplitter" Grid.Column="1" Width="5"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="Transparent" Cursor="SizeWE" ResizeBehavior="PreviousAndNext"/>

            <!-- ═══ Col 2: ② Process — プロンプト一覧 ═══ -->
            <Border Grid.Column="2" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Section Header -->
                    <Border Grid.Row="0" Padding="8,4"
                            BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,0,0,1">
                        <Border.Background>
                            <SolidColorBrush Color="#B8942F" Opacity="0.08"/>
                        </Border.Background>
                        <TextBlock Text="{DynamicResource PE.ProcessHeader}" FontWeight="SemiBold" FontSize="11"
                                   Foreground="{DynamicResource AccentGold}"/>
                    </Border>

                    <!-- Prompt List Header -->
                    <Border Grid.Row="1" Padding="8,4"
                            BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           Foreground="{DynamicResource AccentGold}"
                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="{DynamicResource PE.PromptList}" FontWeight="SemiBold" FontSize="10"
                                           Foreground="{DynamicResource AccentGold}"/>
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="AddGroupButton" Content="&#xE8F4;" FontFamily="Segoe MDL2 Assets"
                                        Click="AddGroup_Click" Padding="3,1" MinWidth="0" MinHeight="0"
                                        FontSize="10" Cursor="Hand"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="{DynamicResource AccentGold}"
                                        ToolTip="{DynamicResource PE.AddGroup}"/>
                                <Button x:Name="AddButton" Content="+" Click="Add_Click"
                                        Padding="4,0" MinWidth="18" MinHeight="0"
                                        FontSize="13" FontWeight="Bold" Cursor="Hand"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="{DynamicResource AccentGold}"
                                        ToolTip="{DynamicResource PE.Add}"/>
                                <Button x:Name="DeleteButton" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                                        Click="Delete_Click" Padding="3,1" MinWidth="0" MinHeight="0"
                                        FontSize="10" Cursor="Hand"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="OrangeRed"
                                        ToolTip="{DynamicResource PE.Delete}"
                                        IsEnabled="False"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Tree -->
                    <TreeView Grid.Row="2" x:Name="PromptTree" BorderThickness="0"
                              SelectedItemChanged="PromptTree_SelectedItemChanged"
                              Background="Transparent">
                        <TreeView.Resources>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="Padding" Value="2,1"/>
                                <Setter Property="FontSize" Value="11"/>
                            </Style>
                        </TreeView.Resources>
                    </TreeView>
                </Grid>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="Transparent" Cursor="SizeWE" ResizeBehavior="PreviousAndNext"/>

            <!-- ═══ Col 4: ② Process — プロンプトエディタ ═══ -->
            <Grid x:Name="EditorPanel" Grid.Column="4" IsEnabled="False" Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- 0: Name -->
                    <RowDefinition Height="Auto"/>  <!-- 1: Category -->
                    <RowDefinition Height="Auto"/>  <!-- 2: Model -->
                    <RowDefinition Height="Auto"/>  <!-- 3: Prompt label + font -->
                    <RowDefinition Height="*"/>     <!-- 4: Prompt box -->
                    <RowDefinition Height="Auto"/>  <!-- 5: Execute button -->
                    <RowDefinition Height="Auto"/>  <!-- 6: Secondary buttons -->
                </Grid.RowDefinitions>

                <!-- Name -->
                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource PE.Name}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,8,0"
                               Foreground="{DynamicResource TextTertiary}"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="NameBox" FontSize="12" Padding="6,3"
                             Foreground="{DynamicResource TextPrimary}"
                             BorderBrush="{DynamicResource BorderDefault}"/>
                </Grid>

                <!-- Category -->
                <Grid Grid.Row="1" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource PE.Category}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,8,0"
                               Foreground="{DynamicResource TextTertiary}"
                               VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" x:Name="CategoryCombo" IsEditable="True"
                              FontSize="11" Padding="4,2"
                              Foreground="{DynamicResource TextPrimary}"
                              BorderBrush="{DynamicResource BorderDefault}"/>
                </Grid>

                <!-- Model -->
                <Grid Grid.Row="2" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource PE.Model}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,8,0"
                               Foreground="{DynamicResource TextTertiary}"
                               VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" x:Name="ModelCombo"
                              FontSize="11" Padding="4,2"
                              Foreground="{DynamicResource TextPrimary}"
                              BorderBrush="{DynamicResource BorderDefault}"/>
                </Grid>

                <!-- Prompt Text label + font controls -->
                <DockPanel Grid.Row="3" Margin="0,0,0,3">
                    <TextBlock Text="{DynamicResource PE.PromptText}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextTertiary}"
                               VerticalAlignment="Center"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="A&#x2212;" Click="FontSizeDown_Click" Padding="4,1" MinWidth="24" MinHeight="0"
                                FontSize="10" Background="Transparent" BorderBrush="{DynamicResource BorderDefault}"
                                BorderThickness="1" Cursor="Hand" Margin="0,0,2,0"/>
                        <TextBlock x:Name="FontSizeLabel" Text="12" FontSize="10" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextTertiary}" MinWidth="16" TextAlignment="Center"/>
                        <Button Content="A+" Click="FontSizeUp_Click" Padding="4,1" MinWidth="24" MinHeight="0"
                                FontSize="10" Background="Transparent" BorderBrush="{DynamicResource BorderDefault}"
                                BorderThickness="1" Cursor="Hand" Margin="2,0,0,0"/>
                    </StackPanel>
                </DockPanel>

                <!-- Prompt Text -->
                <TextBox Grid.Row="4" x:Name="PromptBox" FontSize="12" Padding="6,4"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Foreground="{DynamicResource TextPrimary}"
                         BorderBrush="{DynamicResource BorderDefault}"/>

                <!-- Execute button (Doc Factory style — big gold full-width) -->
                <Button x:Name="ExecuteButton" Grid.Row="5"
                        Click="Execute_Click" Cursor="Hand"
                        Padding="16,10" Margin="0,8,0,0" FontSize="13"
                        HorizontalAlignment="Stretch"
                        ToolTip="{DynamicResource PE.ExecuteTooltip}"
                        IsEnabled="False">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{DynamicResource BrandPrimary}"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#A68329"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#CCCCCC"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{DynamicResource PE.Execute}" VerticalAlignment="Center"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>

                <!-- Secondary buttons row -->
                <DockPanel Grid.Row="6" Margin="0,6,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="CustomizeButton"
                                Click="Customize_Click" Padding="10,4" Margin="0,0,6,0" Cursor="Hand"
                                Background="Transparent"
                                BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1"
                                FontSize="11"
                                IsEnabled="False"
                                ToolTip="{DynamicResource PE.CustomizeTooltip}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,4,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource PE.Customize}"
                                           Foreground="{DynamicResource TextPrimary}"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="SaveButton"
                                Click="Save_Click" Padding="10,4" Cursor="Hand"
                                Background="Transparent"
                                BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1"
                                FontSize="11">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,4,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource PE.Save}"
                                           Foreground="{DynamicResource TextPrimary}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="5" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="Transparent" Cursor="SizeWE" ResizeBehavior="PreviousAndNext"/>

            <!-- ═══ Col 6: ③ Output — 成果物 ═══ -->
            <Border Grid.Column="6" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Section Header -->
                    <Border Grid.Row="0" Padding="8,4"
                            BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,0,0,1">
                        <Border.Background>
                            <SolidColorBrush Color="#FF6D00" Opacity="0.08"/>
                        </Border.Background>
                        <DockPanel>
                            <TextBlock Text="{DynamicResource PE.OutputHeader}" FontWeight="SemiBold" FontSize="11"
                                       Foreground="#FF6D00"/>
                        </DockPanel>
                    </Border>

                    <!-- Filter tabs -->
                    <Border Grid.Row="1" Padding="6,3"
                            BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource PE.OutputAll}" FontSize="10"
                                       Foreground="{DynamicResource TextSecondary}"
                                       Padding="6,2" Cursor="Hand"/>
                        </StackPanel>
                    </Border>

                    <!-- Output content area -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled" Padding="8">
                        <StackPanel x:Name="OutputPanel">
                            <!-- Empty state -->
                            <TextBlock x:Name="OutputEmptyText"
                                       Text="{DynamicResource PE.OutputEmpty}"
                                       FontSize="11" FontStyle="Italic"
                                       Foreground="{DynamicResource TextTertiary}"
                                       TextWrapping="Wrap" Margin="0,20,0,0"
                                       HorizontalAlignment="Center"/>
                            <!-- Output items will be added dynamically -->
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="7" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="Transparent" Cursor="SizeWE" ResizeBehavior="PreviousAndNext"/>

            <!-- ═══ Col 8: ④ AI Chat — コンシェルジュ ═══ -->
            <local:ChatPanelView x:Name="PlanningChatPanel" Grid.Column="8"/>
        </Grid>

        <!-- ═══ Row 1: Action Buttons ═══ -->
        <Border Grid.Row="1" Padding="8,5"
                BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,1,0,0">
            <Border.Background>
                <SolidColorBrush Color="#B8942F" Opacity="0.05"/>
            </Border.Background>
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <!-- Apply (gold primary — Doc Factory style) -->
                    <Button x:Name="ApplyButton" Click="Apply_Click"
                            Padding="14,5" Margin="0,0,6,0" Cursor="Hand"
                            Background="#B8942F" Foreground="White"
                            BorderThickness="0" FontSize="11" FontWeight="SemiBold"
                            ToolTip="{DynamicResource PE.ApplyTooltip}"
                            IsEnabled="False">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0"/>
                            <TextBlock Text="{DynamicResource PE.Apply}"/>
                        </StackPanel>
                    </Button>
                    <!-- Register (transparent border — Doc Factory style) -->
                    <Button x:Name="RegisterButton" Click="Register_Click"
                            Padding="14,5" Margin="0,0,6,0" Cursor="Hand"
                            Background="Transparent"
                            BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1"
                            FontSize="11" FontWeight="SemiBold"
                            ToolTip="{DynamicResource PE.RegisterTooltip}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="{DynamicResource PE.Register}"
                                       Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                    </Button>
                    <!-- Confirm (transparent border — Doc Factory style) -->
                    <Button x:Name="ConfirmButton" Click="Confirm_Click"
                            Padding="14,5" Cursor="Hand"
                            Background="Transparent"
                            BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1"
                            FontSize="11" FontWeight="SemiBold"
                            ToolTip="{DynamicResource PE.ConfirmTooltip}"
                            IsEnabled="False">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8A3;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="{DynamicResource PE.Confirm}"
                                       Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
