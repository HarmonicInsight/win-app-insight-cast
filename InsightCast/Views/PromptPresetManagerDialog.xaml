<Window x:Class="InsightCast.Views.PromptPresetManagerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource AIPrompt.ManageTitle}" Height="550" Width="600"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        MinHeight="400" MinWidth="480"
        Background="{DynamicResource BgPrimary}">

    <Window.Resources>
        <Style x:Key="TabRadioButton" TargetType="RadioButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="SmallButton" TargetType="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="{DynamicResource AIPrompt.ManageTitle}"
                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"
                   Foreground="{DynamicResource TextPrimary}"/>

        <!-- Tab selector -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <RadioButton x:Name="MyPromptsTab" Content="{DynamicResource AIPrompt.MyPrompts}"
                         GroupName="PromptTab" IsChecked="True" Checked="TabChanged"
                         Style="{StaticResource TabRadioButton}"/>
            <RadioButton x:Name="PresetsTab" Content="{DynamicResource AIPrompt.Presets}"
                         GroupName="PromptTab" Checked="TabChanged"
                         Style="{StaticResource TabRadioButton}"/>
        </StackPanel>

        <!-- Filter bar -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="CategoryFilterCombo" Grid.Column="0" Width="140" FontSize="12"
                      Padding="4,3" Margin="0,0,8,0"
                      SelectionChanged="CategoryFilter_Changed"/>
            <TextBox x:Name="SearchBox" Grid.Column="1" FontSize="12" Padding="6,3"
                     TextChanged="SearchBox_TextChanged">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                            <VisualBrush.Visual>
                                                <Label Content="{DynamicResource AIPrompt.SearchPlaceholder}"
                                                       Foreground="LightGray" FontSize="12" Padding="4,0"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
        </Grid>

        <!-- Preset List -->
        <ListBox Grid.Row="3" x:Name="PresetList" FontSize="13"
                 SelectionChanged="PresetList_SelectionChanged"
                 MouseDoubleClick="PresetList_DoubleClick"
                 HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="8,6" Margin="0,1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- Row 0: Name + badges -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Text=" *" Foreground="#FFC107" FontSize="12" VerticalAlignment="Center" Margin="4,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text=" [Pin]" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0" Foreground="#9C27B0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Border CornerRadius="3" Padding="6,1" Margin="8,0,0,0" Background="#E8EAF6" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasCategory}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Category}" FontSize="10" Foreground="#3F51B5"/>
                                </Border>
                            </StackPanel>
                            <!-- Row 1: Description -->
                            <TextBlock Grid.Row="1" Text="{Binding Description}" FontSize="11"
                                       Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0"
                                       TextTrimming="CharacterEllipsis" MaxHeight="16">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <!-- Row 2: Author + Date + Usage -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock FontSize="10" Foreground="{DynamicResource TextTertiary}" Text="{Binding Author}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="  |  " FontSize="10" Foreground="{DynamicResource TextTertiary}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Author}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding ModifiedAt, StringFormat='{}{0:yyyy-MM-dd}'}"
                                           FontSize="10" Foreground="{DynamicResource TextTertiary}"/>
                                <TextBlock Text="  |  " FontSize="10" Foreground="{DynamicResource TextTertiary}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding UsageCount}" Value="0">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock FontSize="10" Foreground="#7986CB" Text="{Binding UsageCount, StringFormat='x{0}'}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding UsageCount}" Value="0">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Buttons -->
        <Grid Grid.Row="4" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <!-- Left: Export/Import -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="{DynamicResource AIPrompt.Export}" Click="ExportPresets_Click" Style="{StaticResource SmallButton}" Margin="0,0,6,0"/>
                <Button Content="{DynamicResource AIPrompt.Import}" Click="ImportPresets_Click" Style="{StaticResource SmallButton}"/>
            </StackPanel>
            <!-- Right: CRUD buttons -->
            <WrapPanel Grid.Column="2" HorizontalAlignment="Right">
                <Button Content="{DynamicResource AIPrompt.New}" Click="NewPreset_Click" Style="{StaticResource SmallButton}" Margin="0,0,6,0"/>
                <Button x:Name="DuplicateBtn" Content="{DynamicResource AIPrompt.Duplicate}" Click="DuplicatePreset_Click" Style="{StaticResource SmallButton}" Margin="0,0,6,0" IsEnabled="False"/>
                <Button x:Name="PinBtn" Click="PinPreset_Click" Style="{StaticResource SmallButton}" Margin="0,0,6,0" IsEnabled="False" Content="{DynamicResource AIPrompt.Pin}"/>
                <Button x:Name="EditBtn" Content="{DynamicResource AIPrompt.Edit}" Click="EditPreset_Click" Style="{StaticResource SmallButton}" Margin="0,0,6,0" IsEnabled="False"/>
                <Button x:Name="DeleteBtn" Content="{DynamicResource AIPrompt.Delete}" Click="DeletePreset_Click" Style="{StaticResource SmallButton}" Margin="0,0,6,0" IsEnabled="False" Foreground="#D32F2F"/>
                <Button x:Name="DefaultBtn" Content="{DynamicResource AIPrompt.SetDefault}" Click="SetDefault_Click" Style="{StaticResource SmallButton}" Margin="0,0,12,0" IsEnabled="False"/>
                <Button Content="{DynamicResource Common.Close}" Click="Close_Click" Style="{StaticResource SmallButton}"/>
            </WrapPanel>
        </Grid>
    </Grid>
</Window>
