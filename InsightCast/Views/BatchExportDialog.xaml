<Window x:Class="InsightCast.Views.BatchExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource BatchExport.Title}"
        Width="700" Height="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="100"/>
        </Style>
        <Style x:Key="SectionBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BgCard}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefault}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="Padding" Value="16,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Project List Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="AddButton" Content="{DynamicResource BatchExport.AddProjects}"
                    Style="{StaticResource DialogButton}" Click="AddButton_Click"/>
            <Button x:Name="RemoveButton" Content="{DynamicResource BatchExport.RemoveSelected}"
                    Style="{StaticResource DialogButton}" Click="RemoveButton_Click"/>
        </StackPanel>

        <!-- Project List -->
        <Border Grid.Row="1" Style="{StaticResource SectionBorder}">
            <ListView x:Name="ProjectListView" SelectionMode="Extended">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="File" Width="300"
                                        DisplayMemberBinding="{Binding FileName}"/>
                        <GridViewColumn Header="Status" Width="100"
                                        DisplayMemberBinding="{Binding Status}"/>
                        <GridViewColumn Header="Output" Width="200"
                                        DisplayMemberBinding="{Binding OutputName}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- Settings -->
        <Border Grid.Row="2" Style="{StaticResource SectionBorder}">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource BatchExport.OutputDirectory}" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="OutputDirTextBox" Grid.Column="1" Height="28" VerticalContentAlignment="Center"/>
                    <Button Grid.Column="2" Content="{DynamicResource BatchExport.Browse}"
                            Style="{StaticResource DialogButton}" MinWidth="70" Click="BrowseOutputDir_Click"/>
                </Grid>
                <CheckBox x:Name="ContinueOnErrorCheckBox" Content="{DynamicResource BatchExport.ContinueOnError}"
                          IsChecked="True"/>
            </StackPanel>
        </Border>

        <!-- Progress -->
        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="ProgressLabel" Grid.Column="0" Foreground="{DynamicResource TextSecondary}"/>
                <TextBlock x:Name="CurrentProjectLabel" Grid.Column="1" Foreground="{DynamicResource TextTertiary}"/>
            </Grid>
            <ProgressBar x:Name="ProgressBar" Height="20" Minimum="0" Maximum="100"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="StartButton" Content="{DynamicResource BatchExport.StartBatch}"
                    Style="{StaticResource DialogButton}" Click="StartButton_Click"/>
            <Button x:Name="CancelButton" Content="{DynamicResource BatchExport.Cancel}"
                    Style="{StaticResource DialogButton}" IsCancel="True" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
