<Window x:Class="InsightCast.Views.QuickModeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Quick.WindowTitle}"
        Width="640" Height="540"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        AllowDrop="True"
        PreviewDragOver="Window_PreviewDragOver"
        Drop="Window_Drop">

    <Border CornerRadius="12" Background="#FAF8F5"
            BorderBrush="#E7E2DA" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.12" ShadowDepth="4" Color="#1C1917"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Header -->
                <RowDefinition Height="*"/>      <!-- Content -->
                <RowDefinition Height="Auto"/>   <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- ═══ Header ═══ -->
            <Border Grid.Row="0" CornerRadius="12,12,0,0" Padding="20,14,20,12"
                    Background="#F5F1EB"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Insight Training Studio" FontSize="16" FontWeight="Bold"
                                       Foreground="#1C1917" VerticalAlignment="Center"/>
                            <Border Background="#B8942F" CornerRadius="6"
                                    Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource Quick.WindowTitle}"
                                           FontSize="9" Foreground="White" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="{DynamicResource Quick.Tagline}"
                                   FontSize="11" Foreground="#57534E" Margin="0,3,0,0"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                            Width="28" Height="28"
                            Background="Transparent" Foreground="#A8A29E" BorderThickness="0"
                            Click="CloseButton_Click" Cursor="Hand"
                            ToolTip="{DynamicResource Common.Close}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        CornerRadius="14" Width="28" Height="28">
                                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="10" HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{TemplateBinding Foreground}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#EEEBE5"/>
                                        <Setter Property="Foreground" Value="#57534E"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Gold accent line -->
            <Rectangle Grid.Row="0" VerticalAlignment="Bottom" Height="2">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#B8942F" Offset="0"/>
                        <GradientStop Color="#D4BC6A" Offset="0.5"/>
                        <GradientStop Color="#B8942F" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- ═══ Main Content ═══ -->
            <Grid Grid.Row="1" Margin="28,20,28,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>      <!-- Drop zone -->
                    <RowDefinition Height="Auto"/>   <!-- Settings -->
                    <RowDefinition Height="Auto"/>   <!-- Generate -->
                </Grid.RowDefinitions>

                <!-- Drop Zone -->
                <Border x:Name="DropZone" Grid.Row="0"
                        CornerRadius="10" Margin="0,0,0,16" Cursor="Hand"
                        MouseLeftButtonDown="DropZone_Click">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#FFFFFF"/>
                            <Setter Property="BorderBrush" Value="#E7E2DA"/>
                            <Setter Property="BorderThickness" Value="2"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F5F0E1"/>
                                    <Setter Property="BorderBrush" Value="#C9A84C"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <!-- Default: drop prompt -->
                        <StackPanel x:Name="DropPrompt" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border Width="60" Height="60" CornerRadius="14" Margin="0,0,0,12"
                                    Background="#F5F0E1" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="26" Foreground="#B8942F"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="DropMainText"
                                       Text="{DynamicResource Quick.DropZone.Title}"
                                       FontSize="17" FontWeight="SemiBold" Foreground="#1C1917"
                                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="{DynamicResource Quick.DropZone.Subtitle}"
                                       FontSize="12" Foreground="#57534E"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="{DynamicResource Quick.DropZone.SelectFile}"
                                       FontSize="11" Foreground="#B8942F"
                                       HorizontalAlignment="Center"
                                       TextDecorations="Underline" Cursor="Hand"/>
                        </StackPanel>

                        <!-- File loaded state -->
                        <StackPanel x:Name="FileLoadedPanel" HorizontalAlignment="Center"
                                    VerticalAlignment="Center" Visibility="Collapsed">
                            <Border Width="52" Height="52" CornerRadius="26" Margin="0,0,0,10"
                                    Background="#E8F5E9" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="22" Foreground="#16A34A"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="LoadedFileName" FontSize="15" FontWeight="SemiBold"
                                       Foreground="#1C1917" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                            <TextBlock x:Name="LoadedSlideCount" FontSize="12"
                                       Foreground="#57534E" HorizontalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Quick.DropReplace}"
                                       FontSize="11" Foreground="#B8942F"
                                       HorizontalAlignment="Center" Margin="0,10,0,0"
                                       TextDecorations="Underline" Cursor="Hand"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Settings -->
                <StackPanel Grid.Row="1" Margin="0,0,0,12">
                    <!-- Speaker -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE767;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="12" Foreground="#B8942F" Margin="0,0,6,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Quick.Speaker}" FontSize="12"
                                       Foreground="#1C1917" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ComboBox x:Name="SpeakerCombo" Grid.Column="1" FontSize="12"
                                  Height="32"/>
                    </Grid>

                    <!-- Orientation -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE809;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="12" Foreground="#B8942F" Margin="0,0,6,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Quick.Orientation}" FontSize="12"
                                       Foreground="#1C1917" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ComboBox x:Name="ResolutionCombo" Grid.Column="1" FontSize="12"
                                  Height="32" SelectedIndex="0">
                            <ComboBoxItem Content="{DynamicResource Quick.Res.Landscape}" Tag="1920x1080"/>
                            <ComboBoxItem Content="1280x720 (HD)" Tag="1280x720"/>
                            <ComboBoxItem Content="{DynamicResource Quick.Res.Portrait}" Tag="1080x1920"/>
                        </ComboBox>
                    </Grid>

                    <!-- Speech Speed + Font Size (inline) -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Speech Speed -->
                        <Grid Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xEC57;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="12" Foreground="#B8942F" Margin="0,0,6,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Quick.SpeechSpeed}" FontSize="12"
                                           Foreground="#1C1917" VerticalAlignment="Center"/>
                            </StackPanel>
                            <ComboBox x:Name="SpeedCombo" Grid.Column="1" FontSize="12"
                                      Height="32" SelectedIndex="2">
                                <ComboBoxItem Content="0.8x" Tag="0.8"/>
                                <ComboBoxItem Content="1.0x" Tag="1.0"/>
                                <ComboBoxItem Content="1.2x" Tag="1.2"/>
                                <ComboBoxItem Content="1.5x" Tag="1.5"/>
                            </ComboBox>
                        </Grid>

                        <!-- Font Size -->
                        <Grid Grid.Column="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,6,0">
                                <TextBlock Text="&#xE8D2;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="12" Foreground="#B8942F" Margin="0,0,6,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Overlay.FontSize}" FontSize="12"
                                           Foreground="#1C1917" VerticalAlignment="Center"/>
                            </StackPanel>
                            <ComboBox x:Name="FontSizeCombo" Grid.Column="1" FontSize="12"
                                      Height="32" IsEditable="True" Text="28">
                                <ComboBoxItem Content="20"/>
                                <ComboBoxItem Content="24"/>
                                <ComboBoxItem Content="28"/>
                                <ComboBoxItem Content="32"/>
                                <ComboBoxItem Content="36"/>
                                <ComboBoxItem Content="42"/>
                                <ComboBoxItem Content="48"/>
                            </ComboBox>
                        </Grid>
                    </Grid>
                </StackPanel>

                <!-- Generate Button -->
                <Button x:Name="GenerateButton" Grid.Row="2"
                        Content="{DynamicResource Quick.Generate}"
                        Height="44" FontSize="14" FontWeight="SemiBold"
                        Foreground="White" BorderThickness="0" Cursor="Hand"
                        IsEnabled="False"
                        Click="GenerateButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" CornerRadius="8"
                                                Background="#B8942F"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#C9A84C"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="Bd" Property="Background" Value="#E7E2DA"/>
                                                <Setter Property="Foreground" Value="#A8A29E"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- ═══ Footer ═══ -->
            <Border Grid.Row="2" Padding="0,6,0,14"
                    BorderBrush="#F5F1EB" BorderThickness="0,1,0,0">
                <TextBlock HorizontalAlignment="Center">
                    <Hyperlink x:Name="DetailLink" Click="DetailEditor_Click"
                               Foreground="#B8942F" FontSize="12"
                               TextDecorations="None">
                        <Run Text="{DynamicResource Quick.OpenEditor}"/>
                    </Hyperlink>
                </TextBlock>
            </Border>
        </Grid>
    </Border>
</Window>
