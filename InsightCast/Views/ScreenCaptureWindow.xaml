<Window x:Class="InsightCast.Views.ScreenCaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Topmost="True"
        ShowInTaskbar="False" Background="Transparent"
        WindowState="Maximized" ResizeMode="NoResize"
        Cursor="Cross"
        KeyDown="Window_KeyDown"
        MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
        MouseMove="Canvas_MouseMove"
        MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
        MouseRightButtonDown="Canvas_MouseRightButtonDown">

    <Window.Resources>
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="#CC333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" ToolTip="{TemplateBinding ToolTip}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#CC555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <!-- Dark overlay covering entire screen -->
        <Canvas x:Name="OverlayCanvas" Background="#88000000"/>

        <!-- Selection rectangle (drawn in code) -->
        <Rectangle x:Name="SelectionRect" Stroke="#00AEFF" StrokeThickness="2"
                   StrokeDashArray="4 2" Fill="Transparent" Visibility="Collapsed"
                   IsHitTestVisible="False"/>

        <!-- Dimension label -->
        <Border x:Name="DimensionLabel" Background="#CC000000" CornerRadius="3"
                Padding="6,2" Visibility="Collapsed" IsHitTestVisible="False"
                HorizontalAlignment="Left" VerticalAlignment="Top">
            <TextBlock x:Name="DimensionText" Foreground="White" FontSize="12" FontFamily="Consolas"/>
        </Border>

        <!-- Toolbar (appears after selection) -->
        <Border x:Name="Toolbar" Visibility="Collapsed"
                Background="#DD222222" CornerRadius="6" Padding="4"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                BorderBrush="#555" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <!-- Drawing tools -->
                <Button Style="{StaticResource ToolBtn}" Content="▭" ToolTip="矩形 (R)" Click="Tool_Rect"/>
                <Button Style="{StaticResource ToolBtn}" Content="○" ToolTip="円 (C)" Click="Tool_Circle"/>
                <Button Style="{StaticResource ToolBtn}" Content="→" ToolTip="矢印 (A)" Click="Tool_Arrow"/>
                <Button Style="{StaticResource ToolBtn}" Content="─" ToolTip="線 (L)" Click="Tool_Line"/>
                <Button Style="{StaticResource ToolBtn}" Content="T" ToolTip="テキスト (T)" Click="Tool_Text"/>
                <Button Style="{StaticResource ToolBtn}" Content="▓" ToolTip="モザイク (M)" Click="Tool_Mosaic"/>
                <Button Style="{StaticResource ToolBtn}" Content="✎" ToolTip="ペン (P)" Click="Tool_Pen"/>

                <Rectangle Width="1" Fill="#555" Margin="4,4"/>

                <!-- Color picker -->
                <Button x:Name="ColorBtn" Style="{StaticResource ToolBtn}" Width="28" Height="28"
                        ToolTip="色" Click="Tool_ColorPick">
                    <Rectangle x:Name="ColorIndicator" Width="18" Height="18" Fill="Red" RadiusX="2" RadiusY="2"/>
                </Button>
                <!-- Stroke width -->
                <ComboBox x:Name="StrokeWidthCombo" Width="50" Margin="2" SelectedIndex="1"
                          VerticalContentAlignment="Center" FontSize="11">
                    <ComboBoxItem Content="1px"/>
                    <ComboBoxItem Content="2px"/>
                    <ComboBoxItem Content="4px"/>
                    <ComboBoxItem Content="6px"/>
                </ComboBox>

                <Rectangle Width="1" Fill="#555" Margin="4,4"/>

                <!-- Undo -->
                <Button Style="{StaticResource ToolBtn}" Content="↩" ToolTip="元に戻す (Ctrl+Z)" Click="Tool_Undo"/>

                <Rectangle Width="1" Fill="#555" Margin="4,4"/>

                <!-- Actions -->
                <Button Style="{StaticResource ToolBtn}" Content="📋" ToolTip="クリップボードにコピー" Click="Action_Copy" Width="40"/>
                <Button Style="{StaticResource ToolBtn}" Content="💾" ToolTip="ファイルに保存" Click="Action_Save" Width="40"/>
                <Button Style="{StaticResource ToolBtn}" Content="📌" ToolTip="シーンに貼り付け" Click="Action_PinToScene" Width="40"/>
                <Button Style="{StaticResource ToolBtn}" Content="✕" ToolTip="キャンセル (Esc)" Click="Action_Cancel" Width="40"/>
            </StackPanel>
        </Border>

        <!-- Color picker popup -->
        <Popup x:Name="ColorPopup" StaysOpen="False" Placement="Bottom"
               PlacementTarget="{Binding ElementName=ColorBtn}">
            <Border Background="#333" CornerRadius="4" Padding="6" BorderBrush="#555" BorderThickness="1">
                <WrapPanel Width="160">
                    <Button Width="28" Height="28" Margin="2" Background="Red" Click="ColorPick_Click" Tag="Red"/>
                    <Button Width="28" Height="28" Margin="2" Background="#FF6600" Click="ColorPick_Click" Tag="#FF6600"/>
                    <Button Width="28" Height="28" Margin="2" Background="Yellow" Click="ColorPick_Click" Tag="Yellow"/>
                    <Button Width="28" Height="28" Margin="2" Background="Lime" Click="ColorPick_Click" Tag="Lime"/>
                    <Button Width="28" Height="28" Margin="2" Background="Cyan" Click="ColorPick_Click" Tag="Cyan"/>
                    <Button Width="28" Height="28" Margin="2" Background="#0088FF" Click="ColorPick_Click" Tag="#0088FF"/>
                    <Button Width="28" Height="28" Margin="2" Background="Magenta" Click="ColorPick_Click" Tag="Magenta"/>
                    <Button Width="28" Height="28" Margin="2" Background="White" Click="ColorPick_Click" Tag="White"/>
                    <Button Width="28" Height="28" Margin="2" Background="Black" Click="ColorPick_Click" Tag="Black"/>
                    <Button Width="28" Height="28" Margin="2" Background="#888888" Click="ColorPick_Click" Tag="#888888"/>
                </WrapPanel>
            </Border>
        </Popup>

        <!-- Text input popup -->
        <Border x:Name="TextInputPanel" Visibility="Collapsed"
                Background="#DD222222" CornerRadius="4" Padding="6"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                BorderBrush="#555" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="TextInputBox" Width="200" FontSize="14" Padding="4"
                         Background="#444" Foreground="White" BorderBrush="#666"
                         KeyDown="TextInput_KeyDown"/>
                <Button Content="OK" Margin="4,0,0,0" Padding="8,4" Click="TextInput_OK"
                        Background="#0088FF" Foreground="White" BorderBrush="#006ACC"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
