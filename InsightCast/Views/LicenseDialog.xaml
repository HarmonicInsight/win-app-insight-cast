<Window x:Class="InsightCast.Views.LicenseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="License - Insight Training Studio"
        Width="500" Height="680"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Border Background="{DynamicResource BgPrimary}"
            BorderBrush="{DynamicResource BorderDefault}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TitleBar -->
            <Border Grid.Row="0" Background="{DynamicResource BgSecondary}"
                    CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="{DynamicResource Backstage.License}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               VerticalAlignment="Center" Margin="16,0,0,0"/>
                    <Button Click="CloseButton_Click"
                            Style="{DynamicResource CloseButtonStyle}"
                            HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0">
                        <TextBlock Text="&#xE106;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0">
                <StackPanel Margin="32,24,32,32">

                    <!-- Product Name -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,24">
                        <TextBlock Text="Insight Training" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource BrandPrimary}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Studio" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource BrandPrimary}"
                                   HorizontalAlignment="Center" Margin="0,-4,0,0"/>
                    </StackPanel>

                    <!-- Current Plan Section -->
                    <Border Background="{DynamicResource BgCard}"
                            BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1"
                            CornerRadius="8" Padding="24,20" Margin="0,0,0,16">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="PlanLabel" Text="{DynamicResource License.CurrentPlan}"
                                       FontSize="12" Foreground="{DynamicResource TextSecondary}"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock x:Name="PlanText" Text="FREE" FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource BrandPrimary}"
                                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock x:Name="ExpiryText" Text=""
                                       FontSize="12" Foreground="{DynamicResource TextSecondary}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Feature List -->
                    <Border Background="{DynamicResource BgCard}"
                            BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1"
                            CornerRadius="8" Padding="20,16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock x:Name="FeatureListLabel" Text="{DynamicResource License.Features}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12"/>

                            <!-- Plan description -->
                            <TextBlock x:Name="PlanDescription" Text="FREE = 基本機能 / TRIAL・BIZ = フル機能 / ENT = エンタープライズ"
                                       FontSize="11" Foreground="{DynamicResource TextSecondary}"
                                       Margin="0,0,0,12"/>

                            <!-- FREE features -->
                            <TextBlock x:Name="StdSectionLabel" Text="── FREE（基本機能）──"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="動画生成"
                                           FontSize="12" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Grid.Column="1" Text="&#x2705;" FontSize="12"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="VOICEVOXナレーション"
                                           FontSize="12" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Grid.Column="1" Text="&#x2705;" FontSize="12"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="テキストオーバーレイ"
                                           FontSize="12" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Grid.Column="1" Text="&#x2705;" FontSize="12"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="BGM設定"
                                           FontSize="12" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Grid.Column="1" Text="&#x2705;" FontSize="12"/>
                            </Grid>

                            <!-- TRIAL/BIZ features -->
                            <TextBlock Text="── TRIAL / BIZ（フル機能）──"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondary}" Margin="0,8,0,6"/>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="字幕・字幕スタイル"
                                           FontSize="12" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock x:Name="Feature1Status" Grid.Column="1" Text="&#x1F512; TRIAL+" FontSize="12"
                                           Foreground="{DynamicResource TextTertiary}"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="トランジション効果"
                                           FontSize="12" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock x:Name="Feature2Status" Grid.Column="1" Text="&#x1F512; TRIAL+" FontSize="12"
                                           Foreground="{DynamicResource TextTertiary}"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="PPTX取込"
                                           FontSize="12" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock x:Name="Feature3Status" Grid.Column="1" Text="&#x1F512; TRIAL+" FontSize="12"
                                           Foreground="{DynamicResource TextTertiary}"/>
                            </Grid>

                            <!-- ENT features -->
                            <TextBlock x:Name="EntSectionLabel" Text="── ENT（エンタープライズ）──"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondary}" Margin="0,8,0,6"/>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="AIアシスタント"
                                           FontSize="12" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock x:Name="Feature4Status" Grid.Column="1" Text="&#x1F512; ENT" FontSize="12"
                                           Foreground="{DynamicResource TextTertiary}"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="VRMアバター"
                                           FontSize="12" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock x:Name="Feature5Status" Grid.Column="1" Text="&#x1F512; ENT" FontSize="12"
                                           Foreground="{DynamicResource TextTertiary}"/>
                            </Grid>
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="高解像度出力(4K)"
                                           FontSize="12" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock x:Name="Feature6Status" Grid.Column="1" Text="&#x1F512; ENT" FontSize="12"
                                           Foreground="{DynamicResource TextTertiary}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- License Activation -->
                    <Border Background="{DynamicResource BgCard}"
                            BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1"
                            CornerRadius="8" Padding="20,16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock x:Name="ActivationLabel" Text="{DynamicResource License.Activation}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12"/>

                            <TextBlock Text="{DynamicResource License.Email}"
                                       FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                            <TextBox x:Name="EmailTextBox" Height="32" FontSize="13" Padding="8,0"
                                     VerticalContentAlignment="Center" Margin="0,0,0,12"/>

                            <TextBlock Text="{DynamicResource License.Key}"
                                       FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                            <TextBox x:Name="LicenseKeyTextBox" Height="32" FontSize="13" Padding="8,0"
                                     VerticalContentAlignment="Center" Margin="0,0,0,16"
                                     FontFamily="Consolas, Courier New" CharacterCasing="Upper"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button x:Name="ActivateButton" Content="{DynamicResource License.Activate}" Click="ActivateButton_Click"
                                        Background="{DynamicResource BrandPrimary}" Foreground="White"
                                        Margin="0,0,8,0" Padding="24,8" FontWeight="SemiBold" Cursor="Hand"/>
                                <Button x:Name="ClearButton" Content="{DynamicResource License.Clear}" Click="ClearButton_Click"
                                        Background="{DynamicResource BgSecondary}" Foreground="{DynamicResource TextPrimary}"
                                        Padding="16,8" Cursor="Hand"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Status Message -->
                    <TextBlock x:Name="StatusMessage" Text="" FontSize="12"
                               TextWrapping="Wrap" HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
