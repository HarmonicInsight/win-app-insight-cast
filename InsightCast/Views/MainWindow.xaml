<Window x:Class="InsightCast.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:InsightCast.Converters"
        xmlns:views="clr-namespace:InsightCast.Views"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        Title="{Binding WindowTitle}"
        MinWidth="1100" MinHeight="750"
        Width="1300" Height="950"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged"
        AllowDrop="True"
        PreviewDragOver="Window_PreviewDragOver"
        Drop="Window_Drop">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>

    </Window.Resources>

    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.New" Executed="NewProject_Executed"/>
        <CommandBinding Command="ApplicationCommands.Open" Executed="OpenProject_Executed"/>
        <CommandBinding Command="ApplicationCommands.Save" Executed="SaveProject_Executed"/>
    </Window.CommandBindings>

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="ApplicationCommands.New"/>
        <KeyBinding Key="O" Modifiers="Control" Command="ApplicationCommands.Open"/>
        <KeyBinding Key="S" Modifiers="Control" Command="ApplicationCommands.Save"/>
        <KeyBinding Key="OemPlus" Modifiers="Control" Command="{x:Static views:MainWindow.ZoomInCommand}"/>
        <KeyBinding Key="OemMinus" Modifiers="Control" Command="{x:Static views:MainWindow.ZoomOutCommand}"/>
        <KeyBinding Key="D0" Modifiers="Control" Command="{x:Static views:MainWindow.ZoomResetCommand}"/>
    </Window.InputBindings>

    <!-- Resize hit-test area (nearly transparent background needed for hit-testing) -->
    <Grid Background="#01000000">
    <Border Background="{DynamicResource BgPrimary}"
            BorderBrush="{DynamicResource BorderDefault}"
            BorderThickness="1"
            CornerRadius="8"
            Margin="4"
            ClipToBounds="False">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48" MinHeight="48"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ================================================================ -->
            <!-- A) Header / Custom Title Bar                                      -->
            <!-- ================================================================ -->
            <Border Grid.Row="0" Background="{DynamicResource BgSecondary}"
                    CornerRadius="8,8,0,0"
                    Panel.ZIndex="100"
                    Height="48"
                    MinHeight="48"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left side: Product name, version, plan badge -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                        <TextBlock Text="Insight Training Studio" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrandPrimary}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="VersionLabel" Text="v1.0.0" FontSize="11"
                                   Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        <Border x:Name="PlanBadge" Background="{DynamicResource BrandLight}"
                                CornerRadius="4" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="PlanBadgeText" Text="{Binding PlanDisplayName}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrandPrimary}"/>
                        </Border>
                        <TextBlock Text="{DynamicResource App.Subtitle}" FontSize="11"
                                   Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>

                    <!-- Right side: window controls -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Detail mode toggle -->
                        <ToggleButton x:Name="DetailToggleButton"
                                      IsChecked="{Binding IsDetailMode, Mode=OneWay}"
                                      Click="DetailToggleButton_Click"
                                      ToolTip="{DynamicResource UI.DetailMode.Tooltip}"
                                      VerticalAlignment="Center" Margin="4,0">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="{TemplateBinding Background}" Padding="6,3" CornerRadius="3">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock x:Name="Label" Text="{DynamicResource UI.SimpleMode}"
                                                                   FontSize="11" VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource TextSecondary}"/>
                                                        <Border x:Name="Track" Width="32" Height="16" CornerRadius="8"
                                                                Background="#555" Margin="6,0,0,0" VerticalAlignment="Center">
                                                            <Border x:Name="Thumb" Width="12" Height="12" CornerRadius="6"
                                                                    Background="White" HorizontalAlignment="Left" Margin="2,0,0,0"/>
                                                        </Border>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Label" Property="Text" Value="{DynamicResource UI.DetailMode}"/>
                                                        <Setter TargetName="Track" Property="Background" Value="#B8942F"/>
                                                        <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                                        <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#22FFFFFF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>

                        <Rectangle Width="1" Height="20" Fill="{DynamicResource BorderDefault}" Margin="4,0"/>

                        <!-- Minimize -->
                        <Button x:Name="MinimizeButton" Click="MinimizeButton_Click"
                                Style="{DynamicResource WindowControlButtonStyle}"
                                ToolTip="{DynamicResource Window.Minimize}">
                            <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                        </Button>

                        <!-- Maximize/Restore -->
                        <Button x:Name="MaximizeButton" Click="MaximizeButton_Click"
                                Style="{DynamicResource WindowControlButtonStyle}"
                                ToolTip="{DynamicResource Window.Maximize}">
                            <TextBlock x:Name="MaximizeIcon" Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                        </Button>

                        <!-- Close -->
                        <Button x:Name="CloseButton" Click="CloseButton_Click"
                                Style="{DynamicResource CloseButtonStyle}"
                                ToolTip="{DynamicResource Window.Close}">
                            <TextBlock Text="&#xE106;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

        <!-- ================================================================ -->
        <!-- B) Syncfusion Ribbon with Backstage                               -->
        <!-- ================================================================ -->
        <syncfusion:Ribbon Grid.Row="1" x:Name="MainRibbon"
                           Panel.ZIndex="1"
                           Margin="0"
                           ShowCustomizeRibbon="False"
                           EnableMoreCommands="False"
                           EnableSimplifiedLayoutMode="False"
                           RibbonState="Normal"
                           FontFamily="Yu Gothic UI, Meiryo UI, Segoe UI"
                           FontSize="12"
                           BackStageHeader="{DynamicResource Ribbon.File}"
                           BackStageColor="{DynamicResource BrandPrimary}">

            <!-- Backstage (File Menu) -->
            <syncfusion:Ribbon.BackStage>
                <syncfusion:Backstage x:Name="BackStageControl">
                    <syncfusion:BackStageCommandButton Header="{DynamicResource Backstage.New}" Click="BackStageNew_Click"/>
                    <syncfusion:BackStageCommandButton Header="{DynamicResource Backstage.Open}" Click="BackStageOpen_Click"/>
                    <syncfusion:BackStageCommandButton Header="{DynamicResource Backstage.Save}" Click="BackStageSave_Click"/>
                    <syncfusion:BackStageCommandButton Header="{DynamicResource Backstage.SaveAs}" Click="BackStageSaveAs_Click"/>
                    <syncfusion:BackStageSeparator/>
                    <syncfusion:BackstageTabItem Header="{DynamicResource Backstage.Recent}" IsSelected="True">
                        <Grid Margin="16,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{DynamicResource Backstage.Recent}" FontSize="18" FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="BackstageRecentFiles">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Click="BackStageRecentFile_Click" Tag="{Binding FullPath}"
                                                    Cursor="Hand" Background="Transparent" BorderThickness="0"
                                                    HorizontalContentAlignment="Stretch" Padding="8,6" Margin="0,2">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#E8E8E8"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding FileName}" FontSize="13" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding FullPath}" FontSize="11"
                                                                   Foreground="#888888" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding LastAccessedDisplay}" FontSize="11"
                                                               Foreground="#888888" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </syncfusion:BackstageTabItem>
                    <syncfusion:BackStageSeparator/>
                    <syncfusion:BackStageCommandButton Header="{DynamicResource Backstage.ImportPptx}" Click="BackStageImportPptx_Click"/>
                    <syncfusion:BackStageSeparator/>
                    <syncfusion:BackstageTabItem Header="{DynamicResource Backstage.Language}">
                        <Grid Margin="16,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{DynamicResource Backstage.Language}" FontSize="18" FontWeight="SemiBold"
                                       Margin="0,0,0,16"/>
                            <StackPanel Grid.Row="1">
                                <RadioButton x:Name="LangJaRadio" Content="日本語" GroupName="Language"
                                             Checked="BackStageLanguageRadio_Checked" Tag="ja"
                                             FontSize="14" Margin="0,0,0,12"/>
                                <RadioButton x:Name="LangEnRadio" Content="English" GroupName="Language"
                                             Checked="BackStageLanguageRadio_Checked" Tag="en"
                                             FontSize="14"/>
                            </StackPanel>
                        </Grid>
                    </syncfusion:BackstageTabItem>
                    <syncfusion:BackStageSeparator/>
                    <syncfusion:BackstageTabItem Header="{DynamicResource Backstage.Narrator}">
                        <Grid Margin="16,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{DynamicResource Backstage.Narrator}" FontSize="18" FontWeight="SemiBold"
                                       Margin="0,0,0,16"/>
                            <StackPanel Grid.Row="1">
                                <RadioButton x:Name="TtsEdgeRadio" GroupName="TtsEngine"
                                             Checked="BackStageTtsRadio_Checked" Tag="EdgeNeural"
                                             FontSize="14" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource TTS.Edge.Name}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{DynamicResource TTS.Edge.Desc}" FontSize="11" Foreground="#666" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton x:Name="TtsVoiceVoxRadio" GroupName="TtsEngine"
                                             Checked="BackStageTtsRadio_Checked" Tag="VoiceVox"
                                             FontSize="14" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource TTS.VoiceVox.Name}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{DynamicResource TTS.VoiceVox.Desc}" FontSize="11" Foreground="#666" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton x:Name="TtsWindowsRadio" GroupName="TtsEngine"
                                             Checked="BackStageTtsRadio_Checked" Tag="WindowsOneCore"
                                             FontSize="14" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource TTS.Windows.Name}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{DynamicResource TTS.Windows.Desc}" FontSize="11" Foreground="#666" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </RadioButton>
                            </StackPanel>
                            <!-- 制約事項 -->
                            <Border Grid.Row="2" Background="#FFF8F0" BorderBrush="#E0D0B0" BorderThickness="1" CornerRadius="4" Padding="12,8" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource TTS.Constraints}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBlock x:Name="TtsConstraintsText" FontSize="12" Foreground="#555" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </syncfusion:BackstageTabItem>
                    <syncfusion:BackStageSeparator/>
                    <syncfusion:BackStageCommandButton Header="{DynamicResource Quick.WindowTitle}" Click="BackStageQuickMode_Click"/>
                    <syncfusion:BackStageSeparator/>
                    <syncfusion:BackStageCommandButton Header="{DynamicResource Backstage.License}" Click="BackStageLicense_Click"/>
                    <syncfusion:BackStageSeparator/>
                    <syncfusion:BackStageCommandButton Header="{DynamicResource Common.Close}" Click="BackStageExit_Click"/>
                </syncfusion:Backstage>
            </syncfusion:Ribbon.BackStage>

            <!-- Home Tab — タブに応じてグループの表示/非表示を切り替え -->
            <syncfusion:RibbonTab Caption="{DynamicResource Ribbon.Tab.Home}">

                <!-- 共通: ファイルグループ -->
                <syncfusion:RibbonBar Header="{DynamicResource Ribbon.Group.File}" IsLauncherButtonVisible="False">
                    <syncfusion:RibbonButton Label="{DynamicResource Ribbon.File.New}"
                            ToolTip="{DynamicResource Ribbon.File.New}"
                            Command="{Binding NewProjectCommand}" SizeForm="Small">
                        <syncfusion:RibbonButton.IconTemplate>
                            <DataTemplate><TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate>
                        </syncfusion:RibbonButton.IconTemplate>
                    </syncfusion:RibbonButton>
                    <syncfusion:RibbonButton Label="{DynamicResource Ribbon.File.Open}"
                            ToolTip="{DynamicResource Ribbon.File.Open}"
                            Command="{Binding OpenProjectCommand}" SizeForm="Small">
                        <syncfusion:RibbonButton.IconTemplate>
                            <DataTemplate><TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate>
                        </syncfusion:RibbonButton.IconTemplate>
                    </syncfusion:RibbonButton>
                    <syncfusion:RibbonButton Label="{DynamicResource Ribbon.File.Save}"
                            ToolTip="{DynamicResource Ribbon.File.Save}"
                            Command="{Binding SaveProjectCommand}" SizeForm="Small">
                        <syncfusion:RibbonButton.IconTemplate>
                            <DataTemplate><TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate>
                        </syncfusion:RibbonButton.IconTemplate>
                    </syncfusion:RibbonButton>
                    <syncfusion:RibbonButton Label="{DynamicResource Ribbon.File.SaveAs}"
                            ToolTip="{DynamicResource Ribbon.File.SaveAs}"
                            Command="{Binding SaveProjectAsCommand}" SizeForm="Small">
                        <syncfusion:RibbonButton.IconTemplate>
                            <DataTemplate><TextBlock Text="&#xE792;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate>
                        </syncfusion:RibbonButton.IconTemplate>
                    </syncfusion:RibbonButton>
                </syncfusion:RibbonBar>

                <!-- ═══ PPTX作成タブ専用 ═══ -->

                <!-- PPTX: 参考資料 -->
                <syncfusion:RibbonBar x:Name="RibbonPptxReference" Header="{DynamicResource Ribbon.Group.Reference}" IsLauncherButtonVisible="False"
                                      Visibility="Collapsed">
                    <syncfusion:RibbonButton Label="{DynamicResource Ribbon.Ref.AddFile}"
                            ToolTip="{DynamicResource Ribbon.Ref.AddFile}"
                            Click="RibbonRefAddFile_Click" SizeForm="Small">
                        <syncfusion:RibbonButton.IconTemplate>
                            <DataTemplate><TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate>
                        </syncfusion:RibbonButton.IconTemplate>
                    </syncfusion:RibbonButton>
                    <syncfusion:RibbonButton Label="{DynamicResource Ribbon.Ref.AddFolder}"
                            ToolTip="{DynamicResource Ribbon.Ref.AddFolder}"
                            Click="RibbonRefAddFolder_Click" SizeForm="Small">
                        <syncfusion:RibbonButton.IconTemplate>
                            <DataTemplate><TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate>
                        </syncfusion:RibbonButton.IconTemplate>
                    </syncfusion:RibbonButton>
                    <syncfusion:RibbonButton Label="{DynamicResource Ribbon.Ref.ClearAll}"
                            ToolTip="{DynamicResource Ribbon.Ref.ClearAll}"
                            Click="RibbonRefClearAll_Click" SizeForm="Small">
                        <syncfusion:RibbonButton.IconTemplate>
                            <DataTemplate><TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate>
                        </syncfusion:RibbonButton.IconTemplate>
                    </syncfusion:RibbonButton>
                </syncfusion:RibbonBar>

                <!-- PPTX: ヘルプ -->
                <syncfusion:RibbonBar x:Name="RibbonPptxHelp" Header="{DynamicResource Ribbon.Group.Help}" IsLauncherButtonVisible="False"
                                      Visibility="Collapsed">
                    <syncfusion:RibbonButton Label="{DynamicResource Ribbon.Help.Help}"
                            ToolTip="{DynamicResource Ribbon.Help.Help}"
                            Click="RibbonHelp_Click" SizeForm="Large">
                        <syncfusion:RibbonButton.IconTemplate>
                            <DataTemplate><TextBlock Text="&#xE897;" FontFamily="Segoe MDL2 Assets" FontSize="20"/></DataTemplate>
                        </syncfusion:RibbonButton.IconTemplate>
                    </syncfusion:RibbonButton>
                </syncfusion:RibbonBar>

                <!-- ═══ 動画生成タブ専用 ═══ -->

                <!-- 動画: シーン操作 -->
                <syncfusion:RibbonBar x:Name="RibbonVideoScene" Header="{DynamicResource Ribbon.Group.Structure}" IsLauncherButtonVisible="False"
                                      Visibility="Collapsed">
                    <syncfusion:RibbonButton Label="{DynamicResource Ribbon.Scene.Add}"
                            ToolTip="{DynamicResource Ribbon.Scene.Add.Tooltip}"
                            Command="{Binding AddSceneCommand}" SizeForm="Small">
                        <syncfusion:RibbonButton.IconTemplate>
                            <DataTemplate><TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate>
                        </syncfusion:RibbonButton.IconTemplate>
                    </syncfusion:RibbonButton>
                    <syncfusion:RibbonButton Label="{DynamicResource Ribbon.Scene.Remove}"
                            ToolTip="{DynamicResource Ribbon.Scene.Remove.Tooltip}"
                            Command="{Binding RemoveSceneCommand}" SizeForm="Small">
                        <syncfusion:RibbonButton.IconTemplate>
                            <DataTemplate><TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate>
                        </syncfusion:RibbonButton.IconTemplate>
                    </syncfusion:RibbonButton>
                    <syncfusion:RibbonButton Label="{DynamicResource Ribbon.Scene.MoveUp}"
                            ToolTip="{DynamicResource Ribbon.Scene.MoveUp.Tooltip}"
                            Command="{Binding MoveSceneUpCommand}" SizeForm="Small">
                        <syncfusion:RibbonButton.IconTemplate>
                            <DataTemplate><TextBlock Text="&#xE74A;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate>
                        </syncfusion:RibbonButton.IconTemplate>
                    </syncfusion:RibbonButton>
                    <syncfusion:RibbonButton Label="{DynamicResource Ribbon.Scene.MoveDown}"
                            ToolTip="{DynamicResource Ribbon.Scene.MoveDown.Tooltip}"
                            Command="{Binding MoveSceneDownCommand}" SizeForm="Small">
                        <syncfusion:RibbonButton.IconTemplate>
                            <DataTemplate><TextBlock Text="&#xE74B;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate>
                        </syncfusion:RibbonButton.IconTemplate>
                    </syncfusion:RibbonButton>
                    <syncfusion:RibbonButton Label="{DynamicResource Ribbon.Scene.Record}"
                            ToolTip="{DynamicResource Ribbon.Scene.Record.Tooltip}"
                            Command="{Binding ScreenRecordCommand}" SizeForm="Small">
                        <syncfusion:RibbonButton.IconTemplate>
                            <DataTemplate><TextBlock Text="&#xE714;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#DD4444"/></DataTemplate>
                        </syncfusion:RibbonButton.IconTemplate>
                    </syncfusion:RibbonButton>
                    <syncfusion:RibbonButton Label="{DynamicResource Ribbon.Scene.ImageCapture}"
                            ToolTip="{DynamicResource Tool.ScreenCapture.Tooltip}"
                            Command="{Binding ScreenCaptureCommand}" SizeForm="Small">
                        <syncfusion:RibbonButton.IconTemplate>
                            <DataTemplate><TextBlock Text="&#xE7AC;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate>
                        </syncfusion:RibbonButton.IconTemplate>
                    </syncfusion:RibbonButton>
                </syncfusion:RibbonBar>

                <!-- 動画: 制作 -->
                <syncfusion:RibbonBar x:Name="RibbonVideoProduction" Header="{DynamicResource Ribbon.Group.Production}" IsLauncherButtonVisible="False"
                                      Visibility="Collapsed">
                    <syncfusion:RibbonButton Label="{DynamicResource Quick.WindowTitle}"
                            ToolTip="{DynamicResource Quick.Tagline}"
                            Click="BackStageQuickMode_Click" SizeForm="Large">
                        <syncfusion:RibbonButton.IconTemplate>
                            <DataTemplate><TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="24" Foreground="#B8942F"/></DataTemplate>
                        </syncfusion:RibbonButton.IconTemplate>
                    </syncfusion:RibbonButton>
                    <syncfusion:RibbonButton Label="{DynamicResource Ribbon.File.ImportPptx}"
                            ToolTip="{DynamicResource Ribbon.File.ImportPptx}"
                            Command="{Binding ImportPptxCommand}" SizeForm="Small">
                        <syncfusion:RibbonButton.IconTemplate>
                            <DataTemplate><TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource AccentGold}"/></DataTemplate>
                        </syncfusion:RibbonButton.IconTemplate>
                    </syncfusion:RibbonButton>
                    <syncfusion:RibbonButton Label="{DynamicResource Ribbon.Script.Clear}"
                            ToolTip="{DynamicResource Ribbon.Script.Clear.Tooltip}"
                            Command="{Binding ClearAllScriptsCommand}" SizeForm="Small">
                        <syncfusion:RibbonButton.IconTemplate>
                            <DataTemplate><TextBlock Text="&#xE894;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#CC0000"/></DataTemplate>
                        </syncfusion:RibbonButton.IconTemplate>
                    </syncfusion:RibbonButton>
                    <syncfusion:RibbonButton Label="{DynamicResource Ribbon.Subtitle.Clear}"
                            ToolTip="{DynamicResource Ribbon.Subtitle.Clear.Tooltip}"
                            Command="{Binding ClearAllSubtitlesCommand}" SizeForm="Small">
                        <syncfusion:RibbonButton.IconTemplate>
                            <DataTemplate><TextBlock Text="&#xED62;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#CC0000"/></DataTemplate>
                        </syncfusion:RibbonButton.IconTemplate>
                    </syncfusion:RibbonButton>
                </syncfusion:RibbonBar>

                <!-- 動画: 書き出し -->
                <syncfusion:RibbonBar x:Name="RibbonVideoExport" Header="{DynamicResource Ribbon.Group.Export}" IsLauncherButtonVisible="False"
                                      Visibility="Collapsed">
                    <syncfusion:RibbonButton Label="{DynamicResource Ribbon.Export.Video}"
                            ToolTip="{DynamicResource Ribbon.Export.Video.Tooltip}"
                            Command="{Binding ExportVideoCommand}" SizeForm="Small">
                        <syncfusion:RibbonButton.IconTemplate>
                            <DataTemplate><TextBlock Text="&#xE714;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate>
                        </syncfusion:RibbonButton.IconTemplate>
                    </syncfusion:RibbonButton>
                    <syncfusion:RibbonButton Label="{DynamicResource Ribbon.Template.OpenOutput}"
                            ToolTip="{DynamicResource Ribbon.Template.OpenOutput.Tooltip}"
                            Command="{Binding OpenOutputFolderCommand}" SizeForm="Small">
                        <syncfusion:RibbonButton.IconTemplate>
                            <DataTemplate><TextBlock Text="&#xE8DA;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate>
                        </syncfusion:RibbonButton.IconTemplate>
                    </syncfusion:RibbonButton>
                </syncfusion:RibbonBar>

                <!-- 動画: テンプレート -->
                <syncfusion:RibbonBar x:Name="RibbonVideoTemplate" Header="{DynamicResource Ribbon.Group.Template}" IsLauncherButtonVisible="False"
                                      Visibility="Collapsed">
                    <syncfusion:RibbonButton Label="{DynamicResource Ribbon.Template.Save}"
                            ToolTip="{DynamicResource Ribbon.Template.Save.Tooltip}"
                            Command="{Binding SaveTemplateCommand}" SizeForm="Small">
                        <syncfusion:RibbonButton.IconTemplate>
                            <DataTemplate><TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate>
                        </syncfusion:RibbonButton.IconTemplate>
                    </syncfusion:RibbonButton>
                    <syncfusion:RibbonButton Label="{DynamicResource Ribbon.Template.Load}"
                            ToolTip="{DynamicResource Ribbon.Template.Load.Tooltip}"
                            Command="{Binding LoadTemplateCommand}" SizeForm="Small">
                        <syncfusion:RibbonButton.IconTemplate>
                            <DataTemplate><TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate>
                        </syncfusion:RibbonButton.IconTemplate>
                    </syncfusion:RibbonButton>
                </syncfusion:RibbonBar>
            </syncfusion:RibbonTab>
        </syncfusion:Ribbon>

        <!-- ================================================================ -->
        <!-- C) Main Content - TabControl                                      -->
        <!-- ================================================================ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

        <TabControl Grid.Column="0" Margin="4,4,4,2" x:Name="MainTabControl"
                    SelectionChanged="MainTabControl_SelectionChanged">
            <!-- 企画・制作タブ -->
            <TabItem Header="{DynamicResource Tab.Planning}">
                <views:PlanningTab x:Name="PlanningTabControl"/>
            </TabItem>

            <!-- 動画生成タブ -->
            <TabItem Header="{DynamicResource Tab.VideoGeneration}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- シーン編集エリア -->
                    <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="160" MaxWidth="320"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Scene List (Card style) -->
            <Border Grid.Column="0" Background="{DynamicResource BgCard}"
                    BorderBrush="{DynamicResource BorderLight}" BorderThickness="1"
                    CornerRadius="6" Margin="0,0,0,0" Padding="0">
                <DockPanel>
                    <!-- Header -->
                    <Border DockPanel.Dock="Top" Padding="10,8"
                            BorderBrush="{DynamicResource BorderLight}" BorderThickness="0,0,0,1">
                        <TextBlock Text="{DynamicResource Scene.List}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                    </Border>

                    <!-- Settings compact bar -->
                    <Border DockPanel.Dock="Top" Background="{DynamicResource BgSecondary}"
                            Padding="8,6" BorderBrush="{DynamicResource BorderLight}" BorderThickness="0,0,0,1"
                            MaxHeight="220">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Export.Resolution}" FontSize="10"
                                       Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,3"/>
                            <ComboBox SelectedIndex="{Binding SelectedResolutionIndex}" FontSize="11"
                                     ToolTip="{DynamicResource Export.Resolution.Tooltip}">
                                <ComboBoxItem Content="{DynamicResource Resolution.Landscape}" Tag="1920x1080"/>
                                <ComboBoxItem Content="{DynamicResource Resolution.Portrait}" Tag="1080x1920"/>
                                <ComboBoxItem Content="{DynamicResource Resolution.Square}" Tag="1080x1080"/>
                                <ComboBoxItem Content="{DynamicResource Resolution.Shorts}" Tag="1080x1920"/>
                                <ComboBoxItem Content="{DynamicResource Resolution.Reels}" Tag="1080x1920"/>
                                <ComboBoxItem Content="{DynamicResource Resolution.TikTok}" Tag="1080x1920"/>
                            </ComboBox>
                            <TextBlock Text="{DynamicResource Export.DefaultSpeaker}" FontSize="10"
                                       Foreground="{DynamicResource TextTertiary}" Margin="0,6,0,3"/>
                            <ComboBox ItemsSource="{Binding ExportSpeakers}"
                                      SelectedIndex="{Binding SelectedExportSpeakerIndex}"
                                      FontSize="11"
                                      ToolTip="{DynamicResource Export.DefaultSpeaker.Tooltip}"/>
                            <TextBlock Text="{DynamicResource Export.DefaultSubtitleSize}" FontSize="10"
                                       Foreground="{DynamicResource TextTertiary}" Margin="0,6,0,3"/>
                            <ComboBox x:Name="DefaultSubtitleSizeCombo" FontSize="11" MinWidth="80"
                                      SelectionChanged="DefaultSubtitleSizeCombo_SelectionChanged"
                                      ToolTip="{DynamicResource Export.DefaultSubtitleSize.Tooltip}"/>
                            <CheckBox x:Name="LetterboxCheckBox" Content="{DynamicResource Export.SubtitleLetterbox}"
                                      FontSize="10" Margin="0,6,0,0"
                                      IsChecked="{Binding SubtitleLetterbox}"
                                      ToolTip="{DynamicResource Export.SubtitleLetterbox.Tooltip}"/>
                            <CheckBox Content="{DynamicResource Export.GenerateSubtitleFile}"
                                      FontSize="10" Margin="0,4,0,0"
                                      IsChecked="{Binding GenerateSubtitleFile}"/>
                            <CheckBox Content="{DynamicResource Export.GenerateMetadata}"
                                      FontSize="10" Margin="0,4,0,0"
                                      IsChecked="{Binding GenerateMetadata}"/>
                        </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- Scene action buttons -->
                    <Border DockPanel.Dock="Bottom" Padding="6,4"
                            BorderBrush="{DynamicResource BorderLight}" BorderThickness="0,1,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="{DynamicResource Common.Add}" Padding="8,3" Margin="2"
                                    Style="{DynamicResource SecondaryButton}" FontSize="11"
                                    Command="{Binding AddSceneCommand}"/>
                            <Button Content="{DynamicResource Common.Remove}" Padding="8,3" Margin="2"
                                    Style="{DynamicResource SecondaryButton}" FontSize="11"
                                    Command="{Binding RemoveSceneCommand}"/>
                            <Button Content="↑" Padding="8,3" Margin="2"
                                    Style="{DynamicResource SecondaryButton}" FontSize="11"
                                    Command="{Binding MoveSceneUpCommand}"/>
                            <Button Content="↓" Padding="8,3" Margin="2"
                                    Style="{DynamicResource SecondaryButton}" FontSize="11"
                                    Command="{Binding MoveSceneDownCommand}"/>
                        </StackPanel>
                    </Border>

                    <!-- Scene list -->
                    <ListBox x:Name="SceneListBox"
                             ItemsSource="{Binding SceneItems}"
                             SelectedIndex="{Binding SelectedSceneIndex}"
                             HorizontalContentAlignment="Stretch"
                             Background="Transparent" BorderThickness="0"
                             Padding="4,2">
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{DynamicResource Ribbon.Scene.Remove}"
                                          Command="{Binding RemoveSceneCommand}"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2,3">
                                    <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis"
                                               FontSize="11" Margin="0,0,0,3"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Border CornerRadius="3" Padding="5,2" Margin="0,0,3,0" MinWidth="32">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource BorderLight}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StepMediaDone}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource Success}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{DynamicResource Progress.Media}" FontSize="10" HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextTertiary}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StepMediaDone}" Value="True">
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                        <TextBlock Text="›" VerticalAlignment="Center" Foreground="{DynamicResource TextTertiary}" Margin="0,0,3,0" FontSize="11"/>
                                        <Border CornerRadius="3" Padding="5,2" Margin="0,0,3,0" MinWidth="32">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource BorderLight}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StepNarrationDone}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource Success}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{DynamicResource Progress.Narration}" FontSize="10" HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextTertiary}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StepNarrationDone}" Value="True">
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                        <TextBlock Text="›" VerticalAlignment="Center" Foreground="{DynamicResource TextTertiary}" Margin="0,0,3,0" FontSize="11"/>
                                        <Border CornerRadius="3" Padding="5,2" MinWidth="32">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource BorderLight}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StepSubtitleDone}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource Success}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{DynamicResource Progress.Subtitle}" FontSize="10" HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextTertiary}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StepSubtitleDone}" Value="True">
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Splitter (thin, subtle) -->
            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center"
                          Background="Transparent" Margin="0,8">
                <GridSplitter.Template>
                    <ControlTemplate TargetType="GridSplitter">
                        <Border Background="Transparent" Width="6">
                            <Border Width="2" Background="{DynamicResource BorderLight}"
                                    CornerRadius="1" VerticalAlignment="Stretch" HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </GridSplitter.Template>
            </GridSplitter>

            <!-- Right Panel: Scene Editor (Card style) -->
            <Border Grid.Column="2" Background="{DynamicResource BgCard}"
                    BorderBrush="{DynamicResource BorderLight}" BorderThickness="1"
                    CornerRadius="6" Padding="0">
                <DockPanel>
                    <!-- Header with progress steps -->
                    <Border DockPanel.Dock="Top" Padding="12,8"
                            BorderBrush="{DynamicResource BorderLight}" BorderThickness="0,0,0,1">
                        <DockPanel DataContext="{Binding CurrentSceneItem}">
                            <TextBlock Text="{DynamicResource Scene.Editor}" VerticalAlignment="Center"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,16,0"
                                       DockPanel.Dock="Left"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Media step -->
                                <Border CornerRadius="4" Padding="10,4" Margin="0,0,4,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource BorderLight}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StepMediaDone}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource Success}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{DynamicResource Progress.Media}" FontSize="11" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextTertiary}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StepMediaDone}" Value="True">
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                                <TextBlock Text="›" VerticalAlignment="Center" Foreground="{DynamicResource TextTertiary}" Margin="2,0,6,0" FontSize="13"/>
                                <!-- Narration step -->
                                <Border CornerRadius="4" Padding="10,4" Margin="0,0,4,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource BorderLight}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StepNarrationDone}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource Success}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{DynamicResource Progress.Narration}" FontSize="11" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextTertiary}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StepNarrationDone}" Value="True">
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                                <TextBlock Text="›" VerticalAlignment="Center" Foreground="{DynamicResource TextTertiary}" Margin="2,0,6,0" FontSize="13"/>
                                <!-- Subtitle step -->
                                <Border CornerRadius="4" Padding="10,4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource BorderLight}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StepSubtitleDone}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource Success}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{DynamicResource Progress.Subtitle}" FontSize="11" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextTertiary}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StepSubtitleDone}" Value="True">
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Editor content -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  Padding="0">
                    <StackPanel Margin="12,10">

                        <!-- Media info -->
                        <DockPanel Margin="0,0,0,8">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Content="{DynamicResource Overlay.Dialog.Button}" Padding="10,4" Margin="3,0"
                                        Style="{DynamicResource SecondaryButton}" FontSize="11"
                                        ToolTip="{DynamicResource Overlay.Dialog.Button.Tooltip}"
                                        Click="TextOverlayButton_Click"/>
                                <Button Content="{DynamicResource Tool.ScreenRecord}" Padding="10,4" Margin="3,0"
                                        Style="{DynamicResource SecondaryButton}" FontSize="11"
                                        ToolTip="{DynamicResource Ribbon.Scene.Record.Tooltip}"
                                        Command="{Binding ScreenRecordCommand}"/>
                                <Button Content="{DynamicResource Tool.ImageCapture}" Padding="10,4" Margin="3,0"
                                        Style="{DynamicResource SecondaryButton}" FontSize="11"
                                        ToolTip="{DynamicResource Tool.ScreenCapture.Tooltip}"
                                        Command="{Binding ScreenCaptureCommand}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource Scene.Media}" VerticalAlignment="Center"
                                           FontSize="11" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding MediaName}" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                           MinWidth="100" Margin="0,0,8,0"/>
                                <Button Content="{DynamicResource Common.Select}" Padding="10,4" Margin="3,0"
                                        Style="{DynamicResource SecondaryButton}" FontSize="11"
                                        Command="{Binding SelectMediaCommand}"
                                        ToolTip="{DynamicResource Scene.Media.Select.Tooltip}"/>
                                <Button Content="{DynamicResource Common.Clear}" Padding="10,4" Margin="3,0"
                                        Style="{DynamicResource SecondaryButton}" FontSize="11"
                                        Command="{Binding ClearMediaCommand}"
                                        ToolTip="{DynamicResource Scene.Media.Clear.Tooltip}"/>
                            </StackPanel>
                        </DockPanel>

                        <!-- Preview + Narration -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="128" Height="192"
                                    Background="#1a1a2e" CornerRadius="6" Margin="0,0,12,0" ClipToBounds="True"
                                    Cursor="Hand" MouseLeftButtonUp="PreviewImage_Click"
                                    ToolTip="{DynamicResource Preview.ClickToEnlarge}">
                                <Grid>
                                    <Image x:Name="PreviewImage" Stretch="Uniform"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <!-- Text overlay preview layer -->
                                    <ItemsControl ItemsSource="{Binding OverlayPreviewItems}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><Canvas/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding CanvasLeft}"/>
                                                <Setter Property="Canvas.Top" Value="{Binding CanvasTop}"/>
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Text}" FontSize="{Binding PreviewFontSize}"
                                                           FontWeight="{Binding FontWeightValue}" Opacity="{Binding Opacity}"
                                                           MaxWidth="120" TextWrapping="Wrap" TextAlignment="{Binding TextAlignmentValue}">
                                                    <TextBlock.Foreground><SolidColorBrush Color="{Binding TextColorValue}"/></TextBlock.Foreground>
                                                    <TextBlock.Effect><DropShadowEffect ShadowDepth="1" BlurRadius="2" Color="Black" Opacity="0.8"/></TextBlock.Effect>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <!-- Subtitle overlay -->
                                    <Border VerticalAlignment="Bottom" Background="#80000000" Padding="4,2"
                                            CornerRadius="0,0,6,6">
                                        <TextBlock Text="{Binding SubtitleText}" Foreground="White"
                                                   FontSize="9" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="120"/>
                                    </Border>
                                    <!-- Zoom icon -->
                                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Background="#80000000" CornerRadius="0,6,0,4" Padding="4">
                                        <Path Data="M9,0 A9,9 0 1 0 9,18 A9,9 0 1 0 9,0 M15,15 L20,20"
                                              Stroke="White" StrokeThickness="1.5" Width="16" Height="16"
                                              Stretch="Uniform"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <Grid Grid.Column="1">
                                <Border BorderBrush="{DynamicResource BorderLight}" BorderThickness="1"
                                        CornerRadius="4" Background="{DynamicResource BgInput}">
                                    <TextBox x:Name="NarrationTextBox"
                                             Text="{Binding NarrationText, UpdateSourceTrigger=PropertyChanged}"
                                             TextWrapping="Wrap" AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto" MinHeight="150"
                                             VerticalContentAlignment="Top" Padding="8,6"
                                             FontSize="12" BorderThickness="0" Background="Transparent"/>
                                </Border>
                                <TextBlock Text="{DynamicResource Scene.Narration.Placeholder}"
                                           Foreground="{DynamicResource TextPlaceholder}" FontStyle="Italic"
                                           IsHitTestVisible="False" Margin="12,10,0,0" VerticalAlignment="Top"
                                           FontSize="12"
                                           Visibility="{Binding NarrationPlaceholderVisible, Converter={StaticResource BoolToVis}}"
                                           ToolTip="{DynamicResource Scene.Narration.Tooltip}"/>
                            </Grid>
                        </Grid>

                        <!-- Speaker + Audio controls -->
                        <Border Background="{DynamicResource BgSecondary}" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                            <StackPanel>
                                <WrapPanel Margin="0,0,0,4">
                                    <TextBlock Text="{DynamicResource Scene.Speaker}" VerticalAlignment="Center"
                                               FontSize="11" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                    <ComboBox MinWidth="180" Margin="0,0,16,0"
                                              ItemsSource="{Binding SceneSpeakers}"
                                              SelectedIndex="{Binding SelectedSceneSpeakerIndex}"
                                              DisplayMemberPath="DisplayName" FontSize="11"
                                              ToolTip="{DynamicResource Scene.Speaker.Tooltip}"/>
                                    <CheckBox Content="{DynamicResource Scene.KeepAudio}"
                                              IsChecked="{Binding KeepOriginalAudio}"
                                              VerticalAlignment="Center" Margin="0,0,16,0" FontSize="11"
                                              ToolTip="{DynamicResource Scene.KeepAudio.Tooltip}"/>
                                    <Button Content="{DynamicResource Scene.PreviewAudio}" Padding="10,4" Margin="3,0"
                                            Style="{DynamicResource SecondaryButton}" FontSize="11"
                                            Command="{Binding PreviewAudioCommand}"
                                            ToolTip="{DynamicResource Scene.PreviewAudio.Tooltip}"
                                            AutomationProperties.Name="Preview Audio"/>
                                    <Button Content="{DynamicResource Scene.PreviewScene}" Padding="10,4" Margin="3,0"
                                            Style="{DynamicResource SecondaryButton}" FontSize="11"
                                            Command="{Binding PreviewSceneCommand}"
                                            ToolTip="{DynamicResource Scene.PreviewScene.Tooltip}"
                                            AutomationProperties.Name="Preview Scene"/>
                                    <Button Content="{DynamicResource Scene.Stop}" Padding="10,4" Margin="3,0"
                                            Style="{DynamicResource SecondaryButton}" FontSize="11"
                                            Command="{Binding StopPreviewCommand}"
                                            ToolTip="{DynamicResource Scene.Stop.Tooltip}"/>
                                </WrapPanel>
                                <WrapPanel>
                                    <TextBlock Text="{DynamicResource Scene.SpeechSpeed}" VerticalAlignment="Center"
                                               FontSize="11" Margin="0,0,6,0"/>
                                    <ComboBox Width="90" ItemsSource="{Binding SpeechSpeedOptions}"
                                              SelectedIndex="{Binding SelectedSpeechSpeedIndex}" FontSize="11"
                                              ToolTip="{DynamicResource Scene.SpeechSpeed.Tooltip}"/>
                                    <TextBlock Text="{DynamicResource Scene.SubtitleSize}" VerticalAlignment="Center"
                                               FontSize="11" Margin="16,0,6,0"/>
                                    <ComboBox x:Name="SubtitleSizeCombo" Width="120" FontSize="11"
                                              IsEnabled="{Binding CanSubtitle}"
                                              SelectionChanged="SubtitleSizeCombo_SelectionChanged"
                                              ToolTip="{DynamicResource Scene.SubtitleSize.Tooltip}"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- Subtitle -->
                        <StackPanel Margin="0,0,0,8">
                            <DockPanel Margin="0,0,0,4">
                                <TextBlock Text="{DynamicResource Scene.Subtitle}" VerticalAlignment="Center"
                                           FontSize="11" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                                <Button Content="{DynamicResource Scene.CopyNarration}" Padding="10,3" Margin="8,0,0,0"
                                        Style="{DynamicResource SecondaryButton}" FontSize="10"
                                        DockPanel.Dock="Right" HorizontalAlignment="Right"
                                        Command="{Binding CopyNarrationToSubtitleCommand}"
                                        IsEnabled="{Binding CanSubtitle}"
                                        ToolTip="{DynamicResource Scene.CopyNarration.Tooltip}"/>
                            </DockPanel>
                            <Grid>
                                <Border BorderBrush="{DynamicResource BorderLight}" BorderThickness="1"
                                        CornerRadius="4" Background="{DynamicResource BgInput}">
                                    <TextBox Text="{Binding SubtitleText, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="8,6" MinHeight="50" MaxHeight="100"
                                             TextWrapping="Wrap" AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             VerticalContentAlignment="Top" FontSize="12"
                                             BorderThickness="0" Background="Transparent"
                                             IsEnabled="{Binding CanSubtitle}"
                                             ToolTip="{DynamicResource Scene.Subtitle.Tooltip}"/>
                                </Border>
                                <TextBlock Text="{Binding SubtitlePlaceholder}"
                                           Foreground="{DynamicResource TextPlaceholder}" FontStyle="Italic"
                                           IsHitTestVisible="False" Margin="12,10,0,0" VerticalAlignment="Top"
                                           FontSize="12"
                                           Visibility="{Binding SubtitlePlaceholderVisible, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </StackPanel>

                        <!-- Detail mode only sections -->
                        <!-- Subtitle style -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6"
                                    Visibility="{Binding IsDetailMode, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{DynamicResource Scene.SubtitleStyle}" VerticalAlignment="Center"
                                       FontSize="11" Margin="0,0,8,0"/>
                            <Border BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1"
                                    CornerRadius="4" Padding="8,2" Margin="0,0,8,0" Background="#1a1a2e" MinWidth="40">
                                <TextBlock x:Name="StylePreviewLabel" Text="A" FontSize="16" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Center"/>
                            </Border>
                            <Button Content="{DynamicResource Scene.SubtitleStyle.Select}" Padding="10,4" Margin="3,0"
                                    Style="{DynamicResource SecondaryButton}" FontSize="11"
                                    Command="{Binding OpenStyleDialogCommand}" IsEnabled="{Binding CanSubtitleStyle}"/>
                        </StackPanel>

                        <!-- Text Overlays: count indicator -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6"
                                    Visibility="{Binding IsDetailMode, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{DynamicResource Overlay.Title}" VerticalAlignment="Center"
                                       FontSize="11" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding OverlayCountDisplay}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                        </StackPanel>

                        <!-- Duration mode -->
                        <StackPanel Margin="0,0,0,6" Visibility="{Binding IsDetailMode, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{DynamicResource Duration.Title}" FontSize="11" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="{DynamicResource Duration.Auto}" IsChecked="{Binding IsAutoDuration}"
                                             VerticalAlignment="Center" Margin="0,0,16,0" GroupName="DurationMode"
                                             FontSize="11"
                                             ToolTip="{DynamicResource Duration.Auto.Tooltip}"/>
                                <RadioButton Content="{DynamicResource Duration.Fixed}" IsChecked="{Binding IsFixedDuration}"
                                             VerticalAlignment="Center" Margin="0,0,8,0" GroupName="DurationMode"
                                             FontSize="11"
                                             ToolTip="{DynamicResource Duration.Fixed.Tooltip}"/>
                                <TextBox Text="{Binding DurationSeconds, UpdateSourceTrigger=PropertyChanged}"
                                         Width="60" TextAlignment="Center" Padding="4,3" FontSize="11"
                                         Margin="0,0,6,0" IsEnabled="{Binding IsFixedDuration}"/>
                                <TextBlock Text="{DynamicResource Duration.Range}" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextTertiary}" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Transition -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6"
                                    Visibility="{Binding IsDetailMode, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{DynamicResource Transition.Title}" VerticalAlignment="Center"
                                       FontSize="11" Margin="0,0,8,0"/>
                            <ComboBox Width="160" Margin="0,0,12,0" FontSize="11"
                                      ItemsSource="{Binding TransitionDisplayNames}"
                                      SelectedIndex="{Binding SelectedTransitionIndex}"
                                      IsEnabled="{Binding CanTransition}"
                                      ToolTip="{DynamicResource Transition.Tooltip}"/>
                            <TextBlock Text="{DynamicResource Transition.Duration}" VerticalAlignment="Center"
                                       FontSize="11" Margin="0,0,6,0"/>
                            <TextBox Text="{Binding TransitionDuration, UpdateSourceTrigger=PropertyChanged}"
                                     Width="60" TextAlignment="Center" Padding="4,3" FontSize="11"
                                     Margin="0,0,6,0" IsEnabled="{Binding CanTransition}"
                                     ToolTip="{DynamicResource Transition.Duration.Tooltip}"/>
                            <TextBlock Text="{DynamicResource Transition.Range}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextTertiary}" FontSize="10"/>
                            <Button Content="{DynamicResource Transition.ApplyAll}" Padding="10,3" Margin="8,0,0,0"
                                    Style="{DynamicResource SecondaryButton}" FontSize="10"
                                    Command="{Binding ApplyTransitionToAllCommand}"
                                    IsEnabled="{Binding CanTransition}"
                                    ToolTip="{DynamicResource Transition.ApplyAll.Tooltip}"/>
                        </StackPanel>

                        <!-- Motion (Ken Burns) -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="{DynamicResource Motion.Title}" VerticalAlignment="Center"
                                       FontSize="11" Margin="0,0,8,0"/>
                            <ComboBox Width="200" FontSize="11"
                                      ItemsSource="{Binding MotionDisplayNames}"
                                      SelectedIndex="{Binding SelectedMotionIndex}"
                                      ToolTip="{DynamicResource Motion.Tooltip}"/>
                        </StackPanel>

                        <!-- Watermark -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6"
                                    Visibility="{Binding IsDetailMode, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{DynamicResource Watermark.Title}" VerticalAlignment="Center"
                                       FontSize="11" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding WatermarkFileName}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                       MinWidth="80" MaxWidth="140" TextTrimming="CharacterEllipsis" Margin="0,0,6,0"/>
                            <Button Content="{DynamicResource Common.Select}" Padding="8,3" Margin="3,0"
                                    Style="{DynamicResource SecondaryButton}" FontSize="11"
                                    Command="{Binding SelectWatermarkCommand}"
                                    ToolTip="{DynamicResource Watermark.Tooltip}"/>
                            <Button Content="✕" Padding="6,3" Margin="3,0"
                                    Style="{DynamicResource SecondaryButton}" FontSize="11"
                                    Command="{Binding ClearWatermarkCommand}"
                                    ToolTip="{DynamicResource Watermark.Clear.Tooltip}"/>
                            <TextBlock Text="{DynamicResource Watermark.Position}" VerticalAlignment="Center"
                                       FontSize="11" Margin="12,0,6,0"/>
                            <ComboBox Width="80" ItemsSource="{Binding WatermarkPositionOptions}"
                                      SelectedIndex="{Binding SelectedWatermarkPosIndex}" FontSize="11"
                                      ToolTip="{DynamicResource Watermark.Position.Tooltip}"/>
                        </StackPanel>

                        <!-- Template -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6"
                                    Visibility="{Binding IsDetailMode, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{DynamicResource Template.Title}" VerticalAlignment="Center"
                                       FontSize="11" Margin="0,0,8,0"/>
                            <Button Content="{DynamicResource Common.Save}" Padding="10,4" Margin="3,0"
                                    Style="{DynamicResource SecondaryButton}" FontSize="11"
                                    Command="{Binding SaveTemplateCommand}"/>
                            <Button Content="{DynamicResource Common.Load}" Padding="10,4" Margin="3,0"
                                    Style="{DynamicResource SecondaryButton}" FontSize="11"
                                    Command="{Binding LoadTemplateCommand}"/>
                            <Button Content="{DynamicResource Template.OpenOutput}" Padding="10,4" Margin="12,0,3,0"
                                    Style="{DynamicResource SecondaryButton}" FontSize="11"
                                    Command="{Binding OpenOutputFolderCommand}"/>
                        </StackPanel>

                        <!-- Info label -->
                        <TextBlock Text="{DynamicResource Duration.Info}"
                                   TextWrapping="Wrap" Foreground="{DynamicResource TextTertiary}"
                                   FontSize="10" Margin="0,4,0,0"/>
                    </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
                    </Grid>

                    <!-- Export Panel (card style) -->
                    <Border Grid.Row="1" Background="{DynamicResource BgCard}"
                            BorderBrush="{DynamicResource BorderLight}" BorderThickness="1"
                            CornerRadius="6" Margin="0,6,0,0" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <WrapPanel Grid.Column="0" VerticalAlignment="Center">
                    <!-- FPS: Detail mode only -->
                    <StackPanel Orientation="Horizontal" Margin="0,2,16,2"
                                Visibility="{Binding IsDetailMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="FPS:" VerticalAlignment="Center" FontSize="11" Margin="0,0,6,0"/>
                        <TextBox Text="{Binding FpsText, UpdateSourceTrigger=PropertyChanged}"
                                 Width="60" TextAlignment="Center" FontSize="11" Padding="6,3"
                                 ToolTip="{DynamicResource Export.FPS.Tooltip}"/>
                    </StackPanel>

                    <!-- BGM: Detail mode only -->
                    <StackPanel Orientation="Horizontal" Margin="0,2,16,2"
                                Visibility="{Binding IsDetailMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding BgmStatusText}" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextTertiary}" FontSize="11" Margin="0,0,8,0"/>
                        <Button Content="{DynamicResource Export.BGM.Settings}" Padding="10,4"
                                Style="{DynamicResource SecondaryButton}" FontSize="11"
                                Command="{Binding BgmSettingsCommand}"/>
                    </StackPanel>
                </WrapPanel>

                <Button Grid.Column="1"
                        Content="{DynamicResource Export.Button}"
                        Width="160" Height="42"
                        FontSize="13" FontWeight="SemiBold"
                        Style="{DynamicResource PrimaryButton}"
                        Command="{Binding ExportVideoCommand}"
                        ToolTip="{DynamicResource Export.Button.Tooltip}"
                        AutomationProperties.Name="Export Video"/>
            </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        </Grid>

        <!-- ================================================================ -->
        <!-- D) ProgressBar                                                    -->
        <!-- ================================================================ -->
        <DockPanel Grid.Row="3" Margin="4,0,4,2"
                   Visibility="{Binding ExportProgressVisible, Converter={StaticResource BoolToVis}}">
            <Button DockPanel.Dock="Right" Content="{DynamicResource Export.Cancel}"
                    Padding="12,2" Margin="4,0,0,0"
                    Command="{Binding CancelExportCommand}"/>
            <ProgressBar Height="6" Minimum="0" Maximum="100"
                         Value="{Binding ExportProgressValue, Mode=OneWay}"/>
        </DockPanel>

        <!-- ================================================================ -->
        <!-- E) Log Area                                                       -->
        <!-- ================================================================ -->
        <DockPanel Grid.Row="4" Height="120" Margin="4,0,4,4">
            <TextBlock Text="{DynamicResource Export.Log}" DockPanel.Dock="Top" FontSize="11"
                       Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
            <TextBox x:Name="LogTextBox" IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap" FontSize="11" FontFamily="Consolas, MS Gothic"
                     Background="{DynamicResource BgSecondary}"/>
        </DockPanel>

            <MediaElement x:Name="AudioPlayer" Grid.Row="4"
                          LoadedBehavior="Manual" UnloadedBehavior="Stop"
                          Visibility="Collapsed" MediaEnded="AudioPlayer_MediaEnded"/>

        <!-- ================================================================ -->
        <!-- F) Status Bar                                                     -->
        <!-- ================================================================ -->
        <Border Grid.Row="5" Background="{DynamicResource BgSecondary}"
                BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,1,0,0"
                Padding="8,4" CornerRadius="0,0,8,8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <Button Content="-" FontSize="11" FontWeight="Bold"
                            Click="ZoomOut_Click" Padding="4,0" MinWidth="0" MinHeight="0"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Foreground="{DynamicResource TextSecondary}"
                            FontFamily="Segoe UI"
                            ToolTip="{DynamicResource UI.ZoomOut}"/>
                    <TextBlock x:Name="ScaleLabel" Text="100%" FontSize="10" Margin="4,0"
                               Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"
                               Cursor="Hand" MouseLeftButtonDown="ScaleLabel_Click"
                               FontFamily="Segoe UI"
                               ToolTip="{DynamicResource UI.ZoomReset}"/>
                    <Button Content="+" FontSize="11" FontWeight="Bold"
                            Click="ZoomIn_Click" Padding="4,0" MinWidth="0" MinHeight="0"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Foreground="{DynamicResource TextSecondary}"
                            FontFamily="Segoe UI"
                            ToolTip="{DynamicResource UI.ZoomIn}"/>
                </StackPanel>
                <TextBlock Text="{Binding StatusText}" FontSize="11"
                           Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

            </Grid>
        </Border>

        <!-- Drop overlay (child of outer Grid, overlays everything) -->
        <Border x:Name="DropOverlay" Visibility="Collapsed"
                Background="#CC1a1a2e" CornerRadius="8" Margin="4"
                IsHitTestVisible="False">
            <Border BorderBrush="#4090FF" BorderThickness="3" CornerRadius="12"
                    Margin="32" Background="Transparent"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="📁" FontSize="64" HorizontalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource DragDrop.Overlay}" FontSize="22" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,12,0,4"/>
                    <TextBlock Text="{DynamicResource DragDrop.Overlay.Sub}" FontSize="13"
                               Foreground="#88FFFFFF" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Border>

    </Grid>
</Window>
