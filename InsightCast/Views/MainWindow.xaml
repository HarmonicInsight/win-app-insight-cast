<Window x:Class="InsightCast.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:InsightCast.Converters"
        xmlns:views="clr-namespace:InsightCast.Views"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        Title="{Binding WindowTitle}"
        MinWidth="1100" MinHeight="750"
        Width="1300" Height="950"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
    </Window.Resources>

    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.New" Executed="NewProject_Executed"/>
        <CommandBinding Command="ApplicationCommands.Open" Executed="OpenProject_Executed"/>
        <CommandBinding Command="ApplicationCommands.Save" Executed="SaveProject_Executed"/>
    </Window.CommandBindings>

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="ApplicationCommands.New"/>
        <KeyBinding Key="O" Modifiers="Control" Command="ApplicationCommands.Open"/>
        <KeyBinding Key="S" Modifiers="Control" Command="ApplicationCommands.Save"/>
    </Window.InputBindings>

    <!-- Resize hit-test area (nearly transparent background needed for hit-testing) -->
    <Grid Background="#01000000">
    <Border Background="{DynamicResource BgPrimary}"
            BorderBrush="{DynamicResource BorderDefault}"
            BorderThickness="1"
            CornerRadius="8"
            Margin="4"
            ClipToBounds="False">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48" MinHeight="48"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ================================================================ -->
            <!-- A) Header / Custom Title Bar                                      -->
            <!-- ================================================================ -->
            <Border Grid.Row="0" Background="{DynamicResource BgSecondary}"
                    CornerRadius="8,8,0,0"
                    Panel.ZIndex="100"
                    Height="48"
                    MinHeight="48"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left side: Product name, version, plan badge -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                        <TextBlock Text="Insight Training Studio" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrandPrimary}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="VersionLabel" Text="v1.0.0" FontSize="11"
                                   Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        <Border x:Name="PlanBadge" Background="{DynamicResource BrandLight}"
                                CornerRadius="4" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="PlanBadgeText" Text="{Binding PlanDisplayName}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrandPrimary}"/>
                        </Border>
                        <TextBlock Text="{DynamicResource App.Subtitle}" FontSize="11"
                                   Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>

                    <!-- Right side: window controls -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- AI Assistant toggle -->
                        <Button x:Name="AiToggleButton" Click="AiToggleButton_Click"
                                Style="{DynamicResource TitleBarButtonStyle}"
                                ToolTip="{DynamicResource Chat.ToggleTooltip}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,4,0"
                                           VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock Text="AI" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondary}"/>
                            </StackPanel>
                        </Button>

                        <Rectangle Width="1" Height="20" Fill="{DynamicResource BorderDefault}" Margin="4,0"/>

                        <!-- Minimize -->
                        <Button x:Name="MinimizeButton" Click="MinimizeButton_Click"
                                Style="{DynamicResource WindowControlButtonStyle}"
                                ToolTip="{DynamicResource Window.Minimize}">
                            <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                        </Button>

                        <!-- Maximize/Restore -->
                        <Button x:Name="MaximizeButton" Click="MaximizeButton_Click"
                                Style="{DynamicResource WindowControlButtonStyle}"
                                ToolTip="{DynamicResource Window.Maximize}">
                            <TextBlock x:Name="MaximizeIcon" Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                        </Button>

                        <!-- Close -->
                        <Button x:Name="CloseButton" Click="CloseButton_Click"
                                Style="{DynamicResource CloseButtonStyle}"
                                ToolTip="{DynamicResource Window.Close}">
                            <TextBlock Text="&#xE106;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

        <!-- ================================================================ -->
        <!-- B) Syncfusion Ribbon with Backstage                               -->
        <!-- ================================================================ -->
        <syncfusion:Ribbon Grid.Row="1" x:Name="MainRibbon"
                           Panel.ZIndex="1"
                           Margin="0"
                           ShowCustomizeRibbon="False"
                           EnableMoreCommands="False"
                           EnableSimplifiedLayoutMode="False"
                           RibbonState="Normal"
                           FontFamily="Yu Gothic UI, Meiryo UI, Segoe UI"
                           FontSize="12"
                           BackStageHeader="{DynamicResource Ribbon.File}"
                           BackStageColor="{DynamicResource BrandPrimary}">

            <!-- Backstage (File Menu) -->
            <syncfusion:Ribbon.BackStage>
                <syncfusion:Backstage x:Name="BackStageControl">
                    <syncfusion:BackStageCommandButton Header="{DynamicResource Backstage.New}" Click="BackStageNew_Click"/>
                    <syncfusion:BackStageCommandButton Header="{DynamicResource Backstage.Open}" Click="BackStageOpen_Click"/>
                    <syncfusion:BackStageCommandButton Header="{DynamicResource Backstage.Save}" Click="BackStageSave_Click"/>
                    <syncfusion:BackStageCommandButton Header="{DynamicResource Backstage.SaveAs}" Click="BackStageSaveAs_Click"/>
                    <syncfusion:BackStageSeparator/>
                    <syncfusion:BackstageTabItem Header="{DynamicResource Backstage.Recent}" IsSelected="True">
                        <Grid Margin="16,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{DynamicResource Backstage.Recent}" FontSize="18" FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="BackstageRecentFiles">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Click="BackStageRecentFile_Click" Tag="{Binding FullPath}"
                                                    Cursor="Hand" Background="Transparent" BorderThickness="0"
                                                    HorizontalContentAlignment="Stretch" Padding="8,6" Margin="0,2">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#E8E8E8"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding FileName}" FontSize="13" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding FullPath}" FontSize="11"
                                                                   Foreground="#888888" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding LastAccessedDisplay}" FontSize="11"
                                                               Foreground="#888888" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </syncfusion:BackstageTabItem>
                    <syncfusion:BackStageSeparator/>
                    <syncfusion:BackStageCommandButton Header="{DynamicResource Backstage.ImportPptx}" Click="BackStageImportPptx_Click"/>
                    <syncfusion:BackStageCommandButton Header="{DynamicResource Backstage.ImportJson}" Click="BackStageImportJson_Click"/>
                    <syncfusion:BackStageCommandButton Header="{DynamicResource Backstage.BatchExport}" Click="BackStageBatchExport_Click"/>
                    <syncfusion:BackStageSeparator/>
                    <syncfusion:BackstageTabItem Header="{DynamicResource Backstage.Language}">
                        <Grid Margin="16,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{DynamicResource Backstage.Language}" FontSize="18" FontWeight="SemiBold"
                                       Margin="0,0,0,16"/>
                            <StackPanel Grid.Row="1">
                                <RadioButton x:Name="LangJaRadio" Content="日本語" GroupName="Language"
                                             Checked="BackStageLanguageRadio_Checked" Tag="ja"
                                             FontSize="14" Margin="0,0,0,12"/>
                                <RadioButton x:Name="LangEnRadio" Content="English" GroupName="Language"
                                             Checked="BackStageLanguageRadio_Checked" Tag="en"
                                             FontSize="14"/>
                            </StackPanel>
                        </Grid>
                    </syncfusion:BackstageTabItem>
                    <syncfusion:BackStageSeparator/>
                    <syncfusion:BackStageCommandButton Header="{DynamicResource Backstage.License}" Click="BackStageLicense_Click"/>
                    <syncfusion:BackStageSeparator/>
                    <syncfusion:BackStageCommandButton Header="{DynamicResource Common.Close}" Click="BackStageExit_Click"/>
                </syncfusion:Backstage>
            </syncfusion:Ribbon.BackStage>

            <!-- Home Tab -->
            <syncfusion:RibbonTab Caption="{DynamicResource Ribbon.Tab.Home}">
                <!-- Scene Group -->
                <syncfusion:RibbonBar Header="{DynamicResource Ribbon.Group.Scene}" IsLauncherButtonVisible="False">
                    <syncfusion:RibbonButton Label="{DynamicResource Ribbon.Scene.Add}"
                            Command="{Binding AddSceneCommand}" SizeForm="Small">
                        <syncfusion:RibbonButton.IconTemplate>
                            <DataTemplate><TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate>
                        </syncfusion:RibbonButton.IconTemplate>
                    </syncfusion:RibbonButton>
                    <syncfusion:RibbonButton Label="{DynamicResource Ribbon.Scene.Remove}"
                            Command="{Binding RemoveSceneCommand}" SizeForm="Small">
                        <syncfusion:RibbonButton.IconTemplate>
                            <DataTemplate><TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate>
                        </syncfusion:RibbonButton.IconTemplate>
                    </syncfusion:RibbonButton>
                    <syncfusion:RibbonButton Label="{DynamicResource Ribbon.Scene.MoveUp}"
                            Command="{Binding MoveSceneUpCommand}" SizeForm="Small">
                        <syncfusion:RibbonButton.IconTemplate>
                            <DataTemplate><TextBlock Text="&#xE74A;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate>
                        </syncfusion:RibbonButton.IconTemplate>
                    </syncfusion:RibbonButton>
                    <syncfusion:RibbonButton Label="{DynamicResource Ribbon.Scene.MoveDown}"
                            Command="{Binding MoveSceneDownCommand}" SizeForm="Small">
                        <syncfusion:RibbonButton.IconTemplate>
                            <DataTemplate><TextBlock Text="&#xE74B;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate>
                        </syncfusion:RibbonButton.IconTemplate>
                    </syncfusion:RibbonButton>
                </syncfusion:RibbonBar>

                <!-- Export Group -->
                <syncfusion:RibbonBar Header="{DynamicResource Ribbon.Group.Export}" IsLauncherButtonVisible="False">
                    <syncfusion:RibbonButton Label="{DynamicResource Ribbon.Export.Video}"
                            Command="{Binding ExportVideoCommand}" SizeForm="Small">
                        <syncfusion:RibbonButton.IconTemplate>
                            <DataTemplate><TextBlock Text="&#xE714;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate>
                        </syncfusion:RibbonButton.IconTemplate>
                    </syncfusion:RibbonButton>
                    <syncfusion:RibbonButton Label="{DynamicResource Ribbon.Export.Preview}"
                            Command="{Binding PreviewSceneCommand}" SizeForm="Small">
                        <syncfusion:RibbonButton.IconTemplate>
                            <DataTemplate><TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate>
                        </syncfusion:RibbonButton.IconTemplate>
                    </syncfusion:RibbonButton>
                </syncfusion:RibbonBar>

                <!-- Template Group -->
                <syncfusion:RibbonBar Header="{DynamicResource Ribbon.Group.Template}" IsLauncherButtonVisible="False">
                    <syncfusion:RibbonButton Label="{DynamicResource Ribbon.Template.Save}"
                            Command="{Binding SaveTemplateCommand}" SizeForm="Small">
                        <syncfusion:RibbonButton.IconTemplate>
                            <DataTemplate><TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate>
                        </syncfusion:RibbonButton.IconTemplate>
                    </syncfusion:RibbonButton>
                    <syncfusion:RibbonButton Label="{DynamicResource Ribbon.Template.Load}"
                            Command="{Binding LoadTemplateCommand}" SizeForm="Small">
                        <syncfusion:RibbonButton.IconTemplate>
                            <DataTemplate><TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate>
                        </syncfusion:RibbonButton.IconTemplate>
                    </syncfusion:RibbonButton>
                    <syncfusion:RibbonButton Label="{DynamicResource Ribbon.Template.OpenOutput}"
                            Command="{Binding OpenOutputFolderCommand}" SizeForm="Small">
                        <syncfusion:RibbonButton.IconTemplate>
                            <DataTemplate><TextBlock Text="&#xE8DA;" FontFamily="Segoe MDL2 Assets" FontSize="16"/></DataTemplate>
                        </syncfusion:RibbonButton.IconTemplate>
                    </syncfusion:RibbonButton>
                </syncfusion:RibbonBar>
            </syncfusion:RibbonTab>
        </syncfusion:Ribbon>

        <!-- ================================================================ -->
        <!-- C) Main Content - TabControl + AI Panel                           -->
        <!-- ================================================================ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition x:Name="AiPanelColumn" Width="0" MinWidth="0" MaxWidth="800"/>
            </Grid.ColumnDefinitions>

        <TabControl Grid.Column="0" Margin="4,4,4,2" x:Name="MainTabControl"
                    SelectionChanged="MainTabControl_SelectionChanged">
            <!-- 企画・制作タブ -->
            <TabItem Header="{DynamicResource Tab.Planning}">
                <views:PlanningTab x:Name="PlanningTabControl"/>
            </TabItem>

            <!-- 動画生成タブ -->
            <TabItem Header="{DynamicResource Tab.VideoGeneration}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- シーン編集エリア -->
                    <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" MinWidth="140" MaxWidth="300"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Scene List -->
            <GroupBox Grid.Column="0" Header="{DynamicResource Scene.List}" Padding="4">
                <DockPanel>
                    <!-- 解像度選択（上部） -->
                    <Border DockPanel.Dock="Top" Background="{DynamicResource BgSecondary}"
                            CornerRadius="4" Padding="6" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Export.Resolution}" FontSize="10"
                                       Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,4"/>
                            <ComboBox SelectedIndex="{Binding SelectedResolutionIndex}" FontSize="11"
                                     ToolTip="{DynamicResource Export.Resolution.Tooltip}">
                                <ComboBoxItem Content="{DynamicResource Resolution.Landscape}" Tag="1920x1080"/>
                                <ComboBoxItem Content="{DynamicResource Resolution.Portrait}" Tag="1080x1920"/>
                                <ComboBoxItem Content="{DynamicResource Resolution.Square}" Tag="1080x1080"/>
                                <ComboBoxItem Content="{DynamicResource Resolution.Shorts}" Tag="1080x1920"/>
                                <ComboBoxItem Content="{DynamicResource Resolution.TikTok}" Tag="1080x1920"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                                HorizontalAlignment="Center" Margin="0,4,0,0">
                        <Button Content="{DynamicResource Common.Add}" Padding="4,2" Margin="1"
                                Command="{Binding AddSceneCommand}"/>
                        <Button Content="{DynamicResource Common.Remove}" Padding="4,2" Margin="1"
                                Command="{Binding RemoveSceneCommand}"/>
                        <Button Content="↑" Padding="6,2" Margin="1"
                                Command="{Binding MoveSceneUpCommand}"/>
                        <Button Content="↓" Padding="6,2" Margin="1"
                                Command="{Binding MoveSceneDownCommand}"/>
                    </StackPanel>
                    <ListBox x:Name="SceneListBox"
                             ItemsSource="{Binding SceneItems}"
                             SelectedIndex="{Binding SelectedSceneIndex}"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,1">
                                    <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" Margin="0,0,0,2"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Border CornerRadius="2" Padding="3,1" Margin="0,0,2,0" MinWidth="28">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource BorderLight}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StepMediaDone}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource Success}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{DynamicResource Progress.Media}" FontSize="9" HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextTertiary}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StepMediaDone}" Value="True">
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                        <TextBlock Text="›" VerticalAlignment="Center" Foreground="{DynamicResource TextTertiary}" Margin="0,0,2,0" FontSize="10"/>
                                        <Border CornerRadius="2" Padding="3,1" Margin="0,0,2,0" MinWidth="28">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource BorderLight}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StepNarrationDone}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource Success}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{DynamicResource Progress.Narration}" FontSize="9" HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextTertiary}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StepNarrationDone}" Value="True">
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                        <TextBlock Text="›" VerticalAlignment="Center" Foreground="{DynamicResource TextTertiary}" Margin="0,0,2,0" FontSize="10"/>
                                        <Border CornerRadius="2" Padding="3,1" MinWidth="28">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource BorderLight}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StepSubtitleDone}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource Success}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{DynamicResource Progress.Subtitle}" FontSize="9" HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextTertiary}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StepSubtitleDone}" Value="True">
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </GroupBox>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{DynamicResource BorderDefault}"/>

            <!-- Right Panel: Scene Editor -->
            <GroupBox Grid.Column="2" Padding="4">
                <GroupBox.Header>
                    <StackPanel Orientation="Horizontal" DataContext="{Binding CurrentSceneItem}">
                        <TextBlock Text="{DynamicResource Scene.Editor}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <!-- 素材 chevron -->
                        <Border CornerRadius="3" Padding="10,3" Margin="0,0,4,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource BorderLight}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StepMediaDone}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Success}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{DynamicResource Progress.Media}" FontSize="11" HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextTertiary}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StepMediaDone}" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                        <TextBlock Text="›" VerticalAlignment="Center" Foreground="{DynamicResource TextTertiary}" Margin="0,0,4,0" FontSize="14"/>
                        <!-- ナレーション chevron -->
                        <Border CornerRadius="3" Padding="10,3" Margin="0,0,4,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource BorderLight}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StepNarrationDone}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Success}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{DynamicResource Progress.Narration}" FontSize="11" HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextTertiary}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StepNarrationDone}" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                        <TextBlock Text="›" VerticalAlignment="Center" Foreground="{DynamicResource TextTertiary}" Margin="0,0,4,0" FontSize="14"/>
                        <!-- 字幕 chevron -->
                        <Border CornerRadius="3" Padding="10,3">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource BorderLight}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StepSubtitleDone}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Success}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{DynamicResource Progress.Subtitle}" FontSize="11" HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextTertiary}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StepSubtitleDone}" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </GroupBox.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="8">

                        <!-- Media info -->
                        <DockPanel Margin="0,0,0,4">
                            <Button DockPanel.Dock="Right" Content="{DynamicResource Tool.Snipaste}" Padding="10,3" Margin="2"
                                    ToolTip="{DynamicResource Tool.Snipaste.Tooltip}"
                                    Command="{Binding LaunchSnipasteCommand}"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource Scene.Media}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding MediaName}" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondary}" MinWidth="120" Margin="0,0,8,0"/>
                                <Button Content="{DynamicResource Common.Select}" Padding="10,3" Margin="2"
                                        Command="{Binding SelectMediaCommand}"/>
                                <Button Content="{DynamicResource Common.Clear}" Padding="10,3" Margin="2"
                                        Command="{Binding ClearMediaCommand}"/>
                            </StackPanel>
                        </DockPanel>

                        <!-- Preview + Narration -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="120" Height="180"
                                    Background="#1a1a2e" CornerRadius="2" Margin="0,0,8,0" ClipToBounds="True"
                                    Cursor="Hand" MouseLeftButtonUp="PreviewImage_Click"
                                    ToolTip="{DynamicResource Preview.ClickToEnlarge}">
                                <Grid>
                                    <Image x:Name="PreviewImage" Stretch="Uniform"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <!-- Text overlay preview layer -->
                                    <ItemsControl ItemsSource="{Binding OverlayPreviewItems}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><Canvas/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding CanvasLeft}"/>
                                                <Setter Property="Canvas.Top" Value="{Binding CanvasTop}"/>
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Text}" FontSize="{Binding PreviewFontSize}"
                                                           FontWeight="{Binding FontWeightValue}" Opacity="{Binding Opacity}"
                                                           MaxWidth="112" TextWrapping="Wrap" TextAlignment="{Binding TextAlignmentValue}">
                                                    <TextBlock.Foreground><SolidColorBrush Color="{Binding TextColorValue}"/></TextBlock.Foreground>
                                                    <TextBlock.Effect><DropShadowEffect ShadowDepth="1" BlurRadius="2" Color="Black" Opacity="0.8"/></TextBlock.Effect>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <!-- Subtitle overlay -->
                                    <Border VerticalAlignment="Bottom" Background="#80000000" Padding="4,2">
                                        <TextBlock Text="{Binding SubtitleText}" Foreground="White"
                                                   FontSize="9" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="112"/>
                                    </Border>
                                    <!-- Zoom icon -->
                                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Background="#80000000" CornerRadius="0,0,0,4" Padding="4">
                                        <Path Data="M9,0 A9,9 0 1 0 9,18 A9,9 0 1 0 9,0 M15,15 L20,20"
                                              Stroke="White" StrokeThickness="1.5" Width="16" Height="16"
                                              Stretch="Uniform"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <Grid Grid.Column="1">
                                <TextBox x:Name="NarrationTextBox"
                                         Text="{Binding NarrationText, UpdateSourceTrigger=PropertyChanged}"
                                         TextWrapping="Wrap" AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto" MinHeight="140"
                                         VerticalContentAlignment="Top" Padding="4"/>
                                <TextBlock Text="{DynamicResource Scene.Narration.Placeholder}"
                                           Foreground="{DynamicResource TextPlaceholder}" FontStyle="Italic"
                                           IsHitTestVisible="False" Margin="8,6,0,0" VerticalAlignment="Top"
                                           Visibility="{Binding NarrationPlaceholderVisible, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </Grid>

                        <!-- Speaker + Audio controls -->
                        <WrapPanel Margin="0,0,0,4">
                            <TextBlock Text="{DynamicResource Scene.Speaker}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <ComboBox MinWidth="180" Margin="0,0,12,0"
                                      ItemsSource="{Binding SceneSpeakers}"
                                      SelectedIndex="{Binding SelectedSceneSpeakerIndex}"
                                      DisplayMemberPath="DisplayName"/>
                            <CheckBox Content="{DynamicResource Scene.KeepAudio}"
                                      IsChecked="{Binding KeepOriginalAudio}"
                                      VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <Button Content="{DynamicResource Scene.PreviewAudio}" Padding="8,3" Margin="2"
                                    Command="{Binding PreviewAudioCommand}"
                                    ToolTip="{DynamicResource Scene.PreviewAudio.Tooltip}"
                                    AutomationProperties.Name="Preview Audio"/>
                            <Button Content="{DynamicResource Scene.PreviewScene}" Padding="8,3" Margin="2"
                                    Command="{Binding PreviewSceneCommand}"
                                    ToolTip="{DynamicResource Scene.PreviewScene.Tooltip}"
                                    AutomationProperties.Name="Preview Scene"/>
                            <Button Content="{DynamicResource Scene.Stop}" Padding="8,3" Margin="2"
                                    Command="{Binding StopPreviewCommand}"
                                    ToolTip="{DynamicResource Scene.Stop.Tooltip}"/>
                            <TextBlock Text="{DynamicResource Scene.SpeechSpeed}" VerticalAlignment="Center" Margin="12,0,4,0"/>
                            <ComboBox Width="90" ItemsSource="{Binding SpeechSpeedOptions}"
                                      SelectedIndex="{Binding SelectedSpeechSpeedIndex}"/>
                        </WrapPanel>

                        <!-- Subtitle -->
                        <StackPanel Margin="0,0,0,4">
                            <DockPanel Margin="0,0,0,4">
                                <TextBlock Text="{DynamicResource Scene.Subtitle}" VerticalAlignment="Center" DockPanel.Dock="Left"/>
                                <!-- B9: Copy narration to subtitle -->
                                <Button Content="{DynamicResource Scene.CopyNarration}" Padding="6,2" Margin="8,0,0,0"
                                        FontSize="10" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                        Command="{Binding CopyNarrationToSubtitleCommand}"
                                        IsEnabled="{Binding CanSubtitle}"
                                        ToolTip="{DynamicResource Scene.CopyNarration.Tooltip}"/>
                            </DockPanel>
                            <Grid>
                                <TextBox Text="{Binding SubtitleText, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="4" MinHeight="50" MaxHeight="100"
                                         TextWrapping="Wrap" AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         VerticalContentAlignment="Top"
                                         IsEnabled="{Binding CanSubtitle}"
                                         ToolTip="{DynamicResource Scene.Subtitle.Tooltip}"/>
                                <TextBlock Text="{Binding SubtitlePlaceholder}"
                                           Foreground="{DynamicResource TextPlaceholder}" FontStyle="Italic"
                                           IsHitTestVisible="False" Margin="8,6,0,0" VerticalAlignment="Top"
                                           Visibility="{Binding SubtitlePlaceholderVisible, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </StackPanel>

                        <!-- Detail mode only sections -->
                        <!-- Subtitle style -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
                                    Visibility="{Binding IsDetailMode, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{DynamicResource Scene.SubtitleStyle}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Border BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1"
                                    CornerRadius="2" Padding="8,2" Margin="0,0,8,0" Background="#1a1a2e" MinWidth="40">
                                <TextBlock x:Name="StylePreviewLabel" Text="A" FontSize="16" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Center"/>
                            </Border>
                            <Button Content="{DynamicResource Scene.SubtitleStyle.Select}" Padding="10,3" Margin="2"
                                    Command="{Binding OpenStyleDialogCommand}" IsEnabled="{Binding CanSubtitleStyle}"/>
                        </StackPanel>

                        <!-- Text Overlays -->
                        <StackPanel Margin="0,4,0,4" Visibility="{Binding IsDetailMode, Converter={StaticResource BoolToVis}}">
                            <DockPanel Margin="0,0,0,4">
                                <TextBlock Text="{DynamicResource Overlay.Title}" VerticalAlignment="Center" DockPanel.Dock="Left"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="{DynamicResource Common.Add}" Padding="6,2" Margin="2"
                                            Command="{Binding AddOverlayCommand}"/>
                                    <Button Content="{DynamicResource Overlay.CoverTemplate}" Padding="6,2" Margin="2"
                                            Command="{Binding AddCoverTemplateCommand}"/>
                                    <Button Content="{DynamicResource Common.Remove}" Padding="6,2" Margin="2"
                                            Command="{Binding RemoveOverlayCommand}"/>
                                </StackPanel>
                            </DockPanel>
                            <!-- Overlay list with reorder buttons -->
                            <DockPanel Visibility="{Binding OverlayListVisible, Converter={StaticResource BoolToVis}}">
                                <StackPanel DockPanel.Dock="Right" Margin="4,0,0,0" VerticalAlignment="Center">
                                    <Button Content="▲" Padding="4,2" Margin="0,0,0,2" FontSize="10"
                                            Command="{Binding MoveOverlayUpCommand}"
                                            ToolTip="{DynamicResource Overlay.MoveUp.Tooltip}"/>
                                    <Button Content="▼" Padding="4,2" FontSize="10"
                                            Command="{Binding MoveOverlayDownCommand}"
                                            ToolTip="{DynamicResource Overlay.MoveDown.Tooltip}"/>
                                </StackPanel>
                                <ListBox ItemsSource="{Binding OverlayItems}"
                                         SelectedIndex="{Binding SelectedOverlayIndex}"
                                         Height="80" HorizontalContentAlignment="Stretch">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="6" Height="14" CornerRadius="1" Margin="0,0,6,0"
                                                        VerticalAlignment="Center">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="{Binding ColorIndicator}"/>
                                                    </Border.Background>
                                                </Border>
                                                <TextBlock Text="{Binding DisplayLabel}" FontSize="11"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                            <Border BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1"
                                    CornerRadius="3" Padding="8,6" Margin="0,4,0,0"
                                    Visibility="{Binding OverlayEditorVisible, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <!-- Text input -->
                                    <DockPanel Margin="0,0,0,4">
                                        <TextBlock Text="{DynamicResource Overlay.Text}" FontSize="11"
                                                   VerticalAlignment="Top" Margin="0,4,8,0" DockPanel.Dock="Left"/>
                                        <TextBox Text="{Binding OverlayText, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="4" MinHeight="24" MaxHeight="60"
                                                 TextWrapping="Wrap" AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 VerticalContentAlignment="Top"/>
                                    </DockPanel>
                                    <!-- All settings in one row -->
                                    <WrapPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                                            <TextBlock Text="{DynamicResource Overlay.XPosition}" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBox Text="{Binding OverlayXPercent, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="50" TextAlignment="Center" VerticalContentAlignment="Center"/>
                                            <TextBlock Text="%" FontSize="11" VerticalAlignment="Center" Margin="2,0,0,0"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                                            <TextBlock Text="{DynamicResource Overlay.YPosition}" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBox Text="{Binding OverlayYPercent, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="50" TextAlignment="Center" VerticalContentAlignment="Center"/>
                                            <TextBlock Text="%" FontSize="11" VerticalAlignment="Center" Margin="2,0,0,0"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                                            <TextBlock Text="{DynamicResource Overlay.FontSize}" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBox Text="{Binding OverlayFontSize, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="60" TextAlignment="Center" VerticalContentAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                                            <TextBlock Text="{DynamicResource Overlay.Alignment}" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <ComboBox Width="70" ItemsSource="{Binding AlignmentOptions}"
                                                      SelectedIndex="{Binding SelectedAlignmentIndex}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                                            <TextBlock Text="{DynamicResource Overlay.Color}" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <ComboBox Width="70" ItemsSource="{Binding OverlayColorOptions}"
                                                      SelectedIndex="{Binding SelectedOverlayColorIndex}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                            <TextBlock Text="{DynamicResource Overlay.Opacity}" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <Slider Width="80" Minimum="0" Maximum="100"
                                                    Value="{Binding OverlayOpacitySlider}"
                                                    TickFrequency="5" IsSnapToTickEnabled="True"
                                                    VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding OverlayOpacityDisplay}" FontSize="11"
                                                       VerticalAlignment="Center" Width="36" Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Duration mode -->
                        <StackPanel Margin="0,0,0,4" Visibility="{Binding IsDetailMode, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{DynamicResource Duration.Title}" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="{DynamicResource Duration.Auto}" IsChecked="{Binding IsAutoDuration}"
                                             VerticalAlignment="Center" Margin="0,0,16,0" GroupName="DurationMode"/>
                                <RadioButton Content="{DynamicResource Duration.Fixed}" IsChecked="{Binding IsFixedDuration}"
                                             VerticalAlignment="Center" Margin="0,0,8,0" GroupName="DurationMode"/>
                                <TextBox Text="{Binding DurationSeconds, UpdateSourceTrigger=PropertyChanged}"
                                         Width="60" TextAlignment="Center" Margin="0,0,4,0" IsEnabled="{Binding IsFixedDuration}"/>
                                <TextBlock Text="{DynamicResource Duration.Range}" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextTertiary}" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Transition -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
                                    Visibility="{Binding IsDetailMode, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{DynamicResource Transition.Title}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox Width="160" Margin="0,0,12,0"
                                      ItemsSource="{Binding TransitionDisplayNames}"
                                      SelectedIndex="{Binding SelectedTransitionIndex}"
                                      IsEnabled="{Binding CanTransition}"
                                      ToolTip="{DynamicResource Transition.Tooltip}"/>
                            <TextBlock Text="{DynamicResource Transition.Duration}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox Text="{Binding TransitionDuration, UpdateSourceTrigger=PropertyChanged}"
                                     Width="60" TextAlignment="Center" Margin="0,0,4,0" IsEnabled="{Binding CanTransition}"
                                     ToolTip="{DynamicResource Transition.Duration.Tooltip}"/>
                            <TextBlock Text="{DynamicResource Transition.Range}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextTertiary}" FontSize="11"/>
                            <!-- B10: Apply transition to all scenes -->
                            <Button Content="{DynamicResource Transition.ApplyAll}" Padding="6,2" Margin="8,0,0,0"
                                    FontSize="10" Command="{Binding ApplyTransitionToAllCommand}"
                                    IsEnabled="{Binding CanTransition}"
                                    ToolTip="{DynamicResource Transition.ApplyAll.Tooltip}"/>
                        </StackPanel>

                        <!-- Watermark -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
                                    Visibility="{Binding IsDetailMode, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{DynamicResource Watermark.Title}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding WatermarkFileName}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                       MinWidth="80" MaxWidth="140" TextTrimming="CharacterEllipsis" Margin="0,0,4,0"/>
                            <Button Content="{DynamicResource Common.Select}" Padding="6,2" Margin="1"
                                    Command="{Binding SelectWatermarkCommand}"/>
                            <Button Content="✕" Padding="4,2" Margin="1"
                                    Command="{Binding ClearWatermarkCommand}"/>
                            <TextBlock Text="{DynamicResource Watermark.Position}" VerticalAlignment="Center" Margin="12,0,4,0"/>
                            <ComboBox Width="80" ItemsSource="{Binding WatermarkPositionOptions}"
                                      SelectedIndex="{Binding SelectedWatermarkPosIndex}"/>
                        </StackPanel>

                        <!-- Template -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
                                    Visibility="{Binding IsDetailMode, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{DynamicResource Template.Title}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Button Content="{DynamicResource Common.Save}" Padding="8,3" Margin="2"
                                    Command="{Binding SaveTemplateCommand}"/>
                            <Button Content="{DynamicResource Common.Load}" Padding="8,3" Margin="2"
                                    Command="{Binding LoadTemplateCommand}"/>
                            <Button Content="{DynamicResource Template.OpenOutput}" Padding="8,3" Margin="12,2,2,2"
                                    Command="{Binding OpenOutputFolderCommand}"/>
                        </StackPanel>

                        <!-- Info label -->
                        <TextBlock Text="{DynamicResource Duration.Info}"
                                   TextWrapping="Wrap" Foreground="{DynamicResource TextTertiary}"
                                   FontSize="11" Margin="0,0,0,0"/>
                    </StackPanel>
                    </ScrollViewer>
            </GroupBox>
                    </Grid>

                    <!-- Export Panel (動画生成タブ内) -->
                    <GroupBox Grid.Row="1" Header="{DynamicResource Export.Settings}" Margin="0,4,0,0" Padding="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <WrapPanel Grid.Column="0" VerticalAlignment="Center">
                    <!-- FPS: Detail mode only -->
                    <StackPanel Orientation="Horizontal" Margin="0,2,12,2"
                                Visibility="{Binding IsDetailMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="FPS:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Text="{Binding FpsText, UpdateSourceTrigger=PropertyChanged}"
                                 Width="60" TextAlignment="Center"/>
                    </StackPanel>

                    <!-- BGM: Detail mode only -->
                    <StackPanel Orientation="Horizontal" Margin="0,2,12,2"
                                Visibility="{Binding IsDetailMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding BgmStatusText}" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextTertiary}" Margin="0,0,6,0"/>
                        <Button Content="{DynamicResource Export.BGM.Settings}" Padding="8,3"
                                Command="{Binding BgmSettingsCommand}"/>
                    </StackPanel>
                </WrapPanel>

                <Button Grid.Column="1"
                        Content="{DynamicResource Export.Button}"
                        Width="150" Height="44"
                        FontSize="12" FontWeight="Bold"
                        Style="{DynamicResource PrimaryButton}"
                        Command="{Binding ExportVideoCommand}"
                        ToolTip="{DynamicResource Export.Button.Tooltip}"
                        AutomationProperties.Name="Export Video"/>
            </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>

            <!-- GridSplitter for AI panel resize -->
            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Cursor="SizeWE"
                          Background="{DynamicResource BorderDefault}"
                          Visibility="{Binding DataContext.IsChatOpen, ElementName=ChatPanel, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                <GridSplitter.Style>
                    <Style TargetType="GridSplitter">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentDefault}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </GridSplitter.Style>
            </GridSplitter>

            <!-- AI Assistant Panel -->
            <views:ChatPanelView x:Name="ChatPanel" Grid.Column="2"/>
        </Grid>

        <!-- ================================================================ -->
        <!-- D) ProgressBar                                                    -->
        <!-- ================================================================ -->
        <DockPanel Grid.Row="3" Margin="4,0,4,2"
                   Visibility="{Binding ExportProgressVisible, Converter={StaticResource BoolToVis}}">
            <Button DockPanel.Dock="Right" Content="{DynamicResource Export.Cancel}"
                    Padding="12,2" Margin="4,0,0,0"
                    Command="{Binding CancelExportCommand}"/>
            <ProgressBar Height="6" Minimum="0" Maximum="100"
                         Value="{Binding ExportProgressValue, Mode=OneWay}"/>
        </DockPanel>

        <!-- ================================================================ -->
        <!-- E) Log Area                                                       -->
        <!-- ================================================================ -->
        <DockPanel Grid.Row="4" Height="120" Margin="4,0,4,4">
            <TextBlock Text="{DynamicResource Export.Log}" DockPanel.Dock="Top" FontSize="11"
                       Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
            <TextBox x:Name="LogTextBox" IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap" FontSize="11" FontFamily="Consolas, MS Gothic"
                     Background="{DynamicResource BgSecondary}"/>
        </DockPanel>

            <MediaElement x:Name="AudioPlayer" Grid.Row="4"
                          LoadedBehavior="Manual" UnloadedBehavior="Stop"
                          Visibility="Collapsed" MediaEnded="AudioPlayer_MediaEnded"/>

            </Grid>
        </Border>
    </Grid>
</Window>
