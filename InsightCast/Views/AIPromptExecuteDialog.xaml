<Window x:Class="InsightCast.Views.AIPromptExecuteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource AIPrompt.DialogTitle}" Height="520" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        MinHeight="400" MinWidth="380"
        Background="{DynamicResource BgPrimary}">

    <Window.Resources>
        <Style x:Key="PromptListItem" TargetType="Border">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="ExecuteButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#9C27B0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#7B1FA2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                           Foreground="#9C27B0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{DynamicResource AIPrompt.DialogTitle}"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"/>
            </StackPanel>
            <TextBlock Text="{DynamicResource AIPrompt.DialogDesc}" FontSize="12"
                       Foreground="{DynamicResource TextSecondary}" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- Row 1: Search -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <TextBox x:Name="SearchBox" FontSize="13" Padding="32,8,8,8"
                     TextChanged="SearchBox_TextChanged" VerticalContentAlignment="Center">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                            <VisualBrush.Visual>
                                                <Label Content="{DynamicResource AIPrompt.SearchPlaceholder}"
                                                       Foreground="LightGray" FontSize="13" Padding="32,0,0,0"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                       Foreground="{DynamicResource TextTertiary}"
                       VerticalAlignment="Center" Margin="10,0,0,0" IsHitTestVisible="False"/>
        </Grid>

        <!-- Row 2: Section Header -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="&#xE99A;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                       Foreground="#9C27B0" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBlock Text="{DynamicResource AIPrompt.ToolEnabledPrompts}"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondary}"/>
        </StackPanel>

        <!-- Row 3: Prompt List -->
        <Grid Grid.Row="3">
            <ListBox x:Name="PromptList" FontSize="13"
                     SelectionChanged="PromptList_SelectionChanged"
                     MouseDoubleClick="PromptList_DoubleClick"
                     HorizontalContentAlignment="Stretch"
                     BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource PromptListItem}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <!-- Icon + Name -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" FontSize="14"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <!-- Mode badge (check = auto-apply, advice = suggestions) -->
                                <Border Grid.Row="0" Grid.Column="1" CornerRadius="3" Padding="6,2"
                                        Background="#E8F5E9" Margin="4,0,0,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Mode}" Value="advice">
                                                    <Setter Property="Background" Value="#FFF3E0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="9" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="自動適用"/>
                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Mode}" Value="advice">
                                                        <Setter Property="Text" Value="提案"/>
                                                        <Setter Property="Foreground" Value="#E65100"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                                <!-- Category -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                           Text="{Binding Category}" FontSize="11"
                                           Foreground="{DynamicResource TextSecondary}" Margin="22,3,0,0"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <!-- Empty state -->
            <Border x:Name="EmptyState" Visibility="Collapsed"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Background="{DynamicResource BgSecondary}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                    <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="36"
                               Foreground="{DynamicResource TextTertiary}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource AIPrompt.NoPrompts}" FontSize="13"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,12,0,0"
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Row 4: Buttons -->
        <Grid Grid.Row="4" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <!-- Left: Manage button -->
            <Button Grid.Column="0" Content="{DynamicResource AIPrompt.ManagePrompts}"
                    Click="ManagePrompts_Click" Style="{StaticResource ActionButton}"/>
            <!-- Right: Execute button -->
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="{DynamicResource Common.Cancel}" Click="Cancel_Click"
                        Style="{StaticResource ActionButton}" Margin="0,0,8,0"/>
                <Button x:Name="ExecuteBtn" Content="{DynamicResource AIPrompt.SelectAndRun}"
                        Click="Execute_Click" Style="{StaticResource ExecuteButton}" IsEnabled="False"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
