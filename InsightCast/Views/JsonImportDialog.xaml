<Window x:Class="InsightCast.Views.JsonImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource JsonImport.Title}"
        Width="500" Height="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="100"/>
        </Style>
        <Style x:Key="SectionBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BgCard}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefault}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="Padding" Value="16,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- File Selection -->
        <Border Grid.Row="0" Style="{StaticResource SectionBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="FilePathLabel" Grid.Column="0"
                           Text="{DynamicResource JsonImport.SelectFile}"
                           Foreground="{DynamicResource TextTertiary}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <Button x:Name="BrowseButton" Grid.Column="1"
                        Content="{DynamicResource Common.Select}"
                        Style="{StaticResource DialogButton}"
                        Click="BrowseButton_Click"/>
            </Grid>
        </Border>

        <!-- Preview -->
        <Border Grid.Row="1" Style="{StaticResource SectionBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{DynamicResource JsonImport.Preview}" Style="{StaticResource SectionHeader}"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="PreviewPanel">
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource JsonImport.ProjectName}" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="ProjectNameLabel" Grid.Column="1" Foreground="{DynamicResource TextPrimary}"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource JsonImport.SceneCount}" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="SceneCountLabel" Grid.Column="1" Foreground="{DynamicResource TextPrimary}"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource JsonImport.Resolution}" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="ResolutionLabel" Grid.Column="1" Foreground="{DynamicResource TextPrimary}"/>
                        </Grid>
                        <TextBlock x:Name="ErrorLabel" Foreground="Red" TextWrapping="Wrap" Margin="0,8,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- OK / Cancel Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="ImportButton" Content="{DynamicResource JsonImport.Import}"
                    Style="{StaticResource DialogButton}"
                    IsEnabled="False"
                    IsDefault="True" Click="ImportButton_Click"/>
            <Button Content="{DynamicResource Common.Cancel}"
                    Style="{StaticResource DialogButton}"
                    IsCancel="True" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
