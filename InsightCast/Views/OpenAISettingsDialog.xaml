<Window x:Class="InsightCast.Views.OpenAISettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource OpenAI.Settings.Title}"
        Width="450" Height="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="120"/>
        </Style>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="Padding" Value="16,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <!-- API Key -->
            <TextBlock Text="{DynamicResource OpenAI.ApiKey}" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <PasswordBox x:Name="ApiKeyBox" Grid.Column="0" Height="28" VerticalContentAlignment="Center"
                             ToolTip="{DynamicResource OpenAI.ApiKey.Tooltip}"/>
                <TextBlock x:Name="ApiKeyStatus" Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0"
                           Foreground="{DynamicResource TextTertiary}"/>
            </Grid>

            <!-- Connection Test -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="TestButton" Grid.Column="0" Content="{DynamicResource OpenAI.TestConnection}"
                        Style="{StaticResource DialogButton}" Click="TestButton_Click"
                        ToolTip="{DynamicResource OpenAI.TestConnection.Tooltip}"/>
                <TextBlock x:Name="ConnectionStatus" Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </Grid>

            <!-- Models -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{DynamicResource OpenAI.NarrationModel}" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="NarrationModelCombo" Grid.Column="1" Height="28"
                          ToolTip="{DynamicResource OpenAI.NarrationModel.Tooltip}">
                    <ComboBoxItem Content="gpt-4o" IsSelected="True"/>
                    <ComboBoxItem Content="gpt-4o-mini"/>
                    <ComboBoxItem Content="gpt-4-turbo"/>
                </ComboBox>
            </Grid>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{DynamicResource OpenAI.ImageModel}" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="ImageModelCombo" Grid.Column="1" Height="28"
                          ToolTip="{DynamicResource OpenAI.ImageModel.Tooltip}">
                    <ComboBoxItem Content="dall-e-3" IsSelected="True"/>
                    <ComboBoxItem Content="dall-e-2"/>
                </ComboBox>
            </Grid>
        </StackPanel>

        <!-- OK / Cancel Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="{DynamicResource Common.OK}" Style="{StaticResource DialogButton}"
                    IsDefault="True" Click="OkButton_Click"/>
            <Button Content="{DynamicResource Common.Cancel}" Style="{StaticResource DialogButton}"
                    IsCancel="True" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
