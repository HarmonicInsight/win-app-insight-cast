<Window x:Class="InsightCast.Views.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="InsightCast - ヘルプ"
        Width="1050" Height="740"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource BgPrimary}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/InsightCast;component/Themes/Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <!-- メインコンテンツ -->
    <Grid Margin="12,8,12,12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 目次サイドバー -->
        <Border Grid.Column="0" Background="{StaticResource BgCard}"
                CornerRadius="6" BorderBrush="{StaticResource BorderDefault}"
                BorderThickness="1" Margin="0,0,8,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="16,14,16,8">
                    <TextBlock Text="&#xE897;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               Foreground="{StaticResource BrandPrimary}"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock x:Name="TocHeader" Text="目次"
                               FontSize="13" FontWeight="SemiBold"
                               FontFamily="Yu Gothic UI, Meiryo, Segoe UI"
                               Foreground="{StaticResource BrandPrimary}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- 検索ボックス (C5) -->
                <Border DockPanel.Dock="Top" Margin="8,0,8,8"
                        Background="White" CornerRadius="4"
                        BorderBrush="{StaticResource BorderDefault}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="12" Foreground="{StaticResource TextTertiary}"
                                   VerticalAlignment="Center" Margin="8,0,4,0"/>
                        <TextBox x:Name="SearchBox" Grid.Column="1"
                                 BorderThickness="0" Background="Transparent"
                                 FontSize="12" Padding="2,5"
                                 FontFamily="Yu Gothic UI, Meiryo, Segoe UI"
                                 TextChanged="SearchBox_TextChanged"/>
                        <TextBlock x:Name="SearchPlaceholder" Grid.Column="1"
                                   Text="検索..." FontSize="12" FontStyle="Italic"
                                   Foreground="{StaticResource TextPlaceholder}"
                                   IsHitTestVisible="False" Margin="4,5,0,0"
                                   Visibility="Visible"/>
                    </Grid>
                </Border>

                <ListBox x:Name="NavList"
                         SelectionChanged="OnNavSelectionChanged"
                         Background="Transparent" BorderThickness="0"
                         Padding="4,0"
                         FontFamily="Yu Gothic UI, Meiryo, Segoe UI"
                         FontSize="12.5">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="12,7" />
                            <Setter Property="Margin" Value="4,1" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="Transparent"
                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#F5F0E8" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#F0E6D0" />
                                                <Setter Property="Foreground" Value="#B8942F" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- コンテンツエリア -->
        <Border Grid.Column="1" Background="{StaticResource BgCard}"
                CornerRadius="6" BorderBrush="{StaticResource BorderDefault}"
                BorderThickness="1" ClipToBounds="True">
            <WebBrowser x:Name="HelpBrowser" Navigating="HelpBrowser_Navigating" />
        </Border>
    </Grid>
</Window>
