    <sys:String x:Key="Setup.Welcome.Title">Welcome to Insight Training Studio</sys:String>
    <sys:String x:Key="Setup.Welcome.Subtitle">Let's get started with the initial setup</sys:String>
    <sys:String x:Key="Setup.Welcome.Desc">Insight Training Studio is a tool that automatically generates narrated videos using the VOICEVOX engine.</sys:String>
