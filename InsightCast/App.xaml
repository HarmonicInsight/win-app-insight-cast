<Application x:Class="InsightCast.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- InsightCommon 共通テーマ（Colors, Icons, Styles） -->
                <ResourceDictionary Source="pack://application:,,,/InsightCommon;component/UI/Resources/InsightTheme.xaml"/>
                <!-- アプリ固有スタイル（オーバーライド用） -->
                <ResourceDictionary Source="Themes/Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

</Application>
